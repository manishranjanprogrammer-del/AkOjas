<!-- res/drawable/payment_option_background.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State when the item is selected -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="2dp" android:color="@color/colorPrimary_day_night" /> <!-- Yellow Border -->
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Default, unselected state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="2dp" android:color="@android:color/transparent" /> <!-- No Border -->
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
