<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true" >
        <shape>
            <solid
                android:color="@color/light_sky_bluee" />
            <stroke
                android:width="1dp"
                android:color="@color/light_sky_bluee" />
            <corners
                android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="@color/light_sky_bluee"
                android:endColor="@color/light_sky_bluee"
                android:angle="270" />
            <stroke
                android:width="0dp"
                android:color="@color/light_sky_bluee" />
            <corners
                android:radius="10dp" />
        </shape>
    </item>
</selector>