<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/astro_chat_bg" />
            <stroke android:width="1dp" android:color="@color/lightest_purple" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:angle="270" android:endColor="@color/astro_chat_bg" android:startColor="@color/astro_chat_bg" />
            <stroke android:width="0dp" android:color="@color/white" />
            <corners android:topLeftRadius="@dimen/dimen_8dp"
                android:topRightRadius="@dimen/dimen_8dp"
                android:bottomLeftRadius="@dimen/dimen_8dp"
                android:bottomRightRadius="@dimen/dimen_8dp"/>
        </shape>
    </item>
</selector>