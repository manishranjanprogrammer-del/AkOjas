<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gray shadow. -->
    <item>
        <shape>
            <solid android:color="@color/gray_color" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- White foreground. -->
    <item
        android:bottom="1dp"
        android:right="1dp"
        android:top="1dp"
        android:left="1dp">
        <shape>
            <solid android:color="@color/gray_color" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>