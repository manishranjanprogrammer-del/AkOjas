<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="true">
        <shape>
            <solid android:color="@color/colorPrimary_day_night" />
            <stroke
                android:width="1dp"
                android:color="@color/colorPrimary_day_night" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape>
            <gradient
                android:startColor="@color/light_gray_bg"
                android:endColor="@color/light_gray_bg"
                android:angle="270" />
            <stroke
                android:width="0dp"
                android:color="@color/light_gray_bg" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
