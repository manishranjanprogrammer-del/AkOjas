<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:topRightRadius="@dimen/dimen_20dp"
                android:topLeftRadius="@dimen/dimen_20dp"/>
        </shape>
    </item>


    <item
        android:bottom="0dp"
        android:left="-100dp"
        android:right="-100dp"
        android:top="-20dp">
        <shape
            android:shape="oval">
            <gradient
                android:angle="90"
                android:endColor="#fcaa6f"
                android:startColor="#fcaa6f" />
            <corners
                android:topLeftRadius="20dp"
                android:topRightRadius="20dp" />
        </shape>
    </item>
    <item
        android:bottom="0dp"
        android:left="-100dp"
        android:right="-100dp"
        android:top="-120dp">
        <shape android:shape="oval">
            <solid android:color="@color/colorPrimary_day_night" />
        </shape>
    </item>

</layer-list>
