<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_frame"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/no_change_white"
    android:minHeight="50dp"
    android:orientation="vertical">

    <!-- <LinearLayout
         android:id="@+id/day_background"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:layout_gravity="center"
         android:orientation="vertical">
 -->
    <TextView
        android:id="@+id/day_text1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/reminder"
        android:gravity="left"
        android:paddingLeft="8dp"
        android:paddingTop="4dp"
        android:text="00"
        android:textColor="@color/no_change_black"
        android:textAppearance="@android:style/TextAppearance.Medium" />

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_gravity="right"
        android:layout_marginBottom="4dp"
        android:layout_marginRight="8dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1">


        <ImageView
            android:id="@+id/moon_image"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_moon_light"

            android:visibility="gone" />

        <TextView
            android:id="@+id/day_text2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:shadowColor="@color/white"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="2"
            android:text="00"
            android:textAlignment="center"
            android:textAppearance="@android:style/TextAppearance.Medium"
            android:textColor="@color/red"
            android:textSize="10sp" />

    </FrameLayout>


    <!--</LinearLayout>-->


</LinearLayout>