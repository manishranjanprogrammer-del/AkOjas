<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/bg_card_view_color"
        android:layout_margin="@dimen/live_stat_margin_bottom">


        <LinearLayout
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/unfollow_cancel"
                android:layout_gravity="right"
                android:layout_marginRight="10dp"
                android:src="@drawable/ic_cancel_black"
                android:layout_height="30dp"
                android:layout_width="30dp"
                app:tint="@color/black" />

            <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                android:id="@+id/live_astrologer_image_unfollow"
                android:layout_width="@dimen/live_name_board_height"
                android:layout_height="@dimen/live_name_board_height"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/live_astrologer_name_follow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:singleLine="true"
                android:textAlignment="gravity"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_medium"
                android:textStyle="bold" />

            <TextView
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:id="@+id/live_login_text"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:gravity="center"
                android:textSize="@dimen/tv_size_12"
                android:text="@string/live_unfollowTxt" />

            <LinearLayout
                android:layout_marginTop="10dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:weightSum="2"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1.0dip">


                <Button
                    android:layout_weight="1"
                    style="@style/buttonBackground"
                    android:id="@+id/live_follow_ok_btn"
                    android:layout_height="@dimen/dimen_32dp"
                    android:layout_width="wrap_content"
                    android:textAllCaps="false"
                    android:text="@string/live_unfollow"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>