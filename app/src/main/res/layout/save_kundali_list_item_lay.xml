<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical">

    <TextView
        android:id="@+id/heading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="16dp"
        android:alpha=".6"
        android:text="Recent Kundli"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/list_item_container"
        style="@style/SelectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/genderImage"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@null"
            android:layout_marginBottom="8dp"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_male" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">

                        <TextView
                            android:id="@+id/personName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Amit Sharma"
                            android:textSize="18dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/cloud_icon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:contentDescription="@null"
                            app:tint="@color/colorPrimary_day_night"
                            android:src="@drawable/ic_cloud_queue_24dp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/more_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha=".4"
                        app:tint="@color/black"
                        android:src="@drawable/ic_more_vert_black" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="20dp">

                    <TextView
                        android:id="@+id/birthDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha=".6"
                        android:textColor="@color/black"
                        android:singleLine="true"
                        android:text="12-01-2016" />

                    <TextView
                        android:id="@+id/birthTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="08:01"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/birthPlace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Agra,Utter Pradesh,India"
                        android:visibility="gone" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:alpha=".1"
                    android:background="@color/black" />
            </LinearLayout>


        </LinearLayout>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp">


            <ImageView
                android:id="@+id/genderImage1"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_male" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="3dp"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/personName1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/black"
                            android:text="Amit Sharma"
                            android:textSize="18dp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/cloud_icon1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:src="@drawable/ic_cloud_queue_24dp"
                            app:tint="@color/colorPrimary_day_night" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/cancelButton"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="right"
                        android:alpha=".8"
                        android:textColor="@color/black"
                        android:background="@drawable/ic_cancel_black" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp">

                    <TextView
                        android:id="@+id/birthDate_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="@string/birth_date" />

                    <TextView
                        android:id="@+id/birthDate1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="12-01-2016" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp">

                    <TextView
                        android:id="@+id/birthTime_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="@string/birth_time" />

                    <TextView
                        android:id="@+id/birthTime1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="08:01" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp">

                    <TextView
                        android:id="@+id/birthPlace_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="@string/birth_place" />

                    <TextView
                        android:id="@+id/birthPlace1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:text="Agra,Utter Pradesh,India" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/black"
                    android:layout_gravity="right">

                    <!-- <Button
                         android:id="@+id/editButton"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:paddingTop="10dp"
                         android:paddingBottom="10dp"
                         android:paddingRight="25dp"
                         android:paddingLeft="25dp"
                         android:textColor="@color/black"
                         android:text="EDIT" />

-->
                    <Button
                        android:id="@+id/editButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_dialog_height"
                        android:layout_marginBottom="@dimen/button_dialog_margin_bottom"
                        android:layout_marginTop="@dimen/button_top_margin_small"
                        android:text="@string/edit"
                        android:textAllCaps="false"
                        android:textColor="@color/black"
                        android:textSize="@dimen/button_dialog_text_size" />

                    <!-- <Button
                         android:id="@+id/viewButton"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:paddingTop="10dp"
                         android:paddingBottom="10dp"
                         android:paddingLeft="15dp"
                         android:paddingRight="15dp"
                         android:text="VIEW KUNDLI"
                         android:textColor="@color/white"
                         android:theme="@style/MyDialogeButton"
                         style="@style/MyDialogeButton"/>-->
                    <Button
                        android:id="@+id/viewButton"
                        style="@style/buttonstyle"
                        android:layout_height="@dimen/button_dialog_height"
                        android:layout_marginBottom="@dimen/button_dialog_margin_bottom"
                        android:layout_marginTop="@dimen/button_top_margin_small"
                        android:text="@string/view_kundli"
                        android:textSize="@dimen/button_dialog_text_size"

                        android:theme="@style/buttonstyle"
                        />

                    <!-- <Button
                         android:id="@+id/btnSelect"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:paddingTop="10dp"
                         android:paddingBottom="10dp"
                         android:paddingLeft="15dp"
                         android:paddingRight="15dp"
                         android:text="SELECT"
                         android:textColor="@color/white"
                         android:theme="@style/MyDialogeButton"
                         style="@style/MyDialogeButton"/>-->

                    <Button
                        android:id="@+id/btnSelect"
                        style="@style/buttonstyle"
                        android:layout_height="@dimen/button_dialog_height"
                        android:layout_marginBottom="@dimen/button_dialog_margin_bottom"
                        android:layout_marginTop="@dimen/button_top_margin_small"
                        android:text="@string/select_for_boy"
                        android:textSize="@dimen/button_dialog_text_size"
                        android:theme="@style/buttonstyle"
                        android:visibility="gone"
                        />

                    <Button
                        android:id="@+id/btnSelectgirl"
                        style="@style/buttonstyle"

                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/button_dialog_margin_bottom"
                        android:layout_marginTop="@dimen/button_top_margin_small"
                        android:text="@string/select_for_girl"
                        android:textSize="@dimen/button_dialog_text_size"
                        android:theme="@style/buttonstyle"
                        android:visibility="gone"
                        />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>


