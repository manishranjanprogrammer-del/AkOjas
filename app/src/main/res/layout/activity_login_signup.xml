<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColorView">

    <ImageView
        android:id="@+id/imgViewTopBg"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:scaleType="fitXY"
        android:src="@drawable/top_tech_bg"
        android:layout_alignParentTop="true"/>

    <ImageView
        android:id="@+id/imgViewBottomBg"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:scaleType="fitXY"
        android:src="@drawable/bottum_tech_bg"
        android:layout_alignParentBottom="true"/>
    <LinearLayout
        android:id="@+id/skipRL"
        android:layout_width="match_parent"
        android:layout_height="56dip"
        android:layout_marginTop="@dimen/dimen_15dp"
        android:layout_marginRight="20dp"
        android:orientation="horizontal"
        android:weightSum="1"
        android:gravity="center_vertical"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="right|center_vertical"
            android:layout_weight=".90">

            <ImageView
                android:id="@+id/ivback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="left|center"
                android:src="@drawable/ic_back_arrow"
                android:visibility="invisible">

            </ImageView>

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="right|center_vertical"
            android:layout_weight=".10">
            <TextView
                android:id="@+id/language_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="right|center"
                android:layout_marginRight="15dp"
                android:paddingLeft="9dp"
                android:paddingRight="9dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/bg_border_orange1"
                android:text="@string/select_language"
                android:textColor="@color/text_color_black"
                android:textSize="@dimen/tv_size_17"
                android:visibility="invisible">

            </TextView>

            <TextView
                android:id="@+id/skip_close_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_border_orange1"
                android:paddingLeft="9dp"
                android:paddingRight="9dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:gravity="right"
                android:text="@string/skip"
                android:textColor="@color/text_color_black"
                android:textSize="@dimen/tv_size_17">

            </TextView>

        </LinearLayout>


    </LinearLayout>


    <ScrollView
        android:id="@+id/container_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:layout_below="@+id/imgViewTopBg"
        android:layout_above="@+id/llFooter"
        >
        <RelativeLayout
            android:id="@+id/base_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <ImageView
                android:id="@+id/imgViewShriGaneshji"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:src="@drawable/ic_ganesh_ji_image" />
            <RelativeLayout
                android:id="@+id/topRL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_below="@+id/imgViewShriGaneshji">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@mipmap/icon"/>
                    <TextView
                        android:id="@+id/astrosage_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/astrosage_name"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_32"
                        android:layout_marginLeft="8dip"
                        android:textStyle="bold"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:src="@drawable/splash_icon_astrosage_ai_logo"
                    app:tint="@color/colorPrimary_day_night"/>


            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen_15dp"
                android:layout_marginRight="@dimen/dimen_15dp"
                android:layout_below="@+id/topRL"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/login_heading_txt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/login"
                    android:gravity="center_horizontal"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_32"
                    android:layout_marginTop="@dimen/activity_vertical_margin"
                    android:textStyle="bold"
                    android:visibility="gone"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="@dimen/dimen_15dp"
                    android:layout_marginRight="5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    >

                    <TextView
                        android:id="@+id/country_code1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.6"
                        android:gravity="center"
                        android:paddingLeft="5dp"
                        android:text="@string/country_code"
                        android:textColor="@color/darker_gray"
                        android:textSize="@dimen/tv_size_17"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/country_code_layout"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/dimen_50dp"
                        android:padding="@dimen/dimen_4dp"
                        android:background="@drawable/drawable_bg_grey"
                        android:gravity="center_vertical"
                        android:visibility="visible"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/country_code"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingLeft="0dp"
                            android:paddingRight="5dp"
                            android:singleLine="true"
                            android:layout_marginStart="@dimen/dimen_3dp"
                            android:text="@string/country_code"
                            android:textColor="@color/text_color_black"
                            android:textSize="15sp"
                            android:layout_toLeftOf="@+id/tv_country_code_txt"
                            android:visibility="visible">
                        </TextView>

                        <Spinner
                            android:id="@+id/tv_country_code_txt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:gravity="center"
                            android:paddingLeft="0dp"
                            android:paddingRight="15dp"
                            android:textColor="@color/darker_gray"
                            android:visibility="gone"/>

                        <ImageView
                            android:id="@+id/dropdown_img"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_centerVertical="true"
                            android:paddingLeft="2dp"
                            android:paddingRight="0dp"
                            android:layout_marginEnd="@dimen/dimen_5dp"
                            android:layout_alignRight="@+id/tv_country_code_txt"
                            app:tint="@color/text_color_black"
                            android:src="@drawable/ic_spinner_down_image"
                            android:visibility="visible" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginLeft="8dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginRight="5dp"
                        android:layout_marginBottom="2dp"
                        android:visibility="gone"
                        android:background="@color/new_theme_darker_gray"/>

                    <EditText
                        android:id="@+id/mobile_number_txt"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/dimen_50dp"
                        android:layout_weight="1.4"
                        android:background="@drawable/drawable_bg_grey"
                        android:gravity="left|center_vertical"
                        android:hint="@string/text_enter_mobile_number"
                        android:imeOptions="actionDone"
                        android:inputType="number"
                        android:paddingLeft="8dp"
                        android:paddingTop="5dp"
                        android:paddingRight="5dp"
                        android:paddingBottom="5dp"
                        android:layout_marginStart="@dimen/dimen_10dp"
                        android:textColorHint="@color/text_day_gray_night_white"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_17"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/sendOtpMsgTV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="@dimen/margin_medium"
                    android:paddingRight="@dimen/margin_medium"
                    android:layout_marginTop="@dimen/activity_vertical_margin"
                    android:gravity="center"
                    android:visibility="gone"
                    android:text="@string/send_otp_desc"
                    android:textColor="@color/hint_text_color"
                    android:textSize="@dimen/tv_size_15" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dip"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:paddingBottom="@dimen/margin_medium">

                    <CheckBox
                        android:id="@+id/agreeCheckBox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"

                        android:outlineSpotShadowColor="@color/white"
                        android:outlineAmbientShadowColor="@color/white"
                        android:textColorHint="@color/white"
                        android:textColor="@color/Orangecolor"/>

                    <TextView
                        android:id="@+id/agree_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dip"
                        android:layout_marginTop="2dp"
                        android:layout_toEndOf="@+id/agreeCheckBox"
                        android:gravity="start"
                        android:text="@string/terms_and_con_text"
                        android:textColor="@color/hint_text_color"
                        android:layout_marginBottom="@dimen/margin_medium"
                        android:textSize="@dimen/tv_size_16" />

                </RelativeLayout>

                <Button
                    android:id="@+id/get_otp_btn"
                    style="@style/buttonBackground"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_normal"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:text="@string/continue_txt"
                    android:textSize="@dimen/tv_size_17"
                    android:textAllCaps="false"
                    android:layout_marginTop="@dimen/dimen_15dp"
                    android:textColor="@color/white"
                    android:background="@drawable/drawable_bg_orange"
                    android:backgroundTint="@color/colorPrimary_day_night"/>



                <TextView
                    android:id="@+id/orWithTxt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="@dimen/margin_medium"
                    android:paddingRight="@dimen/margin_medium"
                    android:layout_marginTop="@dimen/dimen_8dp"
                    android:gravity="center_horizontal"
                    android:text="@string/or_continue_with"
                    android:inputType="textCapWords"
                    android:capitalize="words"
                    android:textColor="@color/text_day_gray_night_white"
                    android:textSize="@dimen/dimen_15sp"

                />
                <LinearLayout
                    android:id="@+id/truecaller_button"
                    android:background="@drawable/drawable_bg_orange"
                    android:backgroundTint="@color/TrueCallerColor"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_normal"
                    android:clickable="true"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="@dimen/dimen_8dp"
                    android:layout_marginRight="5dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/dimen_12dp"
                        android:layout_gravity="center"
                        android:src="@mipmap/ic_truecaller" />


                </LinearLayout>


                <Button
                    android:id="@+id/astrosage_id_btn"
                    style="@style/buttonBackground"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_normal"
                    android:layout_marginLeft="5dp"
                    android:layout_marginTop="@dimen/dimen_15dp"
                    android:layout_marginRight="5dp"
                    android:text="@string/text_astrosage_id"
                    android:textSize="@dimen/tv_size_18"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:visibility="gone"
                    android:background="@drawable/drawable_bg_orange"
                    android:backgroundTint="@color/colorPrimary_day_night"/>

                <LinearLayout
                    android:id="@+id/dont_have_account_ll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_8dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_alignParentBottom="true"
                    >

                    <TextView
                        android:id="@+id/dont_have_account_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dont_have_account"
                        android:textColor="@color/black"
                        android:visibility="gone"
                        android:textSize="@dimen/tv_size_17"/>

                    <TextView
                        android:id="@+id/sign_up_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toRightOf="@+id/dont_have_account_txt"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:text="@string/text_sign_up"
                        android:textColor="@color/black"
                        android:textSize="@dimen/dimen_15sp"
                        />

                </LinearLayout>
                
                <LinearLayout
                    android:id="@+id/linLayoutSocialLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="@dimen/dimen_10dp">
                    <LinearLayout
                        android:id="@+id/linLayoutFB"
                        android:layout_width="@dimen/dimen_35dp"
                        android:layout_height="@dimen/dimen_35dp"
                        android:gravity="center"
                        android:visibility="visible"
                        android:background="@drawable/circle_border_grey"
                        >
                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_fb_login"
                            android:tint="@color/black"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/linLayoutGoogle"
                        android:layout_width="@dimen/dimen_35dp"
                        android:layout_height="@dimen/dimen_35dp"
                        android:gravity="center"
                        android:layout_marginHorizontal="@dimen/dimen_10dp"
                        android:visibility="visible"
                        android:background="@drawable/circle_border_grey"
                        >
                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_google_login"
                            android:tint="@color/black"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/linLayoutEmail"
                        android:layout_width="@dimen/dimen_35dp"
                        android:layout_height="@dimen/dimen_35dp"
                        android:gravity="center"
                        android:background="@drawable/circle_border_grey"
                        >
                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_email_login"/>
                    </LinearLayout>


                </LinearLayout>
            </LinearLayout>

        </RelativeLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/llFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dimen_20dp"
        android:layout_marginRight="@dimen/dimen_20dp"
        android:layout_marginBottom="10dp"
        android:paddingVertical="@dimen/dimen_7dp"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_alignParentBottom="true">

        <TextView
            android:id="@+id/textViewPrivacyPolicy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/privacy_policy"
            android:textColor="@color/black"
            android:layout_weight="1"
            android:textSize="@dimen/tv_size_13"
            android:onClick="gotoSelectedScreen"

        />
        <TextView
            android:id="@+id/textViewTermsAndConditions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/text_terms_and_conditions"
            android:textColor="@color/black"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="@dimen/tv_size_13"
            android:onClick="gotoSelectedScreen"
            />

    </LinearLayout>

</RelativeLayout>
