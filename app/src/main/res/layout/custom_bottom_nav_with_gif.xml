<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="?android:attr/actionBarSize"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/appbarBGColor">

    <LinearLayout
        android:id="@+id/nav_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="false"
        android:weightSum="5">

        <LinearLayout
            android:id="@+id/bottom_nav_home"
            android:layout_width="@dimen/dimen_0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/dimen_5dp">

            <ImageView
                android:id="@+id/imgViewHome"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_home_new"
                app:tint="@color/black" />

            <TextView
                android:id="@+id/txtViewHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/dimen_5dp"
                android:text="@string/title_home"
                android:maxLines="2"
                android:textAlignment="center"
                android:textSize="@dimen/tv_size_12" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_nav_call"
            android:layout_width="@dimen/dimen_0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/dimen_5dp">

            <ImageView
                android:id="@+id/imgViewCall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/nav_call_icons"
                app:tint="@color/black" />

            <TextView
                android:id="@+id/txtViewCall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/dimen_5dp"
                android:text="@string/call"
                android:maxLines="2"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_12" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_nav_live"
            android:layout_width="@dimen/dimen_0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/dimen_5dp">

            <ImageView
                android:id="@+id/imgViewLive"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/nav_live_icons"
                app:tint="@color/black" />

            <TextView
                android:id="@+id/txtViewLive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/dimen_5dp"
                android:text="@string/livelong"
                android:maxLines="2"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_12" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_nav_chat"
            android:layout_width="@dimen/dimen_0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/dimen_5dp">

            <ImageView
                android:id="@+id/imgViewChat"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/nav_chat_icons"
                app:tint="@color/black" />

            <TextView
                android:id="@+id/txtViewChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/dimen_5dp"
                android:text="@string/chat_now"
                android:maxLines="2"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_12" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottom_nav_history"
            android:layout_width="@dimen/dimen_0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/dimen_5dp">

            <ImageView
                android:id="@+id/imgViewHistory"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/nav_more_icons"
                app:tint="@color/black" />

            <TextView
                android:id="@+id/txtViewHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/dimen_5dp"
                android:text="@string/history"
                android:maxLines="2"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_12" />
        </LinearLayout>
    </LinearLayout>
    <View
        android:id="@+id/shaddowView"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentTop="true"
        android:visibility="gone"
        android:background="@drawable/shadow"/>
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:backgroundTint="@color/orange_color"
        android:src="@drawable/ic_live_unmute_video"
        android:layout_alignParentTop="true"
        android:layout_centerInParent="true"
        android:visibility="gone"/>

</RelativeLayout>