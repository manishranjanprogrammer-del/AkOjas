<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/dimen_20dp">

    <TextView
        android:id="@+id/txtViewWhereWereYouBorn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_20dp"
        android:text="@string/where_were_you_born"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size_26sp" />

    <RelativeLayout
        android:id="@+id/linLayoutSerchPlace"
        android:layout_width="match_parent"
        android:layout_height="@dimen/margin_52dp"
        android:layout_below="@+id/txtViewWhereWereYouBorn"
        android:layout_marginTop="@dimen/margin_25dp"
        android:background="@drawable/drawable_otp_box_bg"
        android:backgroundTint="@color/bg_card_view_light_color">

        <EditText
            android:id="@+id/edtTextSearchPlace"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerVertical="true"
            android:layout_toLeftOf="@+id/imgViewSearch"
            android:background="@drawable/drawable_otp_box_bg"
            android:backgroundTint="@color/bg_card_view_light_color"
            android:foreground="?selectableItemBackground"
            android:hint="@string/search_place_here"
            android:paddingStart="@dimen/dimen_15dp"
            android:paddingEnd="@dimen/dimen_5dp"
            android:textColor="@color/black"
            android:textColorHint="@color/grayMiddle"
            android:textSize="@dimen/tv_size_20" />

        <ImageView
            android:id="@+id/imgViewSearch"
            android:layout_width="@dimen/dimen_35dp"
            android:layout_height="@dimen/dimen_35dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dimen_5dp"
            android:layout_marginEnd="@dimen/dimen_5dp"
            android:foreground="?selectableItemBackground"
            android:padding="@dimen/dimen_7dp"
            android:src="@mipmap/ic_search_born"
            app:tint="@color/grey_light" />
    </RelativeLayout>


