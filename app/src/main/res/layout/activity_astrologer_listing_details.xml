<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/backgroundColor"
    android:orientation="vertical">

    <include
        android:id="@+id/appbarAppModule"
        layout="@layout/tool_bar_app_module"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dip"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/omf_text_width">

                <com.android.volley.toolbox.NetworkImageView
                    android:id="@+id/networkProfileIV"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="left|center"
                    android:scaleType="fitXY" />

                <ImageView
                    android:id="@+id/profileIV"
                    android:layout_width="112dip"
                    android:layout_height="112dip"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/image_not_available"
                    android:visibility="gone" />

                <!--android:src="@drawable/ic_aq_profile_detail"-->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/black_40"
                    android:orientation="vertical"
                    android:padding="@dimen/margin_medium">

                    <TextView
                        android:id="@+id/title1TV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="@dimen/title_text_size" />

                    <LinearLayout
                        android:id="@+id/rating_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_mlarge"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/ratingTV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rating_green"
                            android:gravity="center"
                            android:paddingLeft="@dimen/margin_small"
                            android:paddingRight="@dimen/margin_small"
                            android:text="@string/experience"
                            android:textColor="@color/black"
                            android:textSize="@dimen/font_medium" />

                        <androidx.appcompat.widget.AppCompatRatingBar
                            android:id="@+id/rating_star"
                            style="@style/myRatingBarSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/margin_small"
                            android:numStars="5"
                            android:rating="0" />

                        <TextView
                            android:id="@+id/voteTV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/margin_small"
                            android:text="@string/experience"
                            android:textColor="@color/black"
                            android:textSize="@dimen/font_medium" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dip"
                            android:layout_height="22dip"
                            app:tint="@color/white"
                            android:scaleType="fitCenter"
                            android:src="@drawable/cust_footer" />

                        <TextView
                            android:id="@+id/address1TV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/margin_medium"
                            android:textColor="@color/white"
                            android:textSize="@dimen/font_medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dip"
                            android:layout_height="24dip"
                            app:tint="@color/white"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_keyboard_arrow_right_black" />

                        <TextView
                            android:id="@+id/astrologers1TV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/margin_medium"
                            android:text="@string/astrologers_in"
                            android:textColor="@color/white"
                            android:textSize="@dimen/font_medium" />
                    </LinearLayout>

                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_small"
                android:layout_marginTop="@dimen/margin_large"
                android:layout_marginRight="@dimen/margin_small"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/margin_medium">

                <TextView
                    android:id="@+id/title2TV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:textColor="@color/black"
                    android:textSize="@dimen/title_text_size" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dip"
                        android:layout_height="32dip"
                        app:tint="@color/black"
                        android:scaleType="fitCenter"
                        android:padding="5dip"
                        android:background="@drawable/circle_gray"
                        android:src="@drawable/cust_footer" />

                    <TextView
                        android:id="@+id/address2TV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_medium"
                        android:textColor="@color/black_85"
                        android:textSize="@dimen/font_medium" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dip"
                        android:layout_height="32dip"
                        android:scaleType="fitCenter"
                        android:padding="4dip"
                        android:background="@drawable/circle_gray"
                        android:src="@drawable/ic_keyboard_arrow_right_black" />

                    <TextView
                        android:id="@+id/astrologers2TV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_medium"
                        android:text="@string/astrologers_in"
                        android:textColor="@color/black_85"
                        android:textSize="@dimen/font_medium" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/margin_mlarge">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/lblExpTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/experiencee"
                        android:textColor="@color/black"
                        android:textSize="@dimen/font_medium" />

                    <TextView
                        android:id="@+id/valExpTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_min_small"
                        android:textColor="@color/ColorPrimaryDark"
                        android:textSize="@dimen/font_medium" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/lblSystemKnownTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/system_knownn"
                        android:textColor="@color/black"
                        android:textSize="@dimen/font_medium" />

                    <TextView
                        android:id="@+id/valSystemKnownTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_min_small"
                        android:textColor="@color/ColorPrimaryDark"
                        android:textSize="@dimen/font_medium" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/lblLangKnownTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lang_known"
                        android:textColor="@color/black"
                        android:textSize="@dimen/font_medium" />

                    <TextView
                        android:id="@+id/valLangKnownTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/margin_min_small"
                        android:textColor="@color/ColorPrimaryDark"
                        android:textSize="@dimen/font_medium" />

                </LinearLayout>

                <TextView
                    android:id="@+id/aboutTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_large"
                    android:text="@string/about_text"
                    android:textColor="@color/black"
                    android:textSize="@dimen/title_text_size" />

                <LinearLayout
                    android:id="@+id/astrologer_description_dummy_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/astrologer_description_dummy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:justificationMode="inter_word"
                        android:maxLines="6"
                        android:textColor="@color/black_85"
                        android:textSize="@dimen/font_medium" />

                    <TextView
                        android:id="@+id/read_more_txt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-10dp"
                        android:background="@drawable/white_strip_transparent"
                        android:elevation="20dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center"
                        android:paddingTop="10dp"
                        android:paddingBottom="8dp"
                        android:text="@string/read_more"
                        android:textColor="@color/ColorPrimary"
                        android:textSize="20dp"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/astrologer_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:justificationMode="inter_word"
                    android:textColor="@color/black_85"
                    android:textSize="@dimen/font_medium"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center">

        <Button
            android:id="@+id/btnBuyNow"
            style="@style/buttonstyle"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/custom_btn_height"
            android:background="@drawable/bg_orange"
            android:gravity="center"
            android:paddingLeft="@dimen/margin_large"
            android:paddingRight="@dimen/margin_large"
            android:text="@string/get_consultationn"
            android:textSize="@dimen/title_text_size" />
    </LinearLayout>
</LinearLayout>