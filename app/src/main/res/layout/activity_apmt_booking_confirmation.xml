<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <include
        android:id="@+id/appbarAppModule"
        layout="@layout/tool_bar_app_module"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/margin_xlarge">

        <TextView
            android:id="@+id/lblMsgTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/margin_small"
            android:text="@string/suc_book_appointment"
            android:textColor="@color/black_87"
            android:textSize="@dimen/font_xxlarge"
            android:layout_marginTop="@dimen/margin_large"
            android:gravity="center_horizontal"/>

        <Button
            android:id="@+id/btnShowApmt"
            style="@style/buttonstyle"
            android:layout_width="match_parent"
            android:layout_height="@dimen/custom_btn_height"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/margin_xlarge"
            android:layout_marginRight="@dimen/margin_large"
            android:layout_marginLeft="@dimen/margin_large"
            android:background="@drawable/bg_button_blue"
            android:gravity="center"
            android:text="@string/btn_show_apmt"
            android:textSize="@dimen/font_large" />

    </LinearLayout>
</LinearLayout>