<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColorView">

    <LinearLayout
        android:id="@+id/toolbar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/back_arrow"
            android:layout_width="42dp"
            android:layout_height="38dp"
            android:layout_gravity="center_vertical"
            android:layout_margin="@dimen/dimen_16dp"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/ic_back"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/heading_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/free_brihat_kundli"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/back_arrow"
            app:layout_constraintStart_toEndOf="@+id/back_arrow"
            app:layout_constraintTop_toTopOf="@id/back_arrow" />
    </LinearLayout>

    <RelativeLayout

        android:id="@+id/header_image_layout"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_below="@+id/toolbar_layout"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/dimen_20dp"
        android:background="@drawable/circle_border"
        android:elevation="2dp"
        android:padding="30dp">

        <ImageView
            android:id="@+id/header_image"
            android:layout_width="200dp"
            android:layout_height="300dp"
            android:layout_centerInParent="true"
            android:scaleType="centerCrop"
            android:src="@drawable/brihat_horoscope_english" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/kundli_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/toolbar_layout"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="160dp"
        android:background="@color/light_gray_day_night">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="155dp"
            android:text="@string/brihat_kundli"
            android:textColor="@color/colorPrimary_day_night"
            android:textSize="50sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/price_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/title_text"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="20dp"
            android:text="@string/worth_rs599"
            android:textColor="@color/black"
            android:textSize="28sp"/>


    </RelativeLayout>

    <TextView
        android:id="@+id/unlock_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/kundli_layout"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:gravity="center_horizontal"
        android:text="@string/unlocks_in"
        android:textColor="@color/black"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/timer_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/unlock_tv"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:gravity="center_horizontal"
        android:paddingBottom="@dimen/dimen_16dp"
        android:text="20H : 35M : 10S"
        android:textColor="@color/black"
        android:textSize="36sp" />

    <Button
        android:id="@+id/download_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/timer_tv"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_selector_orange_gray"
        android:enabled="true"
        android:text="@string/download_now"
        android:textStyle="bold"
        android:textColor="@color/download_btn_text_color"
        android:textSize="20sp" />
</RelativeLayout>