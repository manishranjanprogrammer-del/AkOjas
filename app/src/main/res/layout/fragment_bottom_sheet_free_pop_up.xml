<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_next_recharge"
    android:minHeight="220dp">

    <TextView
        android:id="@+id/message_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/get_first_chat_free_with_premium_astrologers"
        android:textAlignment="center"
        android:layout_marginTop="@dimen/dimen_10dp"
        android:layout_marginEnd="150dp"
        android:textColor="@color/no_change_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ll_mob"
        android:textSize="@dimen/tv_size_22"
        app:layout_constraintTop_toBottomOf="@+id/cross_btn" />

    <ImageView
        android:id="@+id/cross_btn"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_margin="@dimen/dimen_10dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_close_live"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <Button
        android:id="@+id/open_now"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_below="@id/message_tv"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/text_size"
        android:background="@drawable/bg_button_recharge"
        android:maxLines="1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ll_mob"
        app:layout_constraintTop_toBottomOf="@+id/message_tv"
        android:paddingLeft="@dimen/text_size"
        android:paddingRight="@dimen/text_size"
        android:text="@string/txt_chat_now"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="@dimen/tv_size_20" />

    <LinearLayout
        android:id="@+id/ll_mob"
        android:layout_width="130dp"
        android:layout_height="190dp"
        android:layout_marginEnd="@dimen/dimen_20dp"
        android:background="@drawable/phone_next_recharge"
        android:gravity="bottom|center_horizontal"
        android:orientation="vertical"
        android:padding="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cross_btn">

        <TextView
            android:id="@+id/id_first"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_first"
            android:gravity="center_horizontal"
            android:includeFontPadding="false"
            android:textColor="@color/no_change_black"
            android:textSize="@dimen/tv_size_24" />
        <TextView
            android:id="@+id/id_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat"
            android:includeFontPadding="false"
            android:textColor="@color/no_change_black"
            android:gravity="center_horizontal"
            android:textSize="@dimen/tv_size_24" />

        <TextView
            android:id="@+id/id_free"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_free"
            android:layout_marginBottom="@dimen/dimen_10dp"
            android:includeFontPadding="false"
            android:gravity="center_horizontal"
            android:textColor="@color/colorPrimary_day_night"
            android:textSize="@dimen/tv_size_24" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>