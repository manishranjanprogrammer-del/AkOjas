<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/RelativeLayout1"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/backgroundColorView"
    android:gravity="center_vertical"
    android:paddingLeft="6dp"
    android:paddingRight="10dp"
    style="@style/selectedListRippleTest">

    <TextView
        android:id="@+id/tvRecentScreens"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:maxLines="1"
        android:padding="10dp"
        android:layout_toLeftOf="@+id/addRemoveFavToggle"
        android:singleLine="true"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:text="History Items"
        android:textColor="@color/black"
        android:textSize="@dimen/subheading_text_size"
        android:layout_centerVertical="true"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true" />

    <ToggleButton
        android:id="@+id/addRemoveFavToggle"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:gravity="center_vertical"
        android:alpha="0.8"
        android:padding="2dp"
        android:layout_marginLeft="4dp"
        android:background="@drawable/fav_add_remove"
        android:textOff=""
        android:textOn=""
        android:layout_centerVertical="true"
        android:layout_alignParentRight="true" />

</RelativeLayout>

