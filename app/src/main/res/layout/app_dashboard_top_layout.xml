<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.appbar.AppBarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/toolbarBGColor"
    android:elevation="4dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/tool_barAppModule"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            app:contentInsetLeft="0dp"
            app:contentInsetRight="10dp"
            app:contentInsetStart="0dp"
            android:minHeight="?attr/actionBarSize"
            android:background="@color/toolbarBGColor">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivToggleImage"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="start"
                    android:contentDescription="navigation drawer"
                    android:padding="@dimen/dimen_12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/hamburger_menu_icon"
                    android:visibility="visible"
                    app:tint="@color/ivTintColorDN"
                    android:background="?attr/selectableItemBackground"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvTitle"
                    app:layout_constraintTop_toTopOf="parent" />


                <TextView
                    android:id="@+id/tvTitle"
                    style="@style/title_style"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/color_titleDN"
                    android:text="@string/astrosage_name"
                    android:textAllCaps="false"
                    android:autoSizeTextType="uniform"
                    android:paddingEnd="@dimen/dimen_15dp"
                    android:paddingStart="@dimen/dimen_5dp"
                    android:paddingVertical="@dimen/dimen_15dp"
                    android:textSize="25sp"
                    android:gravity="center_vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintLeft_toRightOf="@id/ivToggleImage"
                    app:layout_constraintRight_toLeftOf="@id/wallet_box_layout"
                    app:layout_constraintTop_toTopOf="parent" />

                <RelativeLayout
                    android:id="@+id/wallet_box_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginEnd="15dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:id="@+id/wallet_layout"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_border_black"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingEnd="@dimen/dimen_5dp">

                        <TextView
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            app:backgroundTint="@color/ivTintColorDN"
                            android:background="@drawable/wallet_new" />

                        <TextView
                            android:id="@+id/wallet_price_txt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="3dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text=""
                            android:gravity="center_vertical"
                            android:textColor="@color/txtColorBlWh"
                            android:textSize="@dimen/tv_size_14"
                            android:textStyle="bold" />

                    </LinearLayout>

                </RelativeLayout>

<!--                <RelativeLayout-->
<!--                    android:id="@+id/notificationcenter"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_gravity="right"-->
<!--                    android:layout_marginLeft="5dp"-->
<!--                    android:minHeight="?attr/actionBarSize"-->
