<!--                    android:paddingRight="2dp"-->
<!--                    android:visibility="gone"-->
<!--                    app:layout_constraintBottom_toBottomOf="parent"-->
<!--                    app:layout_constraintEnd_toEndOf="parent"-->
<!--                    app:layout_constraintHorizontal_bias="0.5"-->
<!--                    app:layout_constraintTop_toTopOf="parent">-->

<!--                    <ImageView-->
<!--                        android:id="@+id/notificationcentericon"-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_centerInParent="true"-->
<!--                        android:contentDescription="notification"-->
<!--                        android:src="@drawable/ic_notifications" />-->

<!--                    <TextView-->
<!--                        android:id="@+id/notificationcount"-->
<!--                        android:layout_width="16dp"-->
<!--                        android:layout_height="16dp"-->
<!--                        android:layout_alignRight="@+id/notificationcentericon"-->
<!--                        android:layout_marginLeft="4dp"-->
<!--                        android:layout_marginTop="10dp"-->
<!--                        android:background="@drawable/cart_red_circle"-->
<!--                        android:gravity="center"-->
<!--                        android:maxLength="2"-->
<!--                        android:textColor="@color/white"-->
<!--                        android:textSize="8sp"-->
<!--                        android:textStyle="bold" />-->
<!--                </RelativeLayout>-->

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.appcompat.widget.Toolbar>
        <com.ojassoft.astrosage.utils.MaterialSearchView
            android:id="@+id/search_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/search_hint"
            app:backgroundTint="@color/ivTintColorDN"
            android:minHeight="?attr/actionBarSize"
            android:visibility="gone" />
    </FrameLayout>


    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabs"
        style="@style/CustomTabText"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@+id/tool_barAppModule"
        android:minHeight="?attr/actionBarSize"
        app:tabGravity="fill"
        app:elevation="2dp"
        android:background="@color/tabBGColor"
        app:tabIndicatorColor="@color/tabIndicatorBGColor"
        app:tabIndicatorHeight="2dp"
        app:tabMaxWidth="0dp"
        app:tabRippleColor="@color/appRippleEffectColor"
        app:tabMode="scrollable"
        app:tabPaddingEnd="0dp"
        app:tabPaddingStart="0dp"
        />

</com.google.android.material.appbar.AppBarLayout>
