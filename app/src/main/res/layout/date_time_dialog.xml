<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/DateTimeDialog"
    android:layout_width="277dp"
    android:layout_height="wrap_content"
    android:background="@color/white">

    <com.ojassoft.astrosage.ui.customcontrols.DateTimePicker
        android:id="@+id/DateTimePicker"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true" />

    <LinearLayout
        android:id="@+id/ControlButtons"
        android:layout_width="277dp"
        android:paddingBottom="@dimen/cardview_keyline_1_minus_8dp"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/DateTimePicker"
        android:layout_centerHorizontal="true" >

        <Button
            android:id="@+id/SetDateTime"
            android:layout_width="0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/buttonstylecalender"
            android:textColor="@color/black_87"
            android:theme="@style/buttonstylecalender"
            android:text="@string/set"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/ResetDateTime"
            android:layout_width="0dip"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:text="Reset"
            android:visibility="gone" />

        <Button
            android:id="@+id/CancelDialog"
            android:layout_width="0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/black_87"
            style="@style/buttonstylecalender"
            android:theme="@style/buttonstylecalender"
            android:text="@string/cancel"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>