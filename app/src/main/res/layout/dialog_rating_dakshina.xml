<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rlDRDParent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_white_rounded">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/dimen_20dp">

            <ProgressBar
                android:id="@+id/progressDRD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvDRDTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dakshina"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_22"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatRatingBar
                android:id="@+id/starsDRD"
                style="@style/myRatingBarLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_20dp"
                android:contentDescription="@string/rating_text"
                android:numStars="5"
                android:rating="0"
                android:stepSize="1.0"
                android:visibility="gone"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDRDTitle" />

            <EditText
                android:id="@+id/etDRDFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:background="@drawable/bg_gray"
                android:gravity="top"
                android:hint="@string/write_your_feedback"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:padding="@dimen/dimen_10dp"
                android:textSize="@dimen/tv_size_14"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/starsDRD" />

            <View
                android:id="@+id/viewDRDLine"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_1dp"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:background="@color/grey_light"
                app:layout_constraintTop_toBottomOf="@id/etDRDFeedback" />

            <TextView
                android:id="@+id/tvDRDHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:gravity="center"
                android:text="@string/give_dakshina_text"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_18"
                android:visibility="gone"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/viewDRDLine" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDRDGiftList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="180dp"
                android:layout_marginTop="@dimen/dimen_15dp"
                app:layout_constraintTop_toBottomOf="@id/tvDRDHeading" />

            <TextView
                android:id="@+id/tvDRDRecharge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_recharge"
                android:textColor="@color/white"
                android:paddingHorizontal="@dimen/dimen_10dp"
                android:paddingVertical="@dimen/dimen_5dp"
                android:background="@drawable/bg_button_orange"
                android:layout_marginTop="@dimen/dimen_10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvDRDGiftList" />

            <TextView
                android:id="@+id/tvDRDBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/dimen_10dp"
                android:text="@string/balance"
                android:textColor="@color/black"
                android:layout_marginStart="@dimen/dimen_5dp"
                app:layout_constraintBottom_toBottomOf="@id/tvDRDRecharge"
                app:layout_constraintLeft_toRightOf="@id/tvDRDRecharge"
                app:layout_constraintTop_toTopOf="@id/tvDRDRecharge" />

            <TextView
                android:id="@+id/tvDRDSubmit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/submit"
                android:textColor="@color/white"
                android:paddingHorizontal="@dimen/dimen_10dp"
                android:paddingVertical="@dimen/dimen_5dp"
                android:layout_marginTop="@dimen/dimen_10dp"
                android:background="@drawable/bg_button_orange"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvDRDGiftList" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <ImageView
        android:id="@+id/ivDRDClose"
        android:layout_width="@dimen/dimen_20dp"
        android:layout_height="@dimen/dimen_20dp"
        android:layout_alignParentEnd="true"
        android:layout_margin="@dimen/dimen_15dp"
        android:clickable="true"
        android:contentDescription="@string/close"
        android:focusable="true"
        android:src="@drawable/ic_close_live"
        app:tint="@color/black" />

</RelativeLayout>