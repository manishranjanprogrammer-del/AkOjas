<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/wallet_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/scrollview"
        android:layout_below="@+id/toolbar"
        android:fillViewport="true"
        android:background="@color/white">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/logo_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/varta_logo"/>

            </LinearLayout>


            <LinearLayout
                android:id="@+id/version_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_below="@+id/logo_layout"
                android:padding="8dp"
                android:gravity="center"
                android:layout_marginTop="20dp">

                <TextView
                    android:id="@+id/version_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:textSize="@dimen/tv_size_18"
                    android:paddingRight="3dp"
                    android:textStyle="bold"
                    android:textColor="@color/Orangecolor"
                    android:text="@string/lib_app_version_text" />

                <TextView
                    android:id="@+id/version_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/tv_size_18"
                    android:textStyle="bold"
                    android:textColor="@color/Orangecolor"
                    android:gravity="start" />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/share_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/version_layout"
                android:layout_above="@+id/disclamer_layout"
                android:paddingRight="16dp"
                android:paddingLeft="16dp"
               android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.9"
                    android:background="@color/white"
                    android:layout_marginTop="-8dp"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/shareApp"
                        layout="@layout/aboutus_single_link"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_border" />

                    <include
                        android:id="@+id/likeUsOnFacebook"
                        layout="@layout/aboutus_single_link"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_border" />

                    <include
                        android:id="@+id/followUsOnTwitter"
                        layout="@layout/aboutus_single_link"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/light_border" />

                    <include
                        android:id="@+id/followUsOnInstagram"
                        layout="@layout/aboutus_single_link"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:paddingTop="1dp"
                    android:paddingBottom="5dp"
                    android:paddingRight="8dp"
                    android:paddingLeft="8dp"
                    android:layout_marginTop="15dp"
                    android:text="Ojas Softech Pvt. Ltd."
                    android:textSize="@dimen/tv_size_20"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/firstNum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:paddingStart="@dimen/dimen_8dp"
                    android:text="+91-9560267006"
                    android:textSize="@dimen/tv_size_13"
                    android:drawablePadding="@dimen/dimen_16dp"
                    android:drawableStart="@drawable/ic_call_black_18dp"/>

<!--                <TextView-->
<!--                    android:id="@+id/secondNum"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:alpha="0.5"-->
<!--                    android:paddingStart="@dimen/dimen_8dp"-->
<!--                    android:text="+91-120-4138503"-->
<!--                    android:textSize="@dimen/tv_size_13"-->
<!--                    android:drawablePadding="@dimen/dimen_16dp"-->
<!--                    android:drawableStart="@drawable/ic_call_black_18dp"-->
<!--                    android:visibility="gone"/>-->

                <TextView
                    android:id="@+id/composeEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:paddingStart="@dimen/dimen_8dp"
                    android:text="query@astrosage.com"
                    android:textSize="@dimen/tv_size_13"
                    android:drawablePadding="@dimen/dimen_16dp"
                    android:drawableStart="@drawable/ic_email_black_18dp"/>

                <TextView
                    android:id="@+id/openWebPage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:paddingStart="@dimen/dimen_8dp"
                    android:text="varta.astrosage.com"
                    android:textSize="@dimen/tv_size_13"
                    android:drawablePadding="@dimen/dimen_16dp"
                    android:drawableStart="@drawable/ic_public_black_18dp"/>

