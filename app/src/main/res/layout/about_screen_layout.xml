            </LinearLayout>


            <LinearLayout
                android:id="@+id/disclamer_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="60dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center|bottom"
                    android:orientation="horizontal"
                    android:paddingTop="16dp">

                    <TextView
                        android:id="@+id/textViewDisclaimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:onClick="gotoSelectedScreen"
                        android:paddingBottom="5dp"
                        android:text="@string/disclaimer_on_about"
                        android:textSize="@dimen/tv_size_13" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" | " />

                    <TextView
                        android:id="@+id/textViewPrivacyPolicy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:onClick="gotoSelectedScreen"
                        android:paddingBottom="5dp"
                        android:text="@string/privacy_policy_on_aboutus"
                        android:textSize="@dimen/tv_size_13" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" | " />

                    <TextView
                        android:id="@+id/textViewTermsAndConditions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:onClick="gotoSelectedScreen"
                        android:paddingBottom="5dp"
                        android:text="@string/terms_and_conditions"
                        android:textSize="@dimen/tv_size_13" />

                </LinearLayout>

                <TextView
                    android:id="@+id/copyright_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center_horizontal"
                    android:text="@string/copyright"
                    android:textSize="@dimen/tv_size_13" />

                <TextView
                    android:id="@+id/helpIV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center_horizontal"
                    android:text="@string/send_log_report"
                    android:textSize="@dimen/tv_size_18"
                    android:textColor="@color/Orangecolor"
                    android:layout_marginTop="@dimen/activity_vertical_margin"/>


            </LinearLayout>

        </RelativeLayout>
    </ScrollView>

</RelativeLayout>
