<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.ojassoft.astrosage.misc.ExpandableHeightListView
        android:id="@+id/rvListData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="@color/light_dividerColor"
        android:dividerHeight="1dp"
        />


    <TextView
        android:id="@+id/tvNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:visibility="gone"
        android:paddingTop="6dp"
        android:text="Note: "
        android:textSize="@dimen/subheading_text_size"
        android:textStyle="bold" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="10dp"
            android:layout_height="wrap_content"
            android:text="@string/bullet_text" />

        <TextView
            android:id="@+id/tvNotevalue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="2dp"
            android:paddingTop="2dp"
            android:text="Note: "
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginLeft="15dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="10dp"
            android:layout_height="wrap_content"
            android:text="@string/bullet_text" />

        <TextView
            android:id="@+id/tvNotevalueclick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="5dp"
            android:paddingLeft="0dp"
            android:paddingTop="2dp"
            android:text="Note: "
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>