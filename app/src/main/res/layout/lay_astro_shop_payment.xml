<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:id="@+id/llcodmsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="15dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/rectangular_image"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtcod_msg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:alpha="0.7"
                    android:gravity="center"
                    android:textColor="@color/no_change_black"
                    android:text="@string/astroshop_pin_not_available"
                    android:textAppearance="?android:attr/textAppearanceLarge"
                    android:textSize="16sp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView xmlns:card_view="http://schemas.android.com/apk/res-auto"
                android:id="@+id/card_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                card_view:cardBackgroundColor="@color/bg_card_view_color"
                android:layout_margin="15dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginRight="8dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical">


                    <TextView
                        android:id="@+id/tvpayMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="5dp"
                        android:gravity="center_vertical"
                        android:padding="2dp"
                        android:text="@string/select_pay_mode"
                        android:textAppearance="?android:attr/textAppearanceLarge"
                        android:textSize="18sp" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">


                            <RadioButton
                                android:id="@+id/radiocreditcard"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left"
                                android:text=""
                                android:theme="@style/MyCheckBox" />

                            <TextView
                                android:id="@+id/txtcreditcard"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left|center_vertical"
                                android:layout_weight="1"
                                android:paddingLeft="16dp"
                                android:text="@string/astroshop_online"
                                android:textSize="16sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_creditcard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <FrameLayout
                                android:id="@+id/flCard"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>


                            <!--<include-->
                            <!--android:id="@+id/inccredit"-->
                            <!--layout="@layout/lay_astro_shop_payment_include"-->
                            <!--android:layout_width="match_parent"-->
                            <!--android:layout_height="wrap_content" />-->
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">


                            <RadioButton
                                android:id="@+id/radiodebitcard"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left"
                                android:text=""
                                android:theme="@style/MyCheckBox" />

                            <TextView
                                android:id="@+id/txtdebitcard"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left|center_vertical"
                                android:layout_weight="1"
                                android:paddingLeft="16dp"
                                android:text="@string/astroshop__debit_card"
                                android:textSize="16sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_debitditcard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">


                            <include
                                android:id="@+id/incdebit"
                                layout="@layout/lay_astro_shop_payment_include"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />


                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">


                            <RadioButton
                                android:id="@+id/radionetbanking"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left"
                                android:text=""
                                android:theme="@style/MyCheckBox" />

                            <TextView
                                android:id="@+id/txtnetbanking"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left|center_vertical"
                                android:layout_weight="1"
                                android:paddingLeft="16dp"
                                android:text="@string/astroshop__net_banking"
                                android:textSize="16sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_net_banking"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">


                            <include
                                android:id="@+id/incnetbanking"
                                layout="@layout/lay_astro_shop_payment_include"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />


                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">


                            <RadioButton
                                android:id="@+id/radiowallet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left"
                                android:text=""
                                android:theme="@style/MyCheckBox" />

                            <TextView
                                android:id="@+id/txtWalet"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left|center_vertical"
                                android:layout_weight="1"
                                android:paddingLeft="16dp"
                                android:singleLine="true"
                                android:text="@string/astroshop__wallet"
                                android:textSize="16sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_net_wallet"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">


                            <include
                                android:id="@+id/incnet_wallet"
                                layout="@layout/lay_astro_shop_payment_include"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />


                        </LinearLayout>
                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone">


                            <RadioButton
                                android:id="@+id/radiopui"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left"
                                android:text=""
                                android:theme="@style/MyCheckBox" />

                            <TextView
                                android:id="@+id/txtOptionUpi"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left|center_vertical"
                                android:layout_weight="1"
                                android:paddingLeft="16dp"
                                android:text="@string/upi"
                                android:textSize="16sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_upi"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">


                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="25dp"
                                android:layout_marginTop="5dp"
                                android:layout_marginRight="25dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/txtlblUpi"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="left"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"
                                    android:text="@string/astroshop_you_pay"
                                    android:textSize="16sp" />

                                <TextView
                                    android:id="@+id/txtUpicost"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="right|end"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"
                                    android:text="2777Rs"
                                    android:textSize="16sp" />
                            </LinearLayout>


                            <Button
                                android:id="@+id/btn_upi_pay_place_order"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:layout_marginLeft="25dp"
                                android:layout_marginTop="15dp"
                                android:layout_marginRight="25dp"
                                android:layout_marginBottom="20dp"
                                android:elevation="7dp"
                                android:gravity="center"
                                android:text="@string/astroshop_place_order"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:theme="@style/MyDialogeButton" />


                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">


                                <RadioButton
                                    android:id="@+id/radiocheque"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="left"
                                    android:text=""
                                    android:theme="@style/MyCheckBox" />

                                <TextView
                                    android:id="@+id/txtcheque"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="left|center_vertical"
                                    android:layout_weight="1"
                                    android:paddingLeft="16dp"
                                    android:text="@string/astroshop__cheque_dd"
                                    android:textSize="16sp" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/layout_cheque_dd"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="25dp"
                                    android:layout_marginTop="5dp"
                                    android:layout_marginRight="25dp"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/txtchequedd"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="left"
                                        android:paddingTop="2dp"
                                        android:paddingBottom="2dp"
                                        android:text="@string/astroshop_you_pay"
                                        android:textSize="16sp" />

                                    <TextView
                                        android:id="@+id/txtchequeddcost"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="right|end"
                                        android:paddingTop="2dp"
                                        android:paddingBottom="2dp"
                                        android:text="2777Rs"
                                        android:textSize="16sp" />
                                </LinearLayout>


                                <Button
                                    android:id="@+id/btn_pay_place_order_cheque_dd"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:layout_gravity="center"
                                    android:layout_marginLeft="25dp"
                                    android:layout_marginTop="15dp"
                                    android:layout_marginRight="25dp"
                                    android:layout_marginBottom="20dp"
                                    android:elevation="7dp"
                                    android:gravity="center"
                                    android:text="@string/astroshop_place_order"
                                    android:textColor="#FFFFFF"
                                    android:textSize="18sp"
                                    android:theme="@style/MyDialogeButton" />


                            </LinearLayout>

                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical">




                                <LinearLayout
                                    android:id="@+id/cod_layout"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:paddingVertical="@dimen/dimen_5dp"
                                    android:orientation="vertical">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <RadioButton
                                            android:id="@+id/radiocashondelivery"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="left"
                                            android:text=""
                                            android:theme="@style/MyCheckBox" />

                                        <TextView
                                            android:id="@+id/txtcashondelivery"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="left|center_vertical"
                                            android:layout_weight="1"
                                            android:paddingLeft="16dp"
                                            android:text="@string/astroshop__cashe_on"
                                            android:textSize="16sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="-10dp"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:id="@+id/txtcashondeliverylimit"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="left|center_vertical"
                                            android:paddingLeft="50dp"
                                            android:text="@string/cash_on_delivery_limit"
                                            android:textSize="13sp" />
                                    </LinearLayout>
                                </LinearLayout>


                            <LinearLayout
                                android:id="@+id/layout_cash_on_delivery"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="25dp"
                                    android:layout_marginTop="5dp"
                                    android:layout_marginRight="25dp"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/txtyoupaycashon"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="left"
                                        android:text="@string/astroshop_you_pay"
                                        android:textSize="16sp" />

                                    <TextView
                                        android:id="@+id/txtyoupayrscashon"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="right|end"
                                        android:text="2777Rs"
                                        android:textSize="16sp" />
                                </LinearLayout>


                                <Button
                                    android:id="@+id/btn_pay_place_order"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:layout_gravity="center"
                                    android:layout_marginLeft="25dp"
                                    android:layout_marginTop="15dp"
                                    android:layout_marginRight="25dp"
                                    android:layout_marginBottom="20dp"
                                    android:elevation="7dp"
                                    android:gravity="center"
                                    android:text="@string/astroshop_place_order"
                                    android:textColor="@color/white"
                                    android:textSize="18sp"
                                    android:backgroundTint="@color/colorPrimary_day_night" />


                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvOptoins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="right"
                            android:gravity="right|end"
                            android:padding="5dp"
                            android:text="@string/show_saved_cards"
                            android:textColor="@color/colorPrimary_day_night"
                            android:textSize="16sp"
                            android:visibility="visible" />
                    </LinearLayout>


                    <Button
                        android:id="@+id/btn_online_pay_place_order"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:layout_marginLeft="25dp"
                        android:layout_marginTop="15dp"
                        android:layout_marginRight="25dp"
                        android:layout_marginBottom="20dp"
                        android:elevation="7dp"
                        android:gravity="center"
                        android:text="@string/astroshop_place_order"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:backgroundTint="@color/colorPrimary_day_night" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>


        </LinearLayout>
    </ScrollView>

</LinearLayout>