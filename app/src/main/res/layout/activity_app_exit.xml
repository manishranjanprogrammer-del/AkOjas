<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColorView"
    android:orientation="vertical"
    android:descendantFocusability="beforeDescendants"
    android:focusableInTouchMode="true">

    <include
        android:id="@+id/appbarAppModule"
        layout="@layout/wallet_toolbar"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/app_exit_font_size"
        android:layout_margin="15dp"
        android:text="@string/hear_about_astrosage"
        android:layout_below="@id/appbarAppModule"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_title"/>

    <LinearLayout
        android:id="@+id/ll_others"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:visibility="gone"
        android:layout_below="@id/recycler_view"
        android:orientation="vertical" >

        <TextView
            android:id="@+id/tv_others_heading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:textSize="@dimen/app_exit_font_size"
            android:layout_weight="0.5"
            android:drawablePadding="10dp"
            android:text="@string/abuse_report_4" />

        <EditText
            android:id="@+id/et_others"
            style="@style/profile_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/yellow_stroke_silver_bg"
            android:ellipsize="end"
            android:inputType="textCapSentences"
            android:maxLength="20"
            android:maxLines="1"
            android:minHeight="@dimen/margin_xXlarge"
            android:paddingStart="5dp"
            android:textColorHint="@color/black" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:weightSum="1"
        android:layout_gravity="bottom"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal" >

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.5"
            app:cardCornerRadius="7dp"
            android:layout_marginBottom="@dimen/cardview_keyline_1_minus_8dp"
            android:layout_marginLeft="@dimen/cardview_keyline_1_minus_8dp"
            android:layout_marginRight="@dimen/cardview_keyline_1_minus_8dp"
            android:layout_marginTop="@dimen/cardview_keyline_1_minus_8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_border_primary_color_round"
                android:gravity="center">

            <TextView
                android:id="@+id/tv_cancel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/app_exit_font_size"
                android:padding="10dp"
                android:textColor="@color/black"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:text="@string/cancel" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.5"
            app:cardCornerRadius="7dp"
            app:cardBackgroundColor="@color/colorPrimary_day_night"
            android:layout_marginBottom="@dimen/cardview_keyline_1_minus_8dp"
            android:layout_marginLeft="@dimen/cardview_keyline_1_minus_8dp"
            android:layout_marginRight="@dimen/cardview_keyline_1_minus_8dp"
            android:layout_marginTop="@dimen/cardview_keyline_1_minus_8dp">

            <TextView
                android:id="@+id/tv_submit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/app_exit_font_size"
                android:padding="10dp"
                android:textColor="@color/white"
                android:gravity="center_horizontal"
                android:text="@string/submit" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>


</RelativeLayout>