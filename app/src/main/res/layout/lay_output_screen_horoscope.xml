<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:descendantFocusability="beforeDescendants"
    android:focusableInTouchMode="true">

        <include
            android:id="@+id/toolBar_InputKundli"
            layout="@layout/tool_bar_app_module"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true" />

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/toolBar_InputKundli"
            android:layout_above="@id/ask_question_layout"
            android:orientation="vertical">

            <com.ojassoft.astrosage.ui.customcontrols.CustomViewPager
                android:id="@+id/pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

    <RelativeLayout
        android:id="@+id/ask_question_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/homeBottomNav"
        android:visibility="gone"
        android:background="@color/white">

        <View
            android:id="@+id/ask_layoutBorder"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_alignParentTop="true"
            android:background="@drawable/shadow_gray_outline" />

        <com.ojassoft.astrosage.varta.utils.TypeWriter
            android:id="@+id/tv_ask_que"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dimen_20dp"
            android:layout_marginEnd="@dimen/dimen_10dp"
            android:layout_toStartOf="@+id/buttonSend"
            android:layout_marginTop="@dimen/dimen_14dp"
            android:layout_marginBottom="@dimen/dimen_14dp"
            android:background="@drawable/circle_border_chat_input_box"
            android:padding="12dp"
            android:text="@string/ask_anything_to_kundli"
            android:hint="@string/ask_anything_to_kundli"
            android:textColorHint="@color/transparent"
            android:textColor="@color/hint_text_color" />


        <RelativeLayout
            android:id="@+id/buttonSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:background="@drawable/circle_yellow"
            android:gravity="center">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/icon_send"
                app:tint="@color/white" />
        </RelativeLayout>

    </RelativeLayout>

    <include
        android:id="@+id/homeBottomNav"
        layout="@layout/custom_bottom_nav_with_gif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

        <LinearLayout
            android:id="@+id/advLayout"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:visibility="gone"/>


    </RelativeLayout>
