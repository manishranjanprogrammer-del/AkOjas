<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginLeft="@dimen/cardview_keyline_1_minus_8dp"
    android:layout_marginRight="@dimen/cardview_keyline_1_minus_8dp"
    android:layout_marginTop="@dimen/cardview_keyline_1_minus_8dp"
    app:cardBackgroundColor="@color/bg_card_view_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="@dimen/cardview_keyline_1_minus_8dp"
        android:layout_marginRight="@dimen/cardview_keyline_1_minus_8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/muhuratTopName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_height"
            android:minHeight="@dimen/min_height"
            android:text="Diwali Muhurat for new Delhi India"
            android:textSize="18sp"
            android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/muhuratValue1"

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/muhuraValue"
                    android:text="17:59:42 to 18:40:43"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/muhuratValue2"

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/muhuraValue"
                    android:layout_toRightOf="@+id/muhuratDurationHeading"
                    android:text="1 Hour 55 Minute"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/muhuratValue3"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"
                    android:layout_below="@+id/muhuraValue"
                    android:text="13:59:42 to 15:40:43"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/muhuratValue4"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"
                    android:layout_below="@+id/muhuraValue"
                    android:layout_toRightOf="@+id/muhuratDurationHeading"
                    android:text="19:59:42 to 20:40:43"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/muhuratValue5"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"
                    android:layout_below="@+id/muhuraValue"
                    android:layout_toRightOf="@+id/muhuratDurationHeading"
                    android:text="19:59:42 to 20:40:43"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/muhuratValue6"
                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"
                    android:layout_below="@+id/muhuraValue"
                    android:layout_toRightOf="@+id/muhuratDurationHeading"
                    android:text="19:59:42 to 20:40:43"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/muhuratValue7"
                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"
                    android:layout_below="@+id/muhuraValue"
                    android:layout_toRightOf="@+id/muhuratDurationHeading"
                    android:text="19:59:42 to 20:40:43"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/muhuratValue8"
                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"
                    android:layout_below="@+id/muhuraValue"
                    android:layout_toRightOf="@+id/muhuratDurationHeading"
                    android:text="19:59:42 to 20:40:43"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>


</androidx.cardview.widget.CardView>