<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:orientation="vertical">

    <include
        android:id="@+id/toolbar_magazine"
        layout="@layout/tool_bar_magazine" />
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFECB3"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- <ImageView
             android:layout_marginTop="16dp"
             android:id="@+id/edit_profile_img"
             android:layout_width="100dp"
             android:layout_height="100dp"
             android:src="@drawable/ic_profile_view" />-->
        <com.ojassoft.astrosage.beans.RoundImage
            android:id="@+id/edit_profile_img"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_profile_view" />

        <TextView
            android:id="@+id/user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:paddingTop="16dp"
            android:textColor="@color/no_change_black"
            android:text="Amit" />

        <TextView
            android:id="@+id/user_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="@color/no_change_black"

            android:text="amitsharma.sari@gmail.com" />
    </LinearLayout>
    <androidx.cardview.widget.CardView
        android:layout_marginTop="8dp"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="4dp"
        android:layout_width="match_parent"
        app:cardBackgroundColor="@color/bg_card_view_color"
        android:layout_height="wrap_content">

    <LinearLayout
        android:layout_margin="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card_view_color"
        android:orientation="vertical">
        <TextView
            android:layout_marginTop="4dp"
            android:id="@+id/user_detail_heading"
            android:textSize="18sp"
            android:text="@string/user_detail_heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textViewUserName"
                android:layout_width="0dp"
                android:layout_weight=".5"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:alpha=".9"
                android:textSize="16sp"
                android:text="@string/lbl_your_name_with_colon"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayUserName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:layout_height="wrap_content"
                android:textColorHint="@color/text_day_gray_night_white">

                <EditText
                    android:id="@+id/user_name_edittext"
                    style="@style/Theme.App.Base"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/colorPrimary_day_night"
                    android:capitalize="sentences"
                    android:hint="@string/username"
                    android:inputType="textCapWords"
                    android:textColor="@color/black"
                    />
                <!-- android:inputType="textNoSuggestions"-->
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textViewMobileNo"
                android:layout_width="0dp"
                android:layout_weight=".5"
                android:layout_height="wrap_content"
                android:alpha=".9"
                android:layout_gravity="center_vertical"
                android:textSize="16sp"
                android:text="@string/mobile_no"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayMobileNo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:layout_height="wrap_content"
                android:textColorHint="@color/text_day_gray_night_white">

                <EditText
                    android:id="@+id/mobile_no_edittext"
                    style="@style/Theme.App.Base"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/ColorPrimary"
                    android:capitalize="sentences"
                    android:hint="@string/astroshop_shipping_enter_mobile_no"
                    android:inputType="number"
                    android:textColor="@color/black"
                    />
                <!-- android:inputType="textNoSuggestions"-->
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textViewMaterialStatus"
                android:layout_width="0dp"
                android:layout_weight=".5"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:alpha=".9"
                android:textSize="16sp"
                android:text="@string/marital_status"/>

            <LinearLayout
                android:layout_marginLeft="4dp"
                android:background="@drawable/rect_rounded_image"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <Spinner
                    style="@style/Base.Widget.AppCompat.Spinner"
                    android:id="@+id/material_status_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textViewOccupation"
                android:layout_width="0dp"
                android:layout_weight=".5"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:alpha=".9"
                android:textSize="16sp"
                android:text="@string/occupation_with_colon"/>

            <LinearLayout
                android:layout_marginLeft="4dp"
                android:background="@drawable/rect_rounded_image"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">

                <Spinner
                    style="@style/Base.Widget.AppCompat.Spinner"
                    android:id="@+id/occupation_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/footer_card"
            android:layout_marginTop="8dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            app:cardBackgroundColor="@color/bg_card_view_color"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_margin="16dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="4dp"
                    android:id="@+id/footer_detail_heading"
                    android:textSize="18sp"
                    android:text="@string/footer_detail_heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <LinearLayout
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textViewHeading"
                        android:layout_width="0dp"
                        android:layout_weight=".5"
                        android:layout_height="wrap_content"
                        android:alpha=".9"
                        android:layout_gravity="center_vertical"
                        android:textSize="16sp"
                        android:text="@string/heading"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputLayHeading"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="4dp"
                        android:layout_height="wrap_content"
                        android:textColorHint="@color/text_day_gray_night_white"
                        >

                        <EditText
                            android:id="@+id/heading_edittext"
                            style="@style/Theme.App.Base"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:backgroundTint="@color/ColorPrimary"
                            android:capitalize="sentences"
                            android:hint="Astrologer / Company name"
                            android:maxLength="50"
                            android:inputType="textCapWords"
                            android:textColor="@color/black"
                            />
                        <!-- android:inputType="textNoSuggestions"-->
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textViewLine1"
                        android:layout_width="0dp"
                        android:layout_weight=".5"
                        android:layout_height="wrap_content"
                        android:alpha=".9"
                        android:layout_gravity="center_vertical"
                        android:textSize="16sp"
                        android:text="@string/line1"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputLayLine1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="4dp"
                        android:layout_height="wrap_content"
                        android:textColorHint="@color/text_day_gray_night_white">

                        <EditText
                            android:id="@+id/line1_edittext"
                            style="@style/Theme.App.Base"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:backgroundTint="@color/ColorPrimary"
                            android:capitalize="sentences"
                            android:hint="Address"
                            android:maxLength="80"
                            android:inputType="textCapWords"
                            android:textColor="@color/black"
                            />
                        <!-- android:inputType="textNoSuggestions"-->
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textViewLine2"
                        android:layout_width="0dp"
                        android:layout_weight=".5"
                        android:layout_height="wrap_content"
                        android:alpha=".9"
                        android:layout_gravity="center_vertical"
                        android:textSize="16sp"
                        android:text="@string/line2"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/inputLayLine2"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="4dp"
                        android:layout_height="wrap_content"
                        android:textColorHint="@color/text_day_gray_night_white">

                        <EditText
                            android:id="@+id/line2_edittext"
                            style="@style/Theme.App.Base"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:backgroundTint="@color/ColorPrimary"
                            android:capitalize="sentences"
                            android:hint="Contact Details"
                            android:maxLength="80"
                            android:inputType="textCapWords"
                            android:textColor="@color/black"
                            />
                        <!-- android:inputType="textNoSuggestions"-->
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    <Button
        android:id="@+id/saveBtn"
        style="@style/buttonstyle"
        android:layout_width="match_parent"
        android:layout_gravity="center_horizontal"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginRight="16dp"
        android:text="@string/save_kundli"
        android:textAllCaps="false"
        android:layout_marginBottom="0dp"
        android:theme="@style/buttonstyle" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_change_password"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:maxLines="1"
            android:clickable="true"
            android:textColor="@color/colorPrimary_day_night"
            android:text="@string/change_password_underline" />

    </LinearLayout>
    </LinearLayout>
    </ScrollView>
</LinearLayout>