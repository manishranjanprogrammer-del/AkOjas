<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginLeft="@dimen/dimen_6dp"
    android:layout_marginBottom="6dp"
    android:orientation="horizontal"
    android:id="@+id/llMsgParentLayout">

    <androidx.cardview.widget.CardView
        app:cardBackgroundColor="@color/black"
        android:id="@+id/nameTvParent"
        android:layout_marginRight="@dimen/dimen_6dp"
        app:cardCornerRadius="@dimen/dimen_16dp"
        android:layout_height="@dimen/dimen_32dp"
        android:layout_width="@dimen/dimen_32dp">

        <TextView
            android:id="@+id/nameTv"
            android:layout_gravity="center"
            android:layout_height="@dimen/dimen_32dp"
            android:layout_width="@dimen/dimen_32dp"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/no_change_white"
            android:textSize="@dimen/font_small" />

    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/bgMsgLL"
        android:background="@drawable/bg_live_steaming_chat_trans"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:paddingBottom="5dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/fromTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:gravity="top|center"
            android:textStyle="bold"
            android:textColor="@color/no_change_white"
            android:textSize="@dimen/font_msmall"
            android:padding="1dp"
            android:layout_marginRight="5dp" />
        <TextView
            android:id="@+id/messageTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:gravity="left|center"
            android:textColor="@color/no_change_white"
            android:textSize="@dimen/font_mediumSmall"
            android:padding="1dp"
            android:layout_marginRight="5dp" />

    </LinearLayout>

</LinearLayout>
