<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/backgroundColor"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/containerLayout"
        android:layout_width="match_parent"
        android:layout_height="60dip"
        android:background="@drawable/bg_layout_clickable"
        android:gravity="center|left"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/margin_mlarge"
        android:paddingRight="@dimen/margin_mlarge">

        <ImageView
            android:id="@+id/iconAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right|center"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_history_black"
            android:visibility="visible"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/history_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:layout_marginLeft="@dimen/margin_mlarge"
            android:textColor="@color/black"
            android:textSize="@dimen/font_large" />

    </LinearLayout>

</LinearLayout>