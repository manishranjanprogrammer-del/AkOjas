<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColorView"
    android:clickable="true">

    <RelativeLayout
        android:id="@+id/mainConatiner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/innerContainerAskAQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/containerDrawerUserData"
            android:paddingTop="16dp"
            android:visibility="gone">


            <TextView
                android:id="@+id/tvQuestionPriceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_marginLeft="@dimen/cardview_keyline_1_minus_8dp"
                android:text="@string/question_price_text"
                android:textColor="@color/black"
                android:textSize="@dimen/subheading_text_size" />

            <TextView
                android:id="@+id/tvQuestionPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_marginRight="@dimen/cardview_keyline_1_minus_8dp"
                android:textColor="@color/black"
                android:textSize="@dimen/subheading_text_size" />

            <TextView
                android:id="@+id/tvFreeQuestionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tvQuestionPriceText"
                android:layout_alignParentLeft="true"
                android:layout_marginLeft="@dimen/cardview_keyline_1_minus_8dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="@dimen/activity_vertical_margin"
                android:text="@string/free_ques_text"
                android:textColor="@color/black"
                android:textSize="@dimen/subheading_text_size" />

            <TextView
                android:id="@+id/tvFreeQuestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tvQuestionPriceText"
                android:layout_alignParentRight="true"
                android:layout_marginTop="16dp"
                android:layout_marginRight="@dimen/cardview_keyline_1_minus_8dp"
                android:layout_marginBottom="@dimen/activity_vertical_margin"
                android:textColor="@color/black"
                android:textSize="@dimen/subheading_text_size" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_below="@+id/tvFreeQuestionText"
                android:background="@color/light_grey" />

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/containerDrawerProfileForMatchMaking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/containerDrawerUserData"
            android:paddingTop="@dimen/status_bar_height"
            android:visibility="gone">

            <RelativeLayout
                android:id="@+id/female_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/ic_female_matching"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:src="@drawable/female_user" />

                <TextView
                    android:id="@+id/tvGirlName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/ic_female_matching"
                    android:text=""
                    android:textColor="@color/black"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvGirlData"
                    style="@style/content_style"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/tvGirlName"
                    android:layout_toEndOf="@+id/ic_female_matching"
                    android:text="" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/male_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/devider"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/ic_male_matching"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:src="@drawable/male_user" />

                <TextView
                    android:id="@+id/tvBoyName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/ic_male_matching"
                    android:text=""
                    android:textColor="@color/black"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvBoyData"
                    style="@style/content_style"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/tvBoyName"
                    android:layout_toEndOf="@+id/ic_male_matching"
                    android:text="" />
            </RelativeLayout>


            <View
                android:id="@+id/devider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_below="@+id/female_container"
                android:layout_marginTop="8dp"
                android:background="@color/light_grey" />

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/containerDrawerUserData"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:visibility="visible">

            <LinearLayout
                android:id="@+id/ll_profile_pic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingRight="4dp">

                <com.ojassoft.astrosage.beans.RoundImage
                    android:id="@+id/imgProfilePic"
                    android:layout_width="65dp"
                    android:layout_height="65dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/male_user"
                    android:visibility="visible" />
                <LinearLayout
                    android:id="@+id/user_detail_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:gravity="center_vertical"
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvusername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:paddingEnd="@dimen/dimen_10dp"
                        android:textSize="@dimen/tv_size_22"
                        android:text="admin@gmail.com"
                        android:textColor="@color/black" />

                    <TextView
                        android:id="@+id/plantv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dimen_18dp"
                        android:maxLines="2"
                        android:textSize="16sp"
                        android:foreground="?attr/selectableItemBackground"
                        android:text="@string/dhruv_plan_txt"
                        android:textColor="@color/black" />

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/signInSignUpLayout"
                    android:layout_width="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_16dp"
                    android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gray_text_view_border"
                    android:paddingVertical="2dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:paddingHorizontal="@dimen/dimen_16dp"
                    android:textSize="@dimen/tv_size_16"
                    android:text="@string/button_sign_in"
                    android:gravity="center"
                    android:textColor="@color/black" />

                <TextView
                    android:id="@+id/tvSignUp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/tv_size_16"
                    android:layout_marginHorizontal="@dimen/dimen_12dp"
                    android:background="@drawable/gray_text_view_border"
                    android:paddingVertical="2dp"
                    android:paddingHorizontal="@dimen/dimen_16dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:singleLine="true"
                    android:gravity="center"
                    android:text="@string/sign_up"
                    android:textColor="@color/black" />
                </LinearLayout>

                <!--            <ImageView-->
                <!--                android:id="@+id/edit_profile"-->
                <!--                android:layout_width="32dp"-->
                <!--                android:layout_height="32dp"-->
                <!--                android:layout_gravity="bottom"-->
                <!--                android:layout_toRightOf="@id/imgProfilePic"-->
                <!--                android:layout_marginTop="35dp"-->
                <!--                android:layout_marginLeft="-25dp"-->
                <!--                android:src="@drawable/ic_edit_profile"/>-->

            </LinearLayout>

        </RelativeLayout>

        

        <LinearLayout
            android:id="@+id/kundli_details_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_below="@+id/containerDrawerUserData">
            <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"
            android:layout_above="@id/kundli_details_layout"/>
            <TextView
                android:id="@+id/defaultKundliUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/defaultKundliUserData"
                style="@style/content_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black" />
        </LinearLayout>

    </RelativeLayout>
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_below="@id/mainConatiner"
        android:background="@color/dividerColor" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/drawerList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/divider"/>


</RelativeLayout>
