<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/parent_layout"
    style="@style/SelectableItemBackground"
    android:layout_height="wrap_content"
    android:layout_width="88dp"
    android:background="@color/backgroundColorView"
    android:foreground="?attr/selectableItemBackground"
    >

    <ImageView
        android:id="@+id/imageViewProductIcon"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:layout_marginTop="8dp"
        android:contentDescription="@null"
        android:background="@drawable/circle_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scaleType="centerCrop"
        android:padding="@dimen/dimen_8dp"
        android:src="@drawable/cancer" />

    <TextView
        android:id="@+id/textViewProductName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        app:layout_constraintStart_toStartOf="@+id/imageViewProductIcon"
        app:layout_constraintEnd_toEndOf="@+id/imageViewProductIcon"
        app:layout_constraintTop_toBottomOf="@+id/imageViewProductIcon"
        android:textColor="@color/black_87DN"
        android:text="Medium Text"
        android:textSize="@dimen/tv_size_14"
        android:paddingHorizontal="2dp"
        android:maxLines="3" />

</androidx.constraintlayout.widget.ConstraintLayout>