<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/mainlayout"
    android:background="@drawable/bg_dialog"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/close_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="0dp"
            android:layout_marginRight="10dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/cross_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:contentDescription="@null"
                android:src="@drawable/ic_action_navigation_close"
                android:visibility="gone"></ImageView>

        </RelativeLayout>

        <TextView
            android:id="@+id/thanku_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:gravity="center"
            android:text="@string/call_initiated"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_20"
            android:textStyle="bold"></TextView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="8dp"
                android:paddingRight="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10sp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/receive_call_from_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:text="@string/receive_call_from_txt"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_15"/>

                    <TextView
                        android:id="@+id/astro_phone_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingLeft="2dp"
                        android:visibility="gone"
                        android:text="@string/astro_phone_number"
                        android:textColor="@color/Orangecolor"
                        android:textSize="@dimen/tv_size_15"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/get_call_shortly_txt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="15dp"
                    android:gravity="center"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:text="@string/astrologer_call_shortly_msg"
                    android:textColor="@color/darker_gray"
                    android:textSize="@dimen/tv_size_15"
                    android:visibility="gone"/>

            </LinearLayout>
        </RelativeLayout>
        <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
            android:id="@+id/asto_profile_img"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_profile_view" />
        <TextView
            android:id="@+id/astrologerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="@string/connecting_with"
            android:layout_marginHorizontal="@dimen/dimen_10dp"
            android:layout_marginTop="@dimen/dimen_8dp"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_14" />
        <!--<TextView
            android:id="@+id/astrologerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="@dimen/dimen_15dp"
            android:layout_gravity="center_horizontal"
            android:ellipsize="end"
            android:layout_marginTop="@dimen/dimen_5dp"
            android:textStyle="bold"
            android:maxLines="1"
            android:text=""
            android:textColor="@color/Orangecolor"
            android:textSize="@dimen/tv_size_15" />-->

        <Button
            android:id="@+id/free_minute_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_black"
            android:gravity="center"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:text="@string/available_talktime"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/tv_size_15"></Button>

        <TextView
            android:id="@+id/tvInternationalCallNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:text="@string/international_call_note"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_15"
            android:visibility="gone"></TextView>

        <TextView
            android:id="@+id/call_not_recieve_msg_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:text="@string/call_initiated_note_msg"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_15"></TextView>

        <TextView
            android:id="@+id/number_switched_on_msg_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:text="@string/call_switched_on_msg"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_15"></TextView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <Button
                android:id="@+id/ok_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="15dp"
                android:layout_marginRight="8dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_button_orange"
                android:gravity="center"
                android:text="@string/ok"
                android:textColor="@color/white"
                android:textSize="@dimen/tv_size_20"></Button>
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>
