<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="@dimen/dimen_20dp">

    <View
        android:id="@+id/view1"
        android:layout_width="@dimen/dimen_24dp"
        android:layout_height="@dimen/dimen_24dp"
        android:background="@drawable/circle_black"
        android:backgroundTint="@color/dot_gray"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>


    <androidx.cardview.widget.CardView
        android:id="@+id/card1"
        android:layout_width="200dp"
        android:layout_height="60dp"
        app:cardCornerRadius="@dimen/dimen_15dp"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginStart="@dimen/dimen_15dp"
        app:layout_constraintLeft_toRightOf="@id/view1"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/card2"
        android:layout_width="200dp"
        android:layout_height="60dp"
        app:cardCornerRadius="@dimen/dimen_15dp"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginTop="30dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card1"/>

    <View
        android:id="@+id/view3"
        android:layout_width="@dimen/dimen_24dp"
        android:layout_height="@dimen/dimen_24dp"
        android:background="@drawable/circle_black"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/card2"
        app:layout_constraintLeft_toLeftOf="parent"/>


    <androidx.cardview.widget.CardView
        android:id="@+id/card3"
        android:layout_width="200dp"
        android:layout_height="60dp"
        app:cardCornerRadius="@dimen/dimen_15dp"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginStart="@dimen/dimen_15dp"
        app:layout_constraintLeft_toRightOf="@id/view3"
        app:layout_constraintTop_toTopOf="@id/view3"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/card4"
        android:layout_width="200dp"
        android:layout_height="60dp"
        app:cardCornerRadius="@dimen/dimen_15dp"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginTop="30dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card3"/>

    <View
        android:id="@+id/view5"
        android:layout_width="@dimen/dimen_24dp"
        android:layout_height="@dimen/dimen_24dp"
        android:background="@drawable/circle_black"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/card4"
        app:layout_constraintLeft_toLeftOf="parent"/>


    <androidx.cardview.widget.CardView
        android:id="@+id/card5"
        android:layout_width="200dp"
        android:layout_height="60dp"
        app:cardCornerRadius="@dimen/dimen_15dp"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginStart="@dimen/dimen_15dp"
        app:layout_constraintLeft_toRightOf="@id/view5"
        app:layout_constraintTop_toTopOf="@id/view5"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/card6"
        android:layout_width="200dp"
        android:layout_height="60dp"
        app:cardCornerRadius="@dimen/dimen_15dp"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginTop="30dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card5"/>

    <View
        android:id="@+id/view7"
        android:layout_width="@dimen/dimen_24dp"
        android:layout_height="@dimen/dimen_24dp"
        android:background="@drawable/circle_black"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/card6"
        app:layout_constraintLeft_toLeftOf="parent"/>


    <androidx.cardview.widget.CardView
        android:id="@+id/card7"
        android:layout_width="200dp"
        android:layout_height="60dp"
        app:cardCornerRadius="@dimen/dimen_15dp"
        android:backgroundTint="@color/dot_gray"
        android:layout_marginStart="@dimen/dimen_15dp"
        app:layout_constraintLeft_toRightOf="@id/view7"
        app:layout_constraintTop_toTopOf="@id/view7"/>

</androidx.constraintlayout.widget.ConstraintLayout>