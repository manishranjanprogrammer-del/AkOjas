<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clVideoCallParent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/full_screen_bg">
        <!--    <FrameLayout-->
        <!--        android:id="@+id/flVideoCallCanvasSelfFull"-->
        <!--        android:layout_width="match_parent"-->
        <!--        android:layout_height="match_parent"-->
        <!--        android:visibility="gone" />-->

        <!-- Spacer height is set from window insets so content stays below the status bar. -->
        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/flVideoCallCanvasRemote"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible" />

        <RelativeLayout
            android:id="@+id/ll_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_border_gradient"
            android:elevation="@dimen/dimen_5dp"
            android:paddingBottom="@dimen/dimen_15dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusBarSpacer">
            <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                android:id="@+id/profile_icon"
                android:layout_width="@dimen/live_name_board_icon_size"
                android:layout_height="@dimen/live_name_board_icon_size"
                android:layout_marginStart="@dimen/dimen_18dp"
                android:layout_marginTop="@dimen/dimen_10dp"
                android:scaleType="centerCrop"
                android:layout_alignParentStart="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/profile_icon"
                android:orientation="vertical">
            <TextView
                android:id="@+id/tvVideoCallAstroName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_20dp"
                android:layout_marginEnd="@dimen/dimen_10dp"
                android:layout_marginBottom="@dimen/dimen_5dp"
                android:paddingTop="12dp"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_18"
                android:textStyle="bold"
                android:visibility="visible"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/llVideoCallDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_20dp"
                android:orientation="horizontal"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent">

                <TextView
                    android:id="@+id/tvVideoCallDurationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_remaining"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_16"
                    android:visibility="visible"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvVideoCallAstroName" />

                <TextView
                    android:id="@+id/tvVideoCallDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_16"
                    android:visibility="visible"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvVideoCallAstroName" />
            </LinearLayout>
            </LinearLayout>
        </RelativeLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_mute_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/tv_size_20"
            android:background="@drawable/bg_live_steaming_chat_trans"
            android:padding="@dimen/dimen_15dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_info_card">

            <ImageView
                android:id="@+id/mute_image_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="7dp"
                android:src="@drawable/ic_live_mute"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/orange_color" />

            <TextView
                android:id="@+id/text_mute_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_14"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/mute_image_icon" />

        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            android:id="@+id/remote_user_offline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/black"
            android:layout_margin="@dimen/tv_size_10"
            android:textSize="18sp"
            android:padding="@dimen/tv_size_10"
            android:textStyle="bold"
            android:text="@string/plz_wait_for_video_call"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:visibility="gone"/>

        <View
            android:id="@+id/guideView"
            android:layout_width="match_parent"
            android:layout_height="66dp"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/ivVideoCallSwitch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="30dp"
            android:background="@drawable/bg_gray_circle"
            android:foreground="?android:attr/selectableItemBackground"
            android:padding="@dimen/dimen_3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/btn_switch_camera"
            app:layout_constraintBottom_toBottomOf="@id/ivVideoCallEnd"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/ivVideoCallVideo"
            app:layout_constraintTop_toTopOf="@id/ivVideoCallEnd"
            app:tint="@color/white" />

        <ImageButton
            android:id="@+id/ivVideoCallVideo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_gray_circle"
            android:padding="@dimen/dimen_8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/btn_mute_video"
            app:layout_constraintBottom_toBottomOf="@id/ivVideoCallEnd"
            app:layout_constraintLeft_toRightOf="@id/ivVideoCallSwitch"
            app:layout_constraintRight_toLeftOf="@id/ivVideoCallMic"
            app:layout_constraintTop_toTopOf="@id/ivVideoCallEnd" />

        <ImageButton
            android:id="@+id/ivVideoCallMic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_gray_circle"
            android:foreground="?android:attr/selectableItemBackground"
            android:padding="@dimen/dimen_10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/btn_mute_audio"
            app:tint="@color/no_change_white"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@id/ivVideoCallEnd"
            app:layout_constraintLeft_toRightOf="@id/ivVideoCallVideo"
            app:layout_constraintRight_toLeftOf="@id/ivVideoCallEnd"
            app:layout_constraintTop_toTopOf="@id/ivVideoCallEnd" />

        <ImageButton
            android:id="@+id/ivVideoCallEnd"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginRight="40dp"
            android:background="@drawable/end_call_icon"
            android:foreground="?android:attr/selectableItemBackground"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@id/ivVideoCallMic"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@id/guideView" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
