<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clVideoCallParent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/full_screen_bg">

        <!-- Remote Video Container - Full Screen Background -->
        <FrameLayout
            android:id="@+id/flVideoCallCanvasRemote"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Background Overlay for Voice Call Style -->
        <View
            android:id="@+id/backgroundOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/full_screen_bg"
            android:alpha="0.0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Spacer height is set from window insets so content stays below the status bar. -->
        <View
            android:id="@+id/statusBarSpacer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Background Sparkles - Same as Voice Call -->
        <ImageView
            android:id="@+id/bgSparkleLarge"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:alpha="0.0"
            android:rotation="8"
            android:src="@drawable/ic_sparkles"
            app:layout_constraintBottom_toTopOf="@id/guideView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusBarSpacer"
            app:tint="@color/no_change_white" />

        <ImageView
            android:id="@+id/bgSparkleLeft"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:alpha="0.0"
            android:rotation="-10"
            android:src="@drawable/ic_sparkles"
            app:layout_constraintBottom_toTopOf="@id/guideView"
            app:layout_constraintEnd_toStartOf="@id/bgSparkleLarge"
            app:layout_constraintHorizontal_bias="0.22"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/bgSparkleLarge"
            app:tint="@color/no_change_white" />

        <ImageView
            android:id="@+id/bgSparkleRight"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:alpha="0.0"
            android:src="@drawable/ic_sparkles"
            app:layout_constraintBottom_toTopOf="@id/guideView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.78"
            app:layout_constraintStart_toEndOf="@id/bgSparkleLarge"
            app:layout_constraintTop_toTopOf="@id/bgSparkleLarge"
            app:tint="@color/no_change_white" />

        <ImageView
            android:id="@+id/bgSparkleBottomLeft"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:alpha="0.0"
            android:src="@drawable/ic_sparkles"
            app:layout_constraintBottom_toTopOf="@id/guideView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bgSparkleLarge"
            app:layout_constraintVertical_bias="0.2"
            app:tint="@color/no_change_white" />

        <!-- Profile Container - Voice Call Style -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/profileContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="44dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusBarSpacer">

            <FrameLayout
                android:id="@+id/profileFrame"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:background="@drawable/circle_orange_border"
                android:padding="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                    android:id="@+id/profile_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvVideoCallAstroName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:textColor="@color/day_black_night_yellow"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/profileFrame"
                tools:text="Acharya Dr. Mragaank" />

            <LinearLayout
                android:id="@+id/llVideoCallDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvVideoCallAstroName">

                <TextView
                    android:id="@+id/tvVideoCallDurationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/time_remaining"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/tvVideoCallDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text=" : 00:00:00"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:visibility="visible" />
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_mute_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_live_steaming_chat_trans"
                android:padding="@dimen/dimen_15dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llVideoCallDuration">

                <ImageView
                    android:id="@+id/mute_image_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="7dp"
                    android:src="@drawable/ic_live_mute"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/orange_color" />

                <TextView
                    android:id="@+id/text_mute_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/muteInfoMic"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_14"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/mute_image_icon" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/remote_user_offline"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:padding="@dimen/tv_size_10"
                android:text="@string/plz_wait_for_video_call"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cl_mute_info" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- PiP Info Container - Same as Voice Call -->
        <LinearLayout
            android:id="@+id/pipInfoContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusBarSpacer">

            <TextView
                android:id="@+id/tvPipVideoCallAstroName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/day_black_night_yellow"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="Acharya Dr. Mragaank" />

            <TextView
                android:id="@+id/tvPipVideoCallTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="14sp"
                tools:text="Remaining time : 05:56" />

        </LinearLayout>

        <!-- Bottom Control Dock - Voice Call Style -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/guideView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="34dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <View
                android:id="@+id/top_padding"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clVideoCallTVContainer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toTopOf="@id/paddingView"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/paddingView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toTopOf="@id/consLayoutBottom"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/consLayoutBottom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/voice_call_control_dock"
                android:paddingStart="10dp"
                android:paddingTop="18dp"
                android:paddingEnd="10dp"
                android:paddingBottom="18dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <!-- In-Call Controls Row -->
                <LinearLayout
                    android:id="@+id/inCallControlsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:foregroundGravity="center">

                        <ImageButton
                            android:id="@+id/ivVideoCallSwitch"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_gravity="center"
                            android:background="@drawable/voice_call_speaker_button_background"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="15dp"
                            android:src="@drawable/btn_switch_camera"
                            app:tint="@color/no_change_white" />

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:foregroundGravity="center">

                        <ImageButton
                            android:id="@+id/ivVideoCallVideo"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_gravity="center"
                            android:background="@drawable/voice_call_mic_button_background"
                            android:foreground="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="15dp"
                            android:src="@drawable/btn_mute_video"
                            app:tint="@color/no_change_white" />

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:foregroundGravity="center">

                        <ImageButton
                            android:id="@+id/ivVideoCallMic"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_gravity="center"
                            android:background="@drawable/voice_call_mic_button_background"
                            android:foreground="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="15dp"
                            android:src="@drawable/btn_mute_audio"
                            app:tint="@color/no_change_white" />

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:foregroundGravity="center">

                        <ImageButton
                            android:id="@+id/ivVideoCallEnd"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_circle_red"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="15dp"
                            android:src="@drawable/ic_call_end"
                            app:tint="@color/no_change_white" />

                    </FrameLayout>

                </LinearLayout>

                <!-- Post-Call Actions Row -->
                <LinearLayout
                    android:id="@+id/postCallActionsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:id="@+id/postCallActionCallAgain"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/call_again"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="@drawable/bg_circle_green"
                            android:padding="15dp"
                            android:src="@drawable/video_call_icon"
                            android:visibility="gone"
                            app:tint="@color/no_change_white" />

                        <TextView
                            android:id="@+id/tv_call_again"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="9dp"
                            android:text="@string/call_again"
                            android:textColor="@color/black"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/postCallActionChat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_chat_icon"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="@drawable/voice_call_mic_button_background"
                            android:padding="13dp"
                            android:scaleX="-1.0"
                            android:src="@drawable/icon_fc_chat"
                            android:visibility="gone"
                            app:tint="@color/no_change_white" />

                        <TextView
                            android:id="@+id/tv_chat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="9dp"
                            android:text="@string/chat"
                            android:textColor="@color/black"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/postCallActionCancel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_cancel_call"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="@drawable/bg_circle_red"
                            android:padding="13dp"
                            android:src="@drawable/ic_close_black"
                            android:visibility="gone"
                            app:tint="@color/no_change_white" />

                        <TextView
                            android:id="@+id/tv_cancel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="9dp"
                            android:text="@string/cancel"
                            android:textColor="@color/black"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/viewVideoCallBlackScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            android:visibility="gone" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
