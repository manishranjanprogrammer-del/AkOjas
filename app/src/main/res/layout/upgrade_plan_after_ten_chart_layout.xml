<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/clMainView"
    android:layout_height="match_parent"
    android:background="@color/transparent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="@dimen/dimen_16dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dialog_border_curved_primary"
                android:foreground="@drawable/fg_dialog_border_curved_primary">

                <ImageView
                    android:id="@+id/kundli_iv"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_dialog_top_curve"
                    android:scaleType="centerCrop"
                    android:src="@drawable/kundli_ai_image"
                    app:layout_constraintBottom_toTopOf="@+id/tv_heading"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/shadow2"
                    android:layout_width="@dimen/dimen_0dp"
                    android:layout_height="100dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/ic_black_layer"
                    app:layout_constraintBottom_toBottomOf="@+id/tv_heading"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/ivClosePage"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="@dimen/dimen_10dp"
                    android:src="@drawable/ic_close_live"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />


                <TextView
                    android:id="@+id/tv_heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp"
                    android:paddingHorizontal="@dimen/dimen_10dp"
                    android:paddingTop="4dp"
                    android:text="@string/upgrade_to_kundli_ai_plus"
                    android:textAlignment="center"
                    android:textColor="@color/colorPrimary_day_night"
                    android:textSize="@dimen/tv_size_28"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@+id/headingTV"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />


                <TextView
                    android:id="@+id/headingTV"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_24dp"
                    android:layout_marginEnd="@dimen/dimen_20dp"
                    android:layout_marginBottom="@dimen/dimen_20dp"
                    android:maxLines="2"
                    android:text="@string/sorry_for_10_charts_only_msg"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toTopOf="@+id/subHeading1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />


                <CheckBox
                    android:id="@+id/ivRightTick1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_16dp"
                    android:checked="true"
                    android:enabled="false"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:layout_constraintBottom_toBottomOf="@+id/subHeading1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/subHeading1"
                    app:tint="@color/colorPrimary_day_night" />

                <TextView
                    android:id="@+id/subHeading1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimen_10dp"
                    android:layout_marginBottom="@dimen/dimen_10dp"
                    android:maxLines="1"
                    android:text="@string/save_unlimited_charts_kundali_on_cloud"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_14"
                    app:layout_constraintBottom_toTopOf="@+id/subHeading2"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/ivRightTick1" />

                <CheckBox
                    android:id="@+id/ivRightTick2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_16dp"
                    android:checked="true"
                    android:enabled="false"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:layout_constraintBottom_toBottomOf="@+id/subHeading2"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/subHeading2"
                    app:tint="@color/colorPrimary_day_night" />

                <TextView
                    android:id="@+id/subHeading2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimen_10dp"
                    android:layout_marginBottom="@dimen/dimen_10dp"
                    android:maxLines="1"
                    android:text="@string/Unlimited_free_chat_with_kundli_ai"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_14"
                    app:layout_constraintBottom_toTopOf="@+id/subHeading3"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/ivRightTick2" />

                <CheckBox
                    android:id="@+id/ivRightTick3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_16dp"
                    android:checked="true"
                    android:enabled="false"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:layout_constraintBottom_toBottomOf="@+id/subHeading3"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/subHeading3"
                    app:tint="@color/colorPrimary_day_night" />

                <TextView
                    android:id="@+id/subHeading3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimen_10dp"
                    android:layout_marginBottom="16dp"
                    android:maxLines="1"
                    android:text="@string/pages_colored_kundali_prints"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_14"
                    app:layout_constraintBottom_toTopOf="@+id/subHeading4"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/ivRightTick3" />

                <CheckBox
                    android:id="@+id/ivRightTick4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_16dp"
                    android:checked="true"
                    android:enabled="false"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:layout_constraintBottom_toBottomOf="@+id/subHeading4"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/subHeading4"
                    app:tint="@color/colorPrimary_day_night"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/subHeading4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimen_10dp"
                    android:layout_marginBottom="16dp"
                    android:maxLines="1"
                    android:text="@string/free_shipping_on_products"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_14"
                    app:layout_constraintBottom_toTopOf="@+id/dont_show_tv"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:visibility="gone"
                    app:layout_constraintStart_toEndOf="@+id/ivRightTick4" />

                <CheckBox
                    android:id="@+id/checkDobotShowAgain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_16dp"
                    android:checked="false"
                    android:enabled="true"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:layout_constraintBottom_toBottomOf="@+id/dont_show_tv"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/dont_show_tv"
                    app:tint="@color/colorPrimary_day_night" />

                <TextView
                    android:id="@+id/dont_show_tv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimen_10dp"
                    android:layout_marginBottom="28dp"
                    android:maxLines="1"
                    android:text="@string/proceed_donot_show_again"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_16"
                    app:layout_constraintBottom_toTopOf="@+id/buy_now_btn"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/ivRightTick3" />


                <TextView
                    android:id="@+id/cancel_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dimen_20dp"
                    android:layout_marginBottom="28dp"
                    android:background="@drawable/bg_border_orange_less_corner"
                    android:ellipsize="end"
                    android:gravity="center_horizontal"
                    android:maxLines="1"
                    android:paddingVertical="@dimen/dimen_8dp"
                    android:text="@string/proceed"
                    android:textColor="@color/colorPrimary_day_night"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/buy_now_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dimen_20dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_button_choose_kundli"
                    android:backgroundTint="@color/colorPrimary_day_night"
                    android:ellipsize="end"
                    android:gravity="center_horizontal"
                    android:maxLines="1"
                    android:paddingVertical="@dimen/dimen_8dp"
                    android:text="@string/subscribe_for_text"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@+id/cancel_btn"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>