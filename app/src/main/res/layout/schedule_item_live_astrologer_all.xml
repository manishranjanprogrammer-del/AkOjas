<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainlayoutLL"
    android:layout_width="match_parent"
    android:layout_height="110dp"
    android:padding="@dimen/dimen_6dp"
    android:layout_marginEnd="@dimen/dimen_10dp"
    android:layout_marginStart="@dimen/dimen_10dp"
    android:layout_marginTop="@dimen/dimen_8dp"
    app:cardCornerRadius="@dimen/dimen_8dp"
    app:cardBackgroundColor="@color/bg_card_view_color"

    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:orientation="horizontal"
        android:weightSum="1"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="0.75">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                    android:id="@+id/ri_profile_img"
                    android:layout_width="@dimen/profile_image_size"
                    android:layout_height="@dimen/profile_image_size"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_profile_view" />

                <ImageView
                    android:id="@+id/online_offline_img"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:src="@drawable/green"/>

            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0.25"
            android:layout_marginStart="@dimen/dimen_10dp"
            android:layout_gravity="center_vertical"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_share"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_share2"
                android:layout_gravity="right"
                app:tint="@color/black"/>

            <TextView
                android:id="@+id/astroTitleTV"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="-15dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/black"
                android:textSize="@dimen/font_large" />
            <TextView
                android:id="@+id/txt_topic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_5dp"
                android:layout_marginEnd="@dimen/dimen_10dp"
                android:textColor="@color/black"
                android:textSize="@dimen/font_medium"
                android:ellipsize="end"
                android:maxLines="1"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_5dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/txt_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_gravity="start"
                    android:textColor="@color/black"
                    android:textSize="@dimen/font_small"
                    android:textStyle="normal" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="|"
                    android:textColor="@color/black"
                    android:layout_marginStart="@dimen/dimen_10dp"
                    android:textSize="@dimen/font_small"
                    android:textStyle="normal" />
                <TextView
                    android:id="@+id/txt_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/black"
                    android:layout_marginStart="@dimen/dimen_10dp"
                    android:textSize="@dimen/font_small"
                    android:textStyle="normal" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>


</androidx.cardview.widget.CardView>