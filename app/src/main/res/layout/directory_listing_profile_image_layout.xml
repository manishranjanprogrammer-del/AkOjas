<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <include
        android:id="@+id/appbarAppModule"
        layout="@layout/act_app_toolbar"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/button_height"
        android:orientation="vertical"
        android:padding="@dimen/activity_vertical_margin">

        <com.android.volley.toolbox.NetworkImageView
            android:id="@+id/networkProfileIV"
            android:layout_width="match_parent"
            android:layout_height="@dimen/omf_text_width"
            android:layout_gravity="left|center"
            android:scaleType="fitXY"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/profile_img"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_profile_view"
            android:visibility="visible" />

        <ImageView
            android:id="@+id/selected_image"
            android:layout_width="match_parent"
            android:layout_height="@dimen/omf_text_width"
            android:layout_gravity="center_horizontal"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/upload_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/activity_vertical_margin"
            android:gravity="center_horizontal"
            android:padding="4dp"
            android:text="@string/upload_photo"
            android:textColor="@color/black"
            android:textSize="@dimen/heading_text_size" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="@dimen/button_height"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/choose_file_btn"
                style="@style/buttonstyle"
                android:layout_width="wrap_content"
                android:layout_height="42dip"
                android:background="@drawable/bg_orange"
                android:gravity="center"
                android:paddingLeft="@dimen/margin_large"
                android:paddingRight="@dimen/margin_large"
                android:text="@string/choose_file"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/photo_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="@dimen/margin_large"
                android:text="@string/no_file_choosen"
                android:textColor="@color/black"
                android:textSize="@dimen/font_medium" />

        </LinearLayout>

        <Button
            android:id="@+id/submit_btn"
            style="@style/buttonstyle"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/custom_btn_height"
            android:background="@drawable/bg_orange"
            android:gravity="center"
            android:paddingLeft="@dimen/margin_xlarge"
            android:paddingRight="@dimen/margin_xlarge"
            android:text="@string/submit"
            android:layout_gravity="center_horizontal"
            android:textSize="@dimen/title_text_size"/>

    </LinearLayout>

</LinearLayout>