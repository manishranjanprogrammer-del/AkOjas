<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/LinearLayout1"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <include
            android:id="@+id/feedbackToolbar"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            layout="@layout/tool_bar_app_module"
            />

        <!--<TextView
            android:id="@+id/textViewHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:text="@string/feedback_form"
            android:textColor="@color/black"
            android:textSize="25sp"
            android:typeface="serif" />-->

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >

            <LinearLayout
                android:id="@+id/linearLayout1"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_10dp"
                android:layout_marginStart="@dimen/dimen_20dp"
                android:layout_marginEnd="@dimen/dimen_20dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="2dp"
                        android:gravity="left"
                        android:text="@string/name"
                        android:visibility="gone"
                        android:textColor="@color/text_color_black" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:alpha="0.8"
                            android:background="@drawable/ic_person_black"
                            android:layout_weight="0"
                            android:visibility="gone"
                            android:backgroundTint="@color/text_color_black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="@string/varta_name"
                            android:id="@+id/font_auto_lay_feedback_1"
                            android:textSize="@dimen/tv_size_16"
                            android:textColor="@color/text_color_black"/>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_layout_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintTextAppearance="@color/new_hint_color"
                            app:hintTextColor="@color/text_color_black">
                            <EditText
                                android:id="@+id/etName"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/dimen_50dp"
                                style="@style/Theme.App.Base"
                                android:ems="10"
                                android:layout_weight="1"
                                android:inputType="textNoSuggestions"
                                android:maxLength="51"
                                android:hint="@string/astro_shop_User_name"
                                android:contentDescription="@string/name"
                                android:background="@drawable/drawable_bg_yellow"
                                android:backgroundTint="@color/new_box_color"
                                android:paddingLeft="5dp"
                                android:paddingRight="5dp"
                                android:textColor="@color/text_color_black"
                                android:textColorHint="@color/new_hint_color"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <TextView
                            android:id="@+id/txtViewErrorFullName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/red1"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEmailId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="2dp"
                        android:gravity="left"
                        android:text="@string/emailId"
                        android:visibility="gone"
                        android:textColor="@color/black" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:alpha="0.8"
                            android:background="@drawable/ic_email_black"
                            android:layout_weight="0"
                            android:visibility="gone"
                            android:backgroundTint="@color/text_color_black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="@string/emailId"
                            android:id="@+id/font_auto_lay_feedback_2"
                            android:textSize="@dimen/tv_size_16"
                            android:textColor="@color/text_color_black"/>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_layout_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintTextAppearance="@color/new_hint_color"
                            app:hintTextColor="@color/text_color_black">
                            <EditText
                                android:id="@+id/etEmailId"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/dimen_50dp"
                                style="@style/Theme.App.Base"
                                android:ems="10"
                                android:layout_weight="1"
                                android:inputType="textEmailAddress"
                                android:maxLength="71"
                                android:hint="@string/please_enter_your_email_id"
                                android:contentDescription="@string/emailId"
                                android:background="@drawable/drawable_bg_yellow"
                                android:backgroundTint="@color/new_box_color"
                                android:paddingLeft="5dp"
                                android:paddingRight="5dp"
                                android:textColor="@color/text_color_black"
                                android:textColorHint="@color/new_hint_color"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <TextView
                            android:id="@+id/txtViewErrorEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/red1"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="2dp"
                        android:gravity="left"
                        android:text="@string/phone"
                        android:visibility="gone"
                        android:textColor="@color/black" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:alpha="0.8"
                            android:background="@drawable/ic_call_black"
                            android:layout_weight="0"
                            android:visibility="gone"
                            android:backgroundTint="@color/text_color_black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="@string/phone"
                            android:id="@+id/font_auto_lay_feedback_3"
                            android:textColor="@color/text_color_black"
                            android:textSize="@dimen/tv_size_16"/>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_layout_phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintTextAppearance="@color/new_hint_color"
                            app:hintTextColor="@color/text_color_black">
                            <EditText
                                android:id="@+id/etPhone"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/dimen_50dp"
                                style="@style/Theme.App.Base"
                                android:ems="10"
                                android:layout_weight="1"
                                android:inputType="number"
                                android:maxLength="10"
                                android:background="@drawable/drawable_bg_yellow"
                                android:backgroundTint="@color/new_box_color"
                                android:hint="@string/please_enter_your_phone_number"
                                android:contentDescription="@string/phone"
                                android:paddingLeft="5dp"
                                android:paddingRight="5dp"
                                android:textColor="@color/text_color_black"
                                android:textColorHint="@color/new_hint_color"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <TextView
                            android:id="@+id/txtViewErrorPhoneNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/red1"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvMsg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="2dp"
                            android:gravity="left"
                            android:text="@string/feedback_form"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/textViewCharCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="500"
                            android:textColor="@color/black" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="top"
                            android:alpha="0.8"
                            android:background="@drawable/ic_feedback_black_24dp"
                            android:layout_weight="0"
                            android:visibility="gone"
                            android:backgroundTint="@color/text_color_black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="@string/Msg_message"
                            android:id="@+id/font_auto_lay_feedback_4"
                            android:textColor="@color/text_color_black"
                            android:textSize="@dimen/tv_size_16"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_layout_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintTextAppearance="@color/new_hint_color"
                            app:hintTextColor="@color/text_color_black">
                            <EditText
                                android:id="@+id/etMsg"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                style="@style/Theme.App.Base"
                                android:gravity="top|left"
                                android:inputType="textMultiLine"
                                android:maxLength="501"
                                android:minLines="1"
                                android:layout_weight="1"
                                android:paddingLeft="5dp"
                                android:paddingRight="5dp"
                                android:hint="@string/message"
                                android:contentDescription="@string/message"
                                android:background="@drawable/drawable_bg_yellow"
                                android:backgroundTint="@color/new_box_color"                                android:scrollHorizontally="false"
                                android:scrollbars="vertical"
                                android:singleLine="false"
                                android:textColor="@color/text_color_black"
                                android:textColorHint="@color/new_hint_color"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <TextView
                            android:id="@+id/txtViewErrorMessage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/red1"
                            android:visibility="gone"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/butCancel"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginRight="5dp"
                        android:theme="@style/MyDialogeButton"
                        android:text="@string/cancel"
                        android:textSize="18sp"
                        android:visibility="gone"
                        android:textColor="@color/white"/>

                    <!--<Button
                        android:id="@+id/butSend"
                        android:layout_width="fill_parent"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="5dp"
                        android:text="@string/send"
                        android:textSize="18sp"
                        android:elevation="3dp"
                        android:textAllCaps="false"
                        android:theme="@style/MyDialogeButton"
                        android:textColor="@color/white"/>-->
                    <Button
                        android:id="@+id/butSend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/button_top_margin_small"
                        android:text="@string/send"
                        android:textSize="@dimen/tv_size_16"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:foreground="?attr/selectableItemBackground"
                        android:background="@drawable/drawable_bg_yellow"
                        android:backgroundTint="@color/colorPrimary_day_night"/>


                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</LinearLayout>