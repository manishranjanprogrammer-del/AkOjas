<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/iv_close_view"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/dimen_10dp"
        android:layout_marginEnd="@dimen/dimen_10dp"
        android:contentDescription="TODO"
        android:src="@drawable/ic_close_circle_grey600_24dp" />

    <Button
        android:id="@+id/cancel_btn"
        android:layout_width="@dimen/button_size"
        android:layout_height="@dimen/button_size"
        android:layout_marginTop="-10dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/cancel_with_red" />


    <TextView
        android:id="@+id/heading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:text="@string/oops"
        android:textColor="@color/orange_color"
        android:textSize="@dimen/tv_size_24" />

    <TextView
        android:id="@+id/recharge_unsucessful"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|center"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:paddingHorizontal="@dimen/dimen_24dp"
        android:text="@string/subscription_payment_unsuccessful"
        android:textColor="@color/black"
        android:textSize="@dimen/tv_size_20" />

    <TextView
        android:id="@+id/recharge_unsucessful_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="8dp"
        android:layout_marginRight="15dp"
        android:background="@drawable/bg_gray"
        android:gravity="center_horizontal"
        android:padding="16dp"
        android:text="@string/rechage_unsucessful_content"
        android:textColor="@color/text_day_gray_night_white"
        android:textSize="@dimen/tv_size_15" />


    <LinearLayout
        android:id="@+id/try_again_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginStart="@dimen/margin_25dp"
        android:layout_marginEnd="@dimen/margin_25dp"
        android:layout_marginBottom="@dimen/dimen_24dp"
        android:background="@drawable/bg_button_yellow_less_round"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="@dimen/dimen_10dp"
        android:paddingHorizontal="@dimen/dimen_24dp">

        <TextView
            android:id="@+id/text1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="@dimen/dimen_10dp"
            android:text="@string/try_again"
            android:textColor="@color/white"
            android:textSize="@dimen/tv_size_18"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dimen_5dp"
            android:gravity="center"
            android:paddingHorizontal="@dimen/dimen_10dp"
            android:paddingBottom="@dimen/dimen_5dp"
            android:text="@string/with_other_payment_gateway"
            android:textColor="@color/white"
            android:textSize="@dimen/tv_size_14"
            android:visibility="gone"/>


    </LinearLayout>

</LinearLayout>