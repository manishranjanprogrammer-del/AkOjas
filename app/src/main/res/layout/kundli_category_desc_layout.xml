<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/spinner_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="visible">

        <EditText
            android:id="@+id/search_et"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:drawableLeft="@drawable/search_icon"
            android:drawablePadding="8dp"
            android:hint="Search"
            android:minHeight="50dp"
            android:paddingLeft="8dp"
            android:maxLines="1"
            android:paddingTop="7dp"
            android:textColor="@color/black"
            android:paddingRight="8dp"
            android:paddingBottom="7dp"
            android:visibility="invisible"
            android:textColorHint="@color/hint_text_color" />

        <RelativeLayout
            android:layout_width="170dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dimen_5dp">
            <Spinner
                android:id="@+id/module_spinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/margin_xXlarge"
                android:paddingEnd="@dimen/dimen_20dp"
                android:background="@drawable/text_view_border"
                android:textColor="@color/black"
                android:layout_alignParentEnd="true"
                android:spinnerMode="dropdown" />

            <ImageView
                android:layout_width="25dp"
                android:layout_height="15dp"
                android:layout_centerVertical="true"
                android:paddingEnd="5dp"
                app:tint="@color/colorPrimary_day_night"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_spinner_down_image"/>
        </RelativeLayout>

    </LinearLayout>


    <View
        android:layout_width="match_parent"
        android:layout_height=".5dp"
        android:background="@color/print_divider_color"
        android:visibility="gone" />

    <TextView
        android:id="@+id/varshfal_heading_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp"
        android:text="@string/select_year_for_varshfal" />

    <CheckBox
        android:id="@+id/select_all_cb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:theme="@style/MyCheckBox"
        android:textColor="@color/black"
        android:layout_marginTop="8dp"
        android:text="Select All"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/selected_range"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp"
        android:text="1998-2003" />

    <io.apptik.widget.MultiSlider
        android:id="@+id/multiSlider"
        style="@style/sliderHoloStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:thumbNumber="2" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/category_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>