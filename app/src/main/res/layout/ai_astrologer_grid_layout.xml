<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    app:cardCornerRadius="@dimen/dimen_8dp"
    app:cardElevation="@dimen/dimen_0dp"
    app:cardBackgroundColor="@color/cardview_color"
    android:layout_margin="@dimen/dimen_7dp"
    android:id="@+id/upper_layout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/consLayout1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgViewAstrologerLarge"
            android:layout_width="match_parent"
            android:layout_height="310dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/bg_gradiant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />



        <TextView
            android:id="@+id/astrologer_name_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxWidth="200dp"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/no_change_white"
            android:textSize="@dimen/dimen_17sp"
            android:text="Jasmeet"
            android:layout_marginStart="@dimen/dimen_10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/vedic_astrologer_txt"/>

        <com.android.volley.toolbox.NetworkImageView
            android:id="@+id/verified_img"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="10dp"
            android:layout_centerInParent="true"
            app:layout_constraintStart_toEndOf="@+id/astrologer_name_txt"
            app:layout_constraintTop_toTopOf="@+id/astrologer_name_txt"
            app:layout_constraintBottom_toBottomOf="@+id/astrologer_name_txt"
            android:src="@drawable/verified_tick" />
        <TextView
            android:id="@+id/vedic_astrologer_txt"
            style="@style/content_textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_10dp"
            android:ellipsize="end"
            android:maxWidth="180dp"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/no_change_white"
            android:text="Vedic, Numerology Vedic, Numerology"
            android:textSize="@dimen/tv_size_13"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/relLayoutEnglishHindi"/>
        <RelativeLayout
            android:id="@+id/relLayoutEnglishHindi"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/dimen_10dp"
            android:layout_marginEnd="@dimen/dimen_10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/astrologer_price_layout"
            app:layout_constraintEnd_toEndOf="parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen_10dp"
                android:layout_toStartOf="@+id/rlRatingAndReview">

                <TextView
                    android:id="@+id/language_txt"
                    style="@style/content_textview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="3dp"
                    android:ellipsize="end"
                    android:gravity="left"
                    android:maxWidth="180dp"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="@color/no_change_white"
                    android:text="Hindi, English, Hindi, English,Hindi, English"
                    android:textSize="@dimen/tv_size_13" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/rating_tag"
                    android:layout_width="13dp"
                    android:layout_height="15dp"
                    android:layout_marginTop="1dp"
                    android:src="@drawable/followers" />

                <TextView
                    android:id="@+id/followersCountTV"
                    style="@style/content_textview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="2dp"
                    android:layout_toEndOf="@+id/rating_tag"
                    android:ellipsize="end"
                    android:maxWidth="60dp"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="4.5"
                    android:textSize="@dimen/tv_size_12" />

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/rlRatingAndReview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="@dimen/dimen_5dp"
                >

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center|right">

                    <ImageView
                        android:id="@+id/rating_star"
                        android:layout_width="15dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="1dp"
                        android:layout_marginRight="2dp"
                        android:src="@drawable/rating_star"
                        app:tint="@color/no_change_white"
                        android:layout_gravity="center"/>

                    <TextView
                        android:id="@+id/rating_txt"
                        style="@style/content_textview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@+id/rating_star"
                        android:ellipsize="end"
                        android:maxWidth="60dp"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="4.5"
                        android:textColor="@color/no_change_white"
                        android:textSize="@dimen/tv_size_14"
                        android:textStyle="bold"
                        />

                    <TextView
                        android:id="@+id/rating_txt_total"
                        style="@style/content_textview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxWidth="60dp"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="(220)"
                        android:textColor="@color/light_gray"
                        android:textSize="11sp"
                        android:gravity="bottom"/>

                </LinearLayout>

            </RelativeLayout>

        </RelativeLayout>

        <TextView
            android:id="@+id/tetViewExpertise"
            style="@style/content_textview"
            android:layout_width="@dimen/dimen_0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_10dp"
            android:layout_marginEnd="@dimen/dimen_5dp"
            android:ellipsize="end"
            android:maxWidth="180dp"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/no_change_white"
            android:text="Vedic, Numerology Vedic, Numerology"
            android:textSize="@dimen/tv_size_14"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/astrologer_price_layout" />

        <RelativeLayout
            android:id="@+id/astrologer_price_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_10dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/call_chat_btn_layout">

            <TextView
                android:id="@+id/new_user"
                style="@style/content_textview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="2dp"
                android:singleLine="true"
                android:text="FREE"
                android:textColor="@color/no_change_white"
                android:textSize="@dimen/tv_size_15"
                android:visibility="gone" />

            <TextView
                android:id="@+id/ruppee_sign"
                style="@style/content_textview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/new_user"
                android:text="@string/rs_sign"
                android:textSize="@dimen/tv_size_14"
                android:textColor="@color/no_change_white"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/actual_question_price_txt"
                style="@style/content_textview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_toRightOf="@+id/ruppee_sign"
                android:singleLine="true"
                android:text="100/min"
                android:textSize="@dimen/tv_size_14"
                android:textStyle="bold"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/question_price_txt"
                style="@style/content_textview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_toRightOf="@+id/actual_question_price_txt"
                android:text="1234"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/no_change_white"
                android:textSize="@dimen/tv_size_14"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/chat_only_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_yellow"
                android:backgroundTint="@color/colorPrimary_day_night"
                android:textAlignment="center"
                android:minWidth="60dp"
                android:paddingStart="@dimen/dimen_15dp"
                android:paddingEnd="@dimen/dimen_15dp"
                android:paddingVertical="@dimen/dimen_3dp"
                android:singleLine="true"
                android:text="@string/chat_now"
                android:textColor="@color/white"
                android:textSize="@dimen/dimen_15sp"
                android:visibility="visible"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_marginBottom="@dimen/dimen_10dp" />

        </RelativeLayout>



        <LinearLayout
            android:id="@+id/call_chat_btn_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/call_now_btn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginStart="@dimen/dimen_10dp"
                android:layout_marginEnd="@dimen/dimen_5dp"
                android:layout_marginBottom="@dimen/dimen_10dp"
                android:background="@drawable/bg_button_yellow"
                android:backgroundTint="@color/colorPrimary_day_night"
                android:gravity="center"
                android:paddingStart="@dimen/dimen_15dp"
                android:paddingEnd="@dimen/dimen_15dp"
                android:paddingVertical="@dimen/dimen_3dp"
                android:singleLine="true"
                android:text="@string/call"
                android:textColor="@color/white"
                android:textSize="@dimen/dimen_15sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/chat_now_btn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="@dimen/dimen_10dp"
                android:layout_marginBottom="@dimen/dimen_10dp"
                android:background="@drawable/bg_button_yellow"
                android:backgroundTint="@color/colorPrimary_day_night"
                android:gravity="center"
                android:paddingVertical="@dimen/dimen_3dp"
                android:singleLine="true"
                android:text="@string/chat_now"
                android:paddingStart="@dimen/dimen_15dp"
                android:paddingEnd="@dimen/dimen_15dp"
                android:textColor="@color/white"
                android:textSize="@dimen/dimen_15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.cardview.widget.CardView>