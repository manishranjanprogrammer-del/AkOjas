<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="@dimen/dimen_20dp">

    <TextView
        android:id="@+id/tvOccupationTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/please_enter_your_occupation"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size_26sp"

    />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clOccupation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_25dp"
        android:layout_below="@+id/tvOccupationTitle">

        <TextView
            android:id="@+id/tvOccupation"
            android:layout_width="match_parent"
            android:layout_height="@dimen/margin_52dp"
            android:background="@drawable/drawable_otp_box_bg"
            android:backgroundTint="@color/edit_profile_color"
            android:textSize="@dimen/tv_size_20"
            android:textColor="@color/black"
            android:text="@string/not_specified"
            android:paddingStart="@dimen/dimen_15dp"
            android:paddingEnd="@dimen/dimen_15dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:layout_width="@dimen/dimen_15dp"
            android:layout_height="@dimen/dimen_15dp"
            android:src="@drawable/icon_drop_down"
            android:layout_marginEnd="@dimen/dimen_15dp"
            app:tint="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvMaritalTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/what_is_your_marital_status"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size_26sp"
        android:layout_marginTop="@dimen/margin_25dp"
        android:layout_below="@id/clOccupation"

    />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clMaritalStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_25dp"
        android:layout_below="@+id/tvMaritalTitle">

        <TextView
            android:id="@+id/tvMaritalStatus"
            android:layout_width="match_parent"
            android:layout_height="@dimen/margin_52dp"
            android:background="@drawable/drawable_otp_box_bg"
            android:backgroundTint="@color/edit_profile_color"
            android:textSize="@dimen/tv_size_20"
            android:textColor="@color/black"
            android:text="@string/not_specified"
            android:paddingStart="@dimen/dimen_15dp"
            android:paddingEnd="@dimen/dimen_15dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:layout_width="@dimen/dimen_15dp"
            android:layout_height="@dimen/dimen_15dp"
            android:src="@drawable/icon_drop_down"
            app:tint="@color/black"
            android:layout_marginEnd="@dimen/dimen_15dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
