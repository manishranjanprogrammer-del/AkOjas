    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linStartChatAndCall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/clMaritalStatus"
        android:layout_marginTop="@dimen/dimen_45dp">

        <TextView
            android:id="@+id/btnStatChatWithAstrologer"
            android:layout_width="@dimen/dimen_0dp"
            android:layout_height="@dimen/margin_52dp"
            android:layout_marginEnd="@dimen/dimen_5dp"
            android:background="@drawable/drawable_otp_box_bg"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:gravity="center"
            android:text="@string/start_chat"
            android:textColor="@color/white"
            android:textSize="@dimen/dimen_22sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnStatCallWithAstrologer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/btnStatCallWithAstrologer"
            android:layout_width="@dimen/dimen_0dp"
            android:layout_height="@dimen/margin_52dp"
            android:layout_marginStart="@dimen/dimen_5dp"
            android:background="@drawable/drawable_otp_box_bg"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:gravity="center"
            android:text="@string/start_call"
            android:textColor="@color/white"
            android:textSize="@dimen/dimen_22sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnStatChatWithAstrologer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/linLayoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="75dp">

        <ImageView
            android:layout_width="@dimen/margin_25dp"
            android:layout_height="@dimen/margin_25dp"
            android:layout_marginStart="@dimen/dimen_5dp"
            android:layout_marginEnd="@dimen/dimen_5dp"
            android:background="@drawable/circle_gray"
            android:padding="@dimen/dimen_5dp"
            android:backgroundTint="@color/colorPrimary_day_night"/>

        <ImageView
            android:layout_width="@dimen/margin_25dp"
            android:layout_height="@dimen/margin_25dp"
            android:background="@drawable/circle_gray"
            android:padding="@dimen/dimen_5dp"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:layout_marginStart="@dimen/dimen_5dp"
            android:layout_marginEnd="@dimen/dimen_5dp"/>

        <ImageView
            android:layout_width="@dimen/margin_25dp"
            android:layout_height="@dimen/margin_25dp"
            android:background="@drawable/circle_gray"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:padding="@dimen/dimen_5dp"
            android:layout_marginStart="@dimen/dimen_5dp"
            android:layout_marginEnd="@dimen/dimen_5dp"/>
        <ImageView
            android:layout_width="@dimen/margin_25dp"
            android:layout_height="@dimen/margin_25dp"
            android:background="@drawable/circle_gray"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:padding="@dimen/dimen_5dp"
            android:layout_marginStart="@dimen/dimen_5dp"
            android:layout_marginEnd="@dimen/dimen_5dp"/>
        <ImageView
            android:layout_width="@dimen/margin_25dp"
            android:layout_height="@dimen/margin_25dp"
            android:background="@drawable/circle_gray"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:padding="@dimen/dimen_5dp"
            android:layout_marginStart="@dimen/dimen_5dp"
            android:layout_marginEnd="@dimen/dimen_5dp"/>

        <ImageView
            android:layout_width="@dimen/margin_25dp"
            android:layout_height="@dimen/margin_25dp"
            android:background="@drawable/circle_gray"
            android:backgroundTint="@color/colorPrimary_day_night"
            app:tint="@color/white"
            android:src="@drawable/ic_occupation"
            android:padding="@dimen/dimen_5dp"
            android:layout_marginStart="@dimen/dimen_5dp"
            android:layout_marginEnd="@dimen/dimen_5dp"/>
    </LinearLayout>

</RelativeLayout>
