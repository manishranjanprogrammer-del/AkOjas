<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/containerLayout"
    android:layout_gravity="bottom"
    android:paddingHorizontal="@dimen/dimen_12dp"
    android:paddingBottom="@dimen/dimen_12dp"
    android:background="@drawable/bg_top_curved_orange_border"
    tools:context=".varta.ui.activity.MiniPaymentInformationActivity">
    <TextView
        android:id="@+id/tv_total_amount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/total_amount_dialog"
        android:textColor="@color/black"
        android:layout_marginTop="@dimen/dimen_12dp"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tv_gst_rate"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1"/>

    <!-- GST Rate -->
    <TextView
        android:id="@+id/tv_gst_rate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/inc_gst"
        android:textColor="@color/user_date_time_text_color"
        android:textSize="12sp"
        android:layout_marginEnd="@dimen/dimen_10dp"
        android:layout_marginTop="@dimen/dimen_5dp"
        app:layout_constraintStart_toEndOf="@id/tv_total_amount"
        app:layout_constraintEnd_toStartOf="@id/closeIcon"
        app:layout_constraintTop_toTopOf="@id/tv_total_amount"
        app:layout_constraintBottom_toBottomOf="@id/tv_total_amount"
        app:layout_constraintHorizontal_chainStyle="spread_inside"/>

    <!-- Close Icon -->
    <ImageView
        android:id="@+id/closeIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_close_live"
        android:clickable="true"
        android:layout_marginTop="@dimen/dimen_8dp"
        android:background="?attr/selectableItemBackground"
        app:tint="@color/black"
        app:layout_constraintStart_toEndOf="@id/tv_gst_rate"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Cashback Text -->
    <TextView
        android:id="@+id/tv_cashback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/you_will_get_in_your_wallet"
        android:textColor="@color/colorPrimary_day_night"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_total_amount" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@color/separator_line_light"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_cashback" />

    <!-- Pay with UPI -->

    <!-- UPI Apps Row -->
    <TextView
        android:id="@+id/tv_pay_with_upi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_10dp"
        android:text="@string/text_pay_with_upi_apps"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <LinearLayout
        android:id="@+id/upiPaymentOptionsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_pay_with_upi">

        <LinearLayout
            android:id="@+id/phonepe_option"
            android:layout_width="80dp"
            android:layout_height="65dp"
            android:background="@drawable/selected_app_background1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="visible">
            <ImageView
                android:id="@+id/phonepe_icon"
                android:layout_width="75dp"
                android:layout_height="60dp"
                android:background="@drawable/selected_app_background1"
                android:contentDescription="@string/phonepe"
                android:src="@drawable/phonepe_wide_icon" />

            <TextView
                android:id="@+id/phonepe_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/phonepe"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/gpay_option"
            android:layout_width="80dp"
            android:layout_height="65dp"
            android:background="@drawable/selected_app_background1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="visible">

            <ImageView
                android:id="@+id/gpay_icon"
                android:layout_width="75dp"
                android:layout_height="60dp"
                android:contentDescription="@string/gpay"
                android:src="@drawable/gpay_wide_icon" />

            <TextView
                android:id="@+id/gpay_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/gpay"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/paytm_option"
            android:layout_width="80dp"
            android:layout_height="65dp"
            android:background="@drawable/selected_app_background1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="visible">

            <ImageView
                android:id="@+id/paytm_icon"
                android:layout_width="75dp"
                android:layout_height="60dp"
                android:contentDescription="@string/paytm"
                android:src="@drawable/paytm_wide_icon" />

            <TextView
                android:id="@+id/paytm_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/paytm"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
    <!-- Other Payment Methods Row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/other_methods_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        android:layout_marginTop="5dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:paddingVertical="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/upiPaymentOptionsContainer">

        <TextView
            android:id="@+id/tv_other_methods"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/other_payment_methods"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_arrow"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_keyboard_arrow_right_black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/ivTintColorDN" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
