<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/containerLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/chat_bg"
    android:orientation="vertical"
    android:paddingBottom="@dimen/margin_medium">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_chat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@color/ColorPrimary"
        android:visibility="visible"
        app:contentInsetStart="0dp"
        app:popupTheme="@style/AppTheme.PopupOverlay">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginStart="0dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivback_chat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/dimen_10dp"
                android:layout_marginEnd="@dimen/dimen_10dp"
                android:layout_marginBottom="@dimen/dimen_10dp"
                android:src="@drawable/ic_back_arrow" />

            <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                android:id="@+id/astrologer_profile_pic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:layout_gravity="center_vertical"
                android:layout_toEndOf="@+id/ivback_chat"
                android:contentDescription="@null"
                android:src="@drawable/ic_profile_view" />

            <TextView
                android:id="@+id/title_text_chat"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_toEndOf="@+id/astrologer_profile_pic"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:text="@string/name"
                android:textColor="@color/black"
                android:textSize="@dimen/chat_status_size" />

            <LinearLayout
                android:id="@+id/llSharing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="5dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivShareChat"
                    android:layout_width="@dimen/dimen_35dp"
                    android:layout_height="@dimen/dimen_35dp"
                    android:layout_marginStart="@dimen/dimen_5dp"
                    android:src="@mipmap/ic_share"/>

                <ImageView
                    android:id="@+id/ivCopyChat"
                    android:layout_width="@dimen/dimen_35dp"
                    android:layout_height="@dimen/dimen_35dp"
                    android:layout_marginStart="@dimen/dimen_5dp"
                    android:src="@mipmap/ic_copy_paste"
                    android:visibility="gone"/>

            </LinearLayout>

        </RelativeLayout>

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:id="@+id/svMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/relSendMessage"
        android:layout_below="@id/toolbar_chat">

        <LinearLayout
            android:id="@+id/llMessageLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginHorizontal="@dimen/dimen_15dp"
                android:layout_marginVertical="@dimen/dimen_15dp"
                android:background="@drawable/rect_rounded_image"
                android:gravity="center"
                android:paddingHorizontal="@dimen/dimen_10dp"
                android:paddingVertical="5dp"
                android:text="@string/warning_message"
                android:textColor="@color/red1"
                android:textSize="@dimen/tv_size_17"
                android:visibility="visible" />

            <LinearLayout
                android:id="@+id/llBirthDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_xMedium"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_chat_purple"
                    android:orientation="vertical"
                    android:layout_marginStart="50dp"
                    android:paddingLeft="13dp"
                    android:paddingTop="7dp"
                    android:paddingRight="13dp"
                    android:paddingBottom="7dp">

                    <TextView
                        android:id="@+id/tvBirthDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="14dp"
                        android:autoLink="all"
                        android:gravity="start"
                        android:text="@string/birthday_str"
                        android:textAlignment="textStart"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_18"
                        android:textStyle="normal"
                        tools:ignore="RtlCompat" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvUserBirthDetailsDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="2dp"
                            android:text="00-00-0000 00:00"
                            android:textAlignment="textEnd"
                            android:textColor="@color/LightBlack"
                            android:textSize="@dimen/dimen_12sp"
                            tools:ignore="RtlCompat" />

                    </LinearLayout>

                </androidx.appcompat.widget.LinearLayoutCompat>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llGreetings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginTop="@dimen/margin_medium"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivGreetings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="@dimen/dimen_5dp"
                    android:adjustViewBounds="true"
                    android:padding="1dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/astrosage_app_icon" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="50dp"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_chat_white"
                    android:orientation="vertical"
                    android:paddingTop="7dp">

                    <TextView
                        android:id="@+id/tvGreetings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:layout_marginHorizontal="13dp"
                        android:autoLink="all"
                        android:gravity="start"
                        android:text="@string/hi"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_18"
                        android:textStyle="normal"
                        tools:ignore="RtlCompat" />

                    <TextView
                        android:id="@+id/tvGreetingsDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="13dp"
                        android:layout_marginBottom="7dp"
                        android:gravity="end"
                        android:minWidth="120dp"
                        android:padding="2dp"
                        android:text="00-00-0000 00:00"
                        android:textAlignment="textEnd"
                        android:textColor="@color/LightBlack"
                        android:textSize="@dimen/dimen_12sp"
                        tools:ignore="RtlCompat" />

                </androidx.appcompat.widget.LinearLayoutCompat>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llUserQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/margin_medium"
                android:layout_marginEnd="@dimen/margin_xMedium"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_chat_purple"
                    android:orientation="vertical"
                    android:layout_marginStart="50dp"
                    android:paddingLeft="13dp"
                    android:paddingTop="7dp"
                    android:paddingRight="13dp"
                    android:paddingBottom="7dp">

                    <TextView
                        android:id="@+id/tvUserQuestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="14dp"
                        android:autoLink="all"
                        android:gravity="start"
                        android:text="@string/ask_questions"
                        android:textAlignment="textStart"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_18"
                        android:textStyle="normal"
                        tools:ignore="RtlCompat" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvUserQuestionDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="2dp"
                            android:text="00-00-0000 00:00"
                            android:textAlignment="textEnd"
                            android:textColor="@color/LightBlack"
                            android:textSize="@dimen/dimen_12sp"
                            tools:ignore="RtlCompat" />

                    </LinearLayout>

                </androidx.appcompat.widget.LinearLayoutCompat>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llAIResponse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_small"
                android:layout_marginTop="@dimen/margin_medium"
                android:orientation="horizontal"
                android:visibility="visible">

                <ImageView
                    android:id="@+id/ivAIResponse"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="@dimen/dimen_5dp"
                    android:adjustViewBounds="true"
                    android:padding="1dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/astrosage_app_icon" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="50dp"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_chat_white"
                    android:orientation="vertical"
                    android:paddingTop="7dp">

                    <TextView
                        android:id="@+id/tvAIResponse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:layout_marginHorizontal="13dp"
                        android:autoLink="all"
                        android:gravity="start"
                        android:text="@string/astrosage_varta_desc"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_18"
                        android:textStyle="normal"
                        tools:ignore="RtlCompat" />

                    <TextView
                        android:id="@+id/tvAIResponseDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="13dp"
                        android:layout_marginBottom="7dp"
                        android:gravity="end"
                        android:minWidth="120dp"
                        android:padding="2dp"
                        android:text="00-00-0000 00:00"
                        android:textAlignment="textEnd"
                        android:textColor="@color/LightBlack"
                        android:textSize="@dimen/dimen_12sp"
                        tools:ignore="RtlCompat" />

                    <LinearLayout
                        android:id="@+id/llButtonsParent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:id="@+id/tv_view"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="@color/grey_light" />

                        <LinearLayout
                            android:id="@+id/llChatButtons"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/dimen_10dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </androidx.appcompat.widget.LinearLayoutCompat>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llWaitMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:layout_marginEnd="50dp"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivWaitMsg"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginStart="@dimen/margin_xMedium"
                    android:background="@drawable/bg_chat_white"
                    android:padding="7dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/relSendMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="@dimen/margin_medium"
        android:layout_marginTop="@dimen/margin_small"
        android:background="@android:color/transparent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="5dp"
        android:visibility="visible">

        <EditText
            android:id="@+id/editTextMessage"
            android:layout_width="0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:layout_weight="1"
            android:background="@drawable/message_input_shape"
            android:hint="@string/say_something"
            android:imeOptions="actionSend"
            android:maxHeight="100dp"
            android:maxLength="255"
            android:minHeight="40dp"
            android:padding="7dp"
            android:textColor="@android:color/black"
            android:textSize="@dimen/chat_font_size" />

        <RelativeLayout
            android:id="@+id/buttonSend"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:background="@drawable/circle_orange"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_stop"
                android:visibility="gone"
                app:tint="@color/white" />

            <ImageView
                android:id="@+id/ivSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/icon_send"
                android:visibility="visible" />
        </RelativeLayout>

    </LinearLayout>

</RelativeLayout>