<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FBD664"
    android:elevation="@dimen/dimen_10dp"
    android:orientation="vertical"
    android:padding="@dimen/dimen_6dp">


    <LinearLayout
        android:id="@+id/mainlayoutLL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2">

            <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                android:id="@+id/chatAstroProfileImage"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_profile_view" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/dimen_10dp"
            android:layout_weight="7"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/txt_chat_call_heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:ellipsize="end"
                    android:textStyle="bold"
                    android:maxWidth="250dp"
                    android:maxLines="1"
                    android:text="@string/chat_is_being_connected"
                    android:textColor="@color/no_change_black"
                    android:textSize="@dimen/font_medium" />
                <com.ojassoft.astrosage.utils.HorizontalDottedProgress
                    android:id="@+id/horizontal_dotted_progress_astro"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:layout_marginTop="@dimen/dimen_3dp"
                    android:layout_marginStart="5dp"
                    android:layout_gravity="center_vertical"
                    android:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@+id/chatAstroName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:ellipsize="end"
                android:layout_marginTop="@dimen/dimen_4dp"
                android:maxLines="1"
                android:textColor="@color/no_change_black"
                android:textSize="@dimen/font_medium" />


            <RelativeLayout
                android:id="@+id/rlBottomLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_4dp">

                <TextView
                    android:id="@+id/chatOfferType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_marginEnd="@dimen/dimen_5dp"
                    android:text="@string/new_user"
                    android:textColor="@color/no_change_black"
                    android:textSize="@dimen/tv_size_14" />

                <TextView
                    android:id="@+id/chatRuppeeSign"
                    style="@style/content_textview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginTop="@dimen/dimen_1dp"
                    android:layout_marginEnd="@dimen/dimen_1dp"
                    android:layout_toEndOf="@+id/chatOfferType"
                    android:singleLine="true"
                    android:text="@string/rs_sign"
                    android:textColor="@color/no_change_black"
                    android:textSize="@dimen/tv_size_14" />

                <TextView
                    android:id="@+id/chgatPriceTv1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="2dp"
                    android:layout_toEndOf="@+id/chatRuppeeSign"
                    android:ellipsize="end"
                    android:textColor="@color/no_change_black"
                    android:maxLines="1"
                    android:text="00"
                    android:textSize="@dimen/tv_size_14" />

                <TextView
                    android:id="@+id/chgatPriceTv2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/dimen_3dp"
                    android:textColor="@color/no_change_black"
                    android:layout_toEndOf="@+id/chgatPriceTv1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="62/min"
                    android:textSize="@dimen/tv_size_14" />

                <TextView
                    android:id="@+id/initiateType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/dimen_3dp"
                    android:layout_toEndOf="@+id/chgatPriceTv2"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:visibility="visible"
                    android:text="()"
                    android:textColor="@color/red"
                    android:textSize="@dimen/tv_size_14" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/waitTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/no_change_black"
                    android:textSize="@dimen/font_small"
                    android:textStyle="normal" />

                <ImageView
                    android:id="@+id/online_offline_img"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical"
                    android:padding="2dp"
                    android:src="@drawable/about_us_black"
                    android:visibility="gone"
                    app:layout_constraintStart_toEndOf="@+id/ri_profile_img"
                    app:layout_constraintTop_toTopOf="@+id/ri_profile_img" />

            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/cross_chat_initiate_view"
                android:layout_width="35dp"
                android:layout_height="30dp"
                android:layout_gravity="end|top"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_close_black"
                android:tint="@color/no_change_black"
                android:visibility="visible"/>
        </FrameLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvInternationalCallNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_10dp"
        android:layout_marginTop="3dip"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="@string/international_call_note_internet"
        android:textColor="@color/no_change_black"
        android:textSize="@dimen/font_small"
        android:visibility="gone"/>
</LinearLayout>