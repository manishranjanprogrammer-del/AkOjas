<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">


    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:visibility="visible">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp">

            <TextView
                android:id="@+id/Astrofeatureheading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:text="@string/astrologiacl_feature"
                android:textColor="#191919"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/Astrofeaturesubheading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/Astrofeatureheading"
                android:layout_marginTop="5dp"
                android:maxLines="2"
                android:paddingRight="60sp"
                android:text="@string/complete_experiance_basic"
                android:textColor="#818181"
                android:textSize="13sp" />


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/plan_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/Astrofeaturesubheading" />

        </RelativeLayout>
    </ScrollView>



    <TextView
        android:id="@+id/buy_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary_day_night"
        android:gravity="center"
        android:padding="@dimen/tv_size_16"
        android:text="@string/select_basic"
        android:textColor="@color/white" />
</LinearLayout>