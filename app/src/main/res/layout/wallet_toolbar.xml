<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.Toolbar xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="62dp"
    android:background="@color/appbarBGColor"
    app:contentInsetStart="0dp">

    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="left"
        android:paddingLeft="16dp"
        android:paddingRight="12dp"
        android:foreground="?android:attr/selectableItemBackground"
        android:src="@drawable/ic_back_arrow" />

    <TextView
        android:id="@+id/tvTitle"
        style="@style/toolbar_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="40dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textSize="@dimen/title_text_size"
        android:text="@string/astrologer_detail" />

    <TextView
        android:id="@+id/txtSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/linStartChatAndCall"
        android:layout_centerHorizontal="true"
        android:textAllCaps="false"
        android:text="@string/skip"
        android:textColor="@color/black"
        android:layout_gravity="end"
        android:textSize="@dimen/dimen_18sp"
        android:layout_marginEnd="@dimen/dimen_20dp"
        android:alpha=".6"
        android:visibility="gone"/>
    <ImageView
        android:id="@+id/ivRechargeHistory"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:src="@drawable/recharge_history"
        android:visibility="gone"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/ivTintColorDN"
        android:layout_marginEnd="@dimen/dimen_10dp"
        android:layout_gravity="end"/>

</androidx.appcompat.widget.Toolbar>