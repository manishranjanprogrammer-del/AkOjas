<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:orientation="vertical">

    <include
        android:id="@+id/appbarAppModule"
        layout="@layout/tool_bar_app_module"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/llBuy"
        android:layout_below="@+id/appbarAppModule"
        android:clipToPadding="false"
        android:focusable="true"
        android:focusableInTouchMode="true">


        <!--<LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:orientation="vertical">-->

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="25dp"
                android:paddingBottom="@dimen/dimen_10dp"
                android:orientation="vertical">

                <com.android.volley.toolbox.NetworkImageView
                    android:id="@+id/image_view"
                    android:layout_width="@dimen/astroshop_large_image_width_height"
                    android:layout_height="@dimen/astroshop_large_image_width_height"
                    android:layout_gravity="center"
                    android:scaleType="fitXY" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    android:orientation="vertical"
                    android:paddingLeft="17dp"
                    android:paddingTop="17dp"
                    android:paddingRight="17dp"
                    android:paddingBottom="5dp">

                    <TextView
                        android:id="@+id/text_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:textSize="@dimen/tv_size_18" />

                    <TextView
                        android:id="@+id/text_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:textSize="16sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/text_sub_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:textSize="@dimen/tv_size_16" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/dimen_10dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <com.android.volley.toolbox.NetworkImageView
                                android:id="@+id/nivHtmlContentImage"
                                android:layout_width="@dimen/tablerowtextviewheight"
                                android:layout_height="@dimen/tablerowtextviewheight"
                                android:layout_gravity="center"
                                android:scaleType="fitXY"
                                android:src="@drawable/ic_astroshop"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvHtmlContent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:paddingTop="10dp"
                                android:textColor="@color/black_87"
                                android:textColorLink="@color/colorPrimary_day_night"
                                android:textSize="14sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <com.android.volley.toolbox.NetworkImageView
                                android:id="@+id/nivHtmlContentImage1"
                                android:layout_width="@dimen/tablerowtextviewheight"
                                android:layout_height="@dimen/tablerowtextviewheight"
                                android:layout_gravity="center"
                                android:scaleType="fitXY"
                                android:src="@drawable/ic_astroshop"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvHtmlContent1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:paddingTop="10dp"
                                android:textColor="@color/black_87"
                                android:textColorLink="@color/colorPrimary_day_night"
                                android:textSize="14sp"
                                android:visibility="visible" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    android:orientation="vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text__title_label_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="left"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:text="@string/astroshop_price"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/text__title_description_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha=".8"
                            android:gravity="right"
                            android:padding="5dp"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text__title_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="left"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:text="@string/sale_price"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/text__title_description"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="right"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:textColor="@color/colorPrimary_day_night"
                            android:textSize="16sp" />
                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text__title_label_you_save"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="left"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:text="@string/you_save"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/text__title_description_price_you_save"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="right"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:textColor="@color/colorPrimary_day_night"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/service_plan_discount_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:orientation="horizontal"
                        android:visibility="visible">

                        <TextView
                            android:id="@+id/text_silver_gold_plan_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="left"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:text=""
                            android:textSize="@dimen/tv_size_16" />

                        <TextView
                            android:id="@+id/text_plan_discount_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="right"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:textColor="@color/astroshop_green"
                            android:textSize="@dimen/tv_size_16" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/basic_plan_user_layout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/golden_border"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="2dp"
                        android:visibility="gone"
                        android:weightSum="1">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:weightSum="1">

                            <TextView
                                android:id="@+id/msg_for_basic_plan_text"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0.7"
                                android:drawableLeft="@mipmap/gold_icon"
                                android:gravity="left|center_vertical"
                                android:maxLines="2"
                                android:paddingLeft="4dp"
                                android:text="@string/basic_user_text_dhruv"
                                android:textColor="@color/black"
                                android:textSize="@dimen/tv_size_12"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/msg_for_basic_plan_price"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0.3"
                                android:maxLines="4"
                                android:paddingRight="2dp"
                                android:text=""
                                android:textAlignment="viewEnd"
                                android:textColor="@color/gold_plan"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/unlock_plan_text"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:drawableStart="@mipmap/lock_icon"
                            android:drawableEnd="@mipmap/left_arrow_icon"
                            android:gravity="end"
                            android:paddingStart="2dp"
                            android:paddingEnd="4dp"
                            android:drawableTint="@color/black"
                            android:textColor="@color/black" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvpromo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:paddingLeft="16dp"
                        android:text="@string/have_a_coupon_code"
                        android:textColor="@color/colorPrimary_day_night"
                        android:textSize="16sp"
                        android:visibility="visible" />
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/llPromo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/llentercoupanview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginLeft="16dp"
                        android:layout_marginRight="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/edt_promo_layout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:hint=" ">
                            <!--
                                                        android:hint="@string/coupon_code"
                        -->


                            <EditText
                                android:id="@+id/etPromo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_margin="5dp"
                                android:backgroundTint="@color/colorPrimary_day_night"
                                android:focusable="true"
                                android:focusableInTouchMode="true"
                                android:hint="@string/enter_code"
                                android:inputType="text"
                                android:maxLength="16"
                                android:textSize="16sp"
                                android:theme="@style/Theme.App.Base" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <Button
                            android:id="@+id/btnRedeem"
                            style="@style/MyDialogeButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:gravity="center"
                            android:text="@string/cop_redeem"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:theme="@style/MyDialogeButton" />
                    </LinearLayout>


                </LinearLayout>


                <LinearLayout
                    android:id="@+id/llcoupanview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="16dp"
                    android:visibility="gone">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvlabelFinalprice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="left"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:text="@string/promo_price"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvFinalprice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="right"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:textColor="@color/red1"
                            android:textSize="16sp" />
                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvlableCoupanDiscount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="left"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:text="@string/you_save"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvCoupanDiscount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="right"
                            android:padding="5dp"
                            android:paddingLeft="15dp"
                            android:textColor="@color/red1"
                            android:textSize="16sp" />
                    </LinearLayout>

                </LinearLayout>
                <LinearLayout
                    android:id="@+id/ll_delivery_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dimen_16dp"
                    android:orientation="horizontal"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="@dimen/dimen_35dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_delivery_bus"/>
                    <TextView
                        android:id="@+id/tv_delivery_time"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Delivery 3-7 working days"
                        android:textSize="@dimen/tv_size_18"
                        android:maxLines="1"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_choose_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dimen_16dp"
                    android:layout_marginTop="@dimen/dimen_5dp"
                    android:visibility="visible"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_white_rounded"
                        android:backgroundTint="@color/dividerColor"
                        android:layout_marginTop="@dimen/dimen_5dp"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/dimen_12dp"
                            android:layout_marginTop="@dimen/dimen_5dp">

                            <TextView
                                android:id="@+id/tv_order_for"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:text="@string/order_for"
                                android:textSize="@dimen/tv_size_17" />

                            <ImageView
                                android:id="@+id/iv_change_profile"
                                android:layout_width="@dimen/dimen_18dp"
                                android:layout_height="@dimen/dimen_18dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_change_profile"/>
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="@dimen/dimen_8dp">

                            <ImageView
                                android:id="@+id/iv_profile_img"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/male_user" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/dimen_10dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_user_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Kapil Sharma"
                                    android:textSize="@dimen/tv_size_20" />

                                <TextView
                                    android:id="@+id/tv_user_dob_address"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:maxLines="1"
                                    android:text="9-Dec-1991, 05:1 0:00, Agra, Uttar Pradesh"
                                    android:textSize="@dimen/tv_size_14" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tv_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_10dp"
                        android:text="@string/enter_email_id"
                        android:textSize="@dimen/tv_size_16"/>
                    <EditText
                        android:id="@+id/edit_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/email"
                        android:background="@drawable/text_view_border"
                        android:textColor="@color/black"
                        android:inputType="textEmailAddress"
                        android:backgroundTint="@color/black"
                        android:paddingVertical="@dimen/dimen_10dp"
                        android:paddingHorizontal="@dimen/dimen_15dp"
                        android:layout_marginTop="@dimen/dimen_5dp"/>
                    <TextView
                        android:id="@+id/tv_email_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/tv_size_13"
                        android:textColor="@color/red1"
                        android:visibility="gone"
                        android:layout_marginEnd="@dimen/dimen_5dp"/>
                    <TextView
                        android:id="@+id/tv_report_lang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_10dp"
                        android:text="@string/report_lang"
                        android:textSize="@dimen/tv_size_16"/>

                    <RelativeLayout
                        android:id="@+id/rl_marital_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_5dp">

                        <Spinner
                            android:id="@+id/spinner_lang_option"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/text_view_border"
                            android:backgroundTint="@color/black"
                            android:layout_centerVertical="true"
                            android:maxLines="1"
                            android:minHeight="@dimen/margin_xXlarge"
                            android:paddingVertical="@dimen/dimen_8dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="20dp"
                            android:spinnerMode="dialog"
                            android:textColor="@color/black"
                            android:theme="@style/ActionBarThemeOverlay" />

                        <ImageView
                            android:layout_width="35dp"
                            android:layout_height="15dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:paddingEnd="20dp"
                            android:src="@drawable/ic_spinner_down_image"
                            app:tint="@color/black" />

                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tv_language_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/tv_size_13"
                        android:textColor="@color/red1"
                        android:visibility="gone"
                        android:layout_marginEnd="@dimen/dimen_5dp"/>


                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/txt_disscount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:layout_gravity="left"
                android:layout_marginLeft="70dp"
                android:layout_marginTop="10dp"
                android:minWidth="62dp"
                android:minHeight="62dp"
                android:background="@drawable/discount_circle"
                android:gravity="center"
                android:padding="5dp"
                android:text="20%"
                android:textColor="@color/no_change_white"
                android:textStyle="bold" />

        </RelativeLayout>
        <!-- </LinearLayout>-->

    </ScrollView>

    <LinearLayout
        android:id="@+id/llBuy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:orientation="vertical">

       <View
           android:layout_width="match_parent"
           android:layout_height="@dimen/dimen_1dp"
           android:background="@drawable/shadow"/>

        <TextView
            android:id="@+id/tvOffer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@+id/buy_now"
            android:paddingLeft="12dp"
            android:paddingTop="12dp"
            android:paddingRight="12dp"
            android:textColor="#1ca202"
            android:textSize="@dimen/tv_size_14"
            android:visibility="gone" />
        <CheckBox
            android:id="@+id/checkbox_use_wallet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wallet_amount"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_17"
            android:visibility="gone"
            android:layout_marginTop="@dimen/dimen_5dp"
            android:layout_marginHorizontal="@dimen/dimen_14dp"
            android:theme="@style/MyCheckBox" />

        <Button
            android:id="@+id/buy_now"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="@dimen/dimen_5dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="5dp"
            android:gravity="center"
            android:text="@string/astroshop_buy_now"
            android:textColor="@color/white"
            android:textSize="@dimen/tv_size_18"
            android:backgroundTint="@color/colorPrimary_day_night"/>

        <TextView
            android:id="@+id/tv_collectors_edi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/collector_s_edition_price"
            android:textSize="@dimen/tv_size_15"
            android:visibility="gone"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/dimen_10dp"/>
    </LinearLayout>

</RelativeLayout>