<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainlayoutLL"
    android:layout_width="match_parent"
    android:layout_height="90dip"
    android:orientation="vertical"
    android:layout_marginLeft="5dp"
    android:layout_marginRight="5dp"
    android:minHeight="90dip">

    <LinearLayout
        android:orientation="horizontal"
        android:weightSum="1"
        android:layout_marginTop="@dimen/dimen_5dp"
        android:layout_marginBottom="@dimen/dimen_5dp"
        android:layout_height="79dip"
        android:layout_width="match_parent">

        <LinearLayout
            android:layout_weight="0.75"
            android:orientation="horizontal"
            android:layout_height="match_parent"
            android:layout_width="match_parent">

            <FrameLayout
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                    android:id="@+id/ri_profile_img"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_centerInParent="true"
                    android:layout_marginLeft="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_profile_view" />

            </FrameLayout>


        </LinearLayout>
        <LinearLayout
            android:layout_marginLeft="@dimen/dimen_5dp"
            android:layout_weight="0.25"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_height="match_parent"
            android:layout_width="match_parent">

            <TextView
                android:layout_gravity="center|left"
                android:gravity="center|left"
                android:id="@+id/astroTitleTV"
                android:text="Astrologer Punit Pandey"
                android:singleLine="true"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_18"/>

            <TextView
                android:id="@+id/astroTitleFollow"
                android:layout_gravity="left|center"
                android:gravity="left|center"
                android:text="@string/following"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="@dimen/dimen_5dp"
                android:paddingRight="@dimen/dimen_5dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textColor="@color/white"
                android:textSize="@dimen/font_small"
                android:background="@drawable/bg_border_orange_live"/>

        </LinearLayout>


    </LinearLayout>
    <View
        android:layout_height="1dp"
        android:layout_marginLeft="@dimen/dimen_10dp"
        android:layout_marginRight="@dimen/dimen_5dp"
        android:layout_width="match_parent"
        android:background="@color/print_unselected_text_color"/>

</LinearLayout>