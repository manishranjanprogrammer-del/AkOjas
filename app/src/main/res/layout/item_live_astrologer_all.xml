<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainlayoutLL"
    android:layout_width="match_parent"
    android:layout_height="120dip"
    android:minHeight="100dip"
    android:layout_marginLeft="6dp"
    android:layout_marginTop="6dp"
    android:layout_marginRight="6dp"
    android:weightSum="1"
    android:background="@drawable/banner_background">

        <LinearLayout
            android:layout_weight="0.25"
            android:layout_height="match_parent"
            android:layout_width="0dp">

            <FrameLayout
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                    android:id="@+id/ri_profile_img"
                    android:layout_width="@dimen/profile_image_size"
                    android:layout_height="@dimen/profile_image_size"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_profile_view" />

                <ImageView
                    android:id="@+id/online_offline_img"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|right"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="5dp"
                    android:src="@drawable/green"/>

            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_marginLeft="@dimen/dimen_5dp"
            android:layout_weight="0.75"
            android:orientation="vertical"
            android:weightSum="1"
            android:layout_height="match_parent"
            android:layout_width="0dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_weight="0.70"
                android:layout_height="0dp"
                android:layout_width="match_parent">

                <TextView
                    android:layout_marginTop="@dimen/dimen_14dp"
                    android:layout_gravity="left"
                    android:gravity="bottom"
                    android:text="Astro Guru Mragaank Sharma"
                    android:maxLines="1"
                    android:id="@+id/astroTitleTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/font_large"/>

                <TextView
                    android:layout_marginTop="@dimen/dimen_4sp"
                    android:layout_gravity="left"
                    android:gravity="left|top"
                    android:id="@+id/expertiseNameTV"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:text="Vedic, Numerology, Kp vastu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/font_small"/>

            </LinearLayout>

            <LinearLayout
                android:layout_marginBottom="@dimen/dimen_5dp"
                android:layout_weight="0.30"
                android:weightSum="1"
                android:orientation="horizontal"
                android:layout_height="0dp"
                android:layout_width="match_parent">

                <LinearLayout
                    android:layout_weight="0.60"
                    android:layout_gravity="top"
                    android:gravity="top"
                    android:layout_height="match_parent"
                    android:layout_width="0dp">


                    <TextView
                        android:layout_gravity="top|center"
                        android:gravity="center"
                        android:text="@string/text_live"
                        android:textStyle="bold"
                        android:paddingLeft="6dp"
                        android:paddingRight="6dp"
                        android:textAllCaps="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_red"
                        android:textSize="@dimen/font_medium"
                        android:layout_marginTop="@dimen/dimen_5dp"
                        android:background="@drawable/bg_button_white_color"/>

                </LinearLayout>

                <LinearLayout
                    android:visibility="gone"
                    android:weightSum="2"
                    android:layout_weight="0.40"
                    android:orientation="horizontal"
                    android:layout_height="wrap_content"
                    android:layout_width="0dp">

                    <LinearLayout
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:layout_height="match_parent"
                        android:layout_width="0dp">

                        <ImageView
                            android:backgroundTint="@color/white"
                            android:background="@drawable/ic_star_unselect"
                            android:layout_width="20dp"
                            android:layout_height="20dp"/>

                        <TextView
                            android:layout_marginLeft="5dp"
                            android:text="4.8"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:textColor="@color/white"
                            android:textSize="@dimen/font_small"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:layout_height="match_parent"
                        android:layout_width="0dp">

                        <ImageView
                            android:backgroundTint="@color/white"
                            android:background="@drawable/user_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"/>

                        <TextView
                            android:layout_marginLeft="5dp"
                            android:text="1,078"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:textColor="@color/white"
                            android:textSize="@dimen/font_small"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

</LinearLayout>