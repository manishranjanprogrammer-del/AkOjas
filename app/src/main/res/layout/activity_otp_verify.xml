<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/container_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/language_screen_bg"
        >

        <ImageView
            android:id="@+id/imgViewTopBg"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="fitXY"
            android:src="@drawable/top_tech_bg"
            android:layout_alignParentTop="true"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/imgViewTopBg"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="76dip"
                android:layout_marginBottom="30dip"
                android:gravity="center"
                android:visibility="gone"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@mipmap/icon"/>
                <TextView
                    android:id="@+id/astrosage_txt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/astrosage_name"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_32"
                    android:layout_marginLeft="8dip"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginLeft="@dimen/dimen_15dp"
                android:layout_marginRight="@dimen/dimen_15dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/otp_heading_txt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/otp_verification"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_32"

                />
                <LinearLayout
                    android:id="@+id/otp_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_15dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/otp_msg_txt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAlignment="center"
                            android:layout_marginTop="5dp"
                            android:layout_marginBottom="5dp"
                            android:text="@string/otp_verify_msg"
                            android:textColor="@color/black"
                            android:textSize="@dimen/tv_size_16"/>


                    </LinearLayout>



                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:orientation="horizontal"
                        android:gravity="center">


                        <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
                            android:id="@+id/otp_edt1"
                            style="@style/OtpEdittext"
                            android:layout_marginRight="3dp"
                            android:focusable="true"
                            android:imeOptions="actionNext" />

                        <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
                            android:id="@+id/otp_edt2"
                            style="@style/OtpEdittext"
                            android:layout_marginHorizontal="@dimen/dimen_3dp"
                            android:imeOptions="actionNext" />


                        <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
                            android:id="@+id/otp_edt3"
                            style="@style/OtpEdittext"
                            android:layout_marginHorizontal="@dimen/dimen_3dp"
                            android:imeOptions="actionNext" />

                        <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
                            android:id="@+id/otp_edt4"
                            style="@style/OtpEdittext"
                            android:layout_marginLeft="3dp"
                            android:layout_marginRight="6dp"
                            android:imeOptions="actionNext" />

                        <!--<EditText
                            android:id="@+id/otp_edt5"
                            android:layout_marginRight="6dp"
                            android:layout_marginLeft="6dp"
                            style="@style/OtpEdittext"
                            android:imeOptions="actionNext">

                        </EditText>

                        <EditText
                            android:id="@+id/otp_edt6"
                            android:layout_marginLeft="6dp"
                            style="@style/OtpEdittext"
                            android:imeOptions="actionDone">

                        </EditText>-->


                    </LinearLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/verify_btn"
                    style="@style/buttonBackground"
                    android:layout_width="wrap_content"
                    android:layout_height="55dp"
                    android:layout_marginTop="25dp"
                    android:text="@string/verify"
                    android:layout_gravity="center_horizontal"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:paddingStart="@dimen/dimen_50dp"
                    android:paddingEnd="@dimen/dimen_50dp"
                    android:textSize="@dimen/dimen_22sp"
                    android:background="@drawable/drawable_bg_yellow"
                    android:backgroundTint="@color/colorPrimary_day_night"/>



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal"
                    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/didt_get_otp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_17"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/llResendOTPLayout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">

                        <TextView
                            android:id="@+id/txtViewResendOtp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/resend_sms_in"
                            android:textColor="@color/new_theme_darker_gray"
                            android:textSize="@dimen/tv_size_17" />

                        <TextView
                            android:id="@+id/textViewTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="right"
                            android:layout_marginTop="@dimen/margin_small"
                            android:layout_marginRight="@dimen/activity_vertical_margin"
                            android:text="00"
                            android:visibility="gone"
                            android:textColor="@color/new_theme_darker_gray"
                            android:textSize="@dimen/dimen_15sp" />

                    </LinearLayout>

                </LinearLayout>



                <TextView
                    android:id="@+id/resend_otp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:padding="@dimen/margin_small"
                    android:text="@string/resend_otp"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_17" />

                <TextView
                    android:id="@+id/get_otp_via_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:textAlignment="center"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:padding="@dimen/margin_small"
                    android:text="@string/get_otp_via_phone"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_17" />

            </LinearLayout>

        </LinearLayout>
        <ImageView
            android:id="@+id/imgViewBottomBg"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="fitXY"
            android:src="@drawable/bottum_tech_bg"
            android:layout_alignParentBottom="true"/>

    </RelativeLayout>
</ScrollView>