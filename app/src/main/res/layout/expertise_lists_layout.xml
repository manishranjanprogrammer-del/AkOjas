<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tvExpertiseHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/kp_astrologers"
        android:layout_marginTop="@dimen/dimen_10dp"
        android:textSize="@dimen/tv_size_18"
        android:textColor="@color/black"
        android:maxWidth="200dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="visible"
        android:layout_marginStart="@dimen/dimen_5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toTopOf="@id/rvExpertise"/>

    <TextView
        android:id="@+id/tvExpertiseSeeMore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_10dp"
        android:text="@string/see_more"
        android:textSize="@dimen/tv_size_15"
        android:maxWidth="100dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="visible"
        android:layout_marginEnd="@dimen/dimen_5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvExpertise"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_10dp"
        tools:listitem="@layout/layout_astrologer_grid_view"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvExpertiseHeading"/>

</androidx.constraintlayout.widget.ConstraintLayout>