<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/transparent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="30dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:paddingBottom="25dp"
            android:paddingHorizontal="@dimen/dimen_20dp"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_rounded_white"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvTitleFRPAFC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_marginTop="85dp"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_28"
                android:textStyle="bold"
                android:text="@string/cashback_100_percent"/>

            <TextView
                android:id="@+id/tvSubheadingFRPAFC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:gravity="center"
                android:visibility="gone"
                android:textSize="@dimen/tv_size_22"
                android:layout_marginTop="@dimen/dimen_20dp"
                android:text="@string/get_devine_guidance"/>

            <TextView
                android:id="@+id/tvMessageFRPAFC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:text="@string/get_100_percent_cashback_text"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="@dimen/tv_size_20"
                android:layout_marginTop="@dimen/dimen_20dp" />

            <TextView
                android:id="@+id/tvBtnFRPAFC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recharge_and_get_offer"
                android:textSize="@dimen/tv_size_18"
                android:textColor="@color/white"
                android:paddingVertical="@dimen/dimen_5dp"
                android:paddingHorizontal="@dimen/dimen_15dp"
                android:layout_marginTop="25dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:foreground="?android:attr/selectableItemBackground"
                android:background="@drawable/orange_rect_with_round_corner"/>

        </LinearLayout>
    <FrameLayout
        android:id="@+id/ivCloseFRPAFC"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="@dimen/dimen_10dp"
        android:layout_marginBottom="@dimen/dimen_10dp"
        android:layout_marginTop="@dimen/dimen_60dp"
        android:background="?android:attr/selectableItemBackground"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            app:tint="@color/black"
            android:layout_gravity="center"
            android:src="@drawable/ic_close_live" />
    </FrameLayout>


        <ImageView
            android:id="@+id/ivFRPAFC"
            android:layout_width="125dp"
            android:layout_height="125dp"
            android:adjustViewBounds="true"
            android:scaleType="fitXY"
            android:background="@drawable/solid_white_circle"
            android:src="@drawable/ganesh"
            android:padding="@dimen/dimen_8dp"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</RelativeLayout>
