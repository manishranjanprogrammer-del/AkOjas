<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFBB3D"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:layout_width="@dimen/language_notification_icon_size"
                android:layout_height="@dimen/language_notification_icon_size"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/icon_top_margin"
                android:contentDescription="@null"
                android:src="@drawable/wizard_notification_icon"
                />

            <TextView
                android:id="@+id/textViewHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minWidth="@dimen/min_height"
                android:minHeight="@dimen/min_height"
                android:gravity="center_horizontal"
                android:text="@string/LibNotificationConffigHeading"
                android:textColor="@android:color/white"
                android:textSize="25sp"
                android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/radioOnce"
                        layout="@layout/select_language_item_lay" />

                    <include
                        android:id="@+id/radioTwice"
                        layout="@layout/select_language_item_lay" />

                    <include
                        android:id="@+id/radioAsManyTimes"
                        layout="@layout/select_language_item_lay" />

                    <include
                        android:id="@+id/radioNever"
                        layout="@layout/select_language_item_lay" />

                    <Button
                        android:id="@+id/buttonNext"
                        android:layout_marginTop="@dimen/button_margin_top"
                        android:text="@string/button_next"
                        android:backgroundTint="@color/ColorPrimaryDark"

                        android:layout_marginLeft="30dp"
                        android:layout_marginRight="30dp"
                        style="@style/buttonstyle"
                        android:theme="@style/buttonstyle"/>
                </LinearLayout>
        </LinearLayout>

    </ScrollView>

