<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/semi_transparent_black">

    <TextView
        android:id="@+id/skip_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_32dp"
        android:layout_marginTop="200dp"
        android:background="@drawable/bg_button"
        android:paddingHorizontal="10dp"
        android:paddingVertical="2dp"
        android:text="@string/skip"
        android:textColor="@color/white"
        android:textSize="@dimen/dimen_16sp"
        android:textStyle="bold"
        android:clickable="true"

        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <LinearLayout
        android:id="@+id/next_done_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="200dp"
        android:layout_marginEnd="@dimen/dimen_32dp"
        android:background="@drawable/bg_button"
        android:gravity="center"
        android:orientation="horizontal"
        android:clickable="true"
        android:focusable="true"
        android:paddingHorizontal="10dp"
        android:paddingVertical="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/next_done_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/next"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textSize="@dimen/dimen_16sp" />

        <ImageView
            android:id="@+id/next_image"
            android:layout_width="@dimen/dimen_12dp"
            android:layout_height="@dimen/dimen_12dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="5dp"
            android:visibility="visible"
            android:src="@drawable/next_purple_arrow"
            app:tint="@color/white" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/kundli_page_intro_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

    <ImageView
        android:id="@+id/nav_menu_icon"
        android:layout_width="@dimen/dimen_45dp"
        android:layout_height="@dimen/dimen_45dp"
        android:layout_marginStart="@dimen/dimen_10dp"
        android:layout_marginTop="@dimen/dimen_10dp"
        android:background="@drawable/no_change_white_circle_bg"
        android:padding="@dimen/dimen_10dp"
        android:src="@drawable/hamburger_menu_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/no_change_black" />

    <ImageView
        android:id="@+id/icon_facing_nav_icon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginTop="@dimen/dimen_8dp"
        android:src="@drawable/up_arrow_white"
        app:layout_constraintEnd_toEndOf="@+id/nav_menu_icon"
        app:layout_constraintStart_toStartOf="@+id/nav_menu_icon"
        app:layout_constraintTop_toBottomOf="@+id/nav_menu_icon" />

    <TextView
        android:id="@+id/nav_menu_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_10dp"
        android:text="@string/navigation_menu"
        android:textColor="@color/no_change_white"
        android:textSize="@dimen/tv_size_18"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/icon_facing_nav_icon" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sub_menu"
        android:textColor="@color/no_change_white"
        android:textSize="@dimen/tv_size_18"
        android:layout_marginEnd="@dimen/dimen_10dp"
        app:layout_constraintBottom_toBottomOf="@+id/arrow_to_expand_icon"
        app:layout_constraintEnd_toStartOf="@+id/arrow_to_expand_icon"
        app:layout_constraintTop_toTopOf="@+id/arrow_to_expand_icon" />

    <ImageView
        android:id="@+id/arrow_to_expand_icon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/right_arrow_white_144"
        android:layout_marginEnd="@dimen/dimen_10dp"
        app:layout_constraintBottom_toBottomOf="@+id/expand_icon_layout"
        app:layout_constraintEnd_toStartOf="@+id/expand_icon_layout"
        app:layout_constraintTop_toTopOf="@+id/expand_icon_layout" />

    <LinearLayout
        android:id="@+id/expand_icon_layout"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="@dimen/dimen_4dp"
        android:background="@drawable/no_change_white_circle_bg"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/more_help_iv"
        app:layout_constraintEnd_toStartOf="@+id/more_help_iv"
        app:layout_constraintTop_toTopOf="@+id/more_help_iv">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@drawable/button_purple"
            android:padding="4dp"
            android:src="@drawable/icon_drop_down"
            app:tint="@color/white" />
    </LinearLayout>


    <ImageView
        android:id="@+id/more_help_iv"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="@dimen/dimen_10dp"
        android:layout_marginEnd="@dimen/dimen_5dp"
        android:background="@drawable/no_change_white_circle_bg"
        android:padding="@dimen/dimen_10dp"
        android:src="@drawable/ic_more_vert_black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/no_change_black" />

    <ImageView
        android:id="@+id/arrow_facing_more_setting"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginTop="@dimen/dimen_8dp"
        android:layout_marginEnd="@dimen/dimen_10dp"
        android:src="@drawable/curved_up_arrow_right_144"
        app:layout_constraintEnd_toEndOf="@+id/more_help_iv"
        app:layout_constraintStart_toStartOf="@+id/more_help_iv"
        app:layout_constraintTop_toBottomOf="@+id/more_help_iv" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dimen_10dp"
        android:text="@string/change_settings"
        android:textColor="@color/no_change_white"
        android:textSize="@dimen/tv_size_18"
        app:layout_constraintBottom_toBottomOf="@+id/arrow_facing_more_setting"
        app:layout_constraintEnd_toStartOf="@+id/arrow_facing_more_setting" />





    <TextView
        android:id="@+id/swipe_tv"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:textSize="@dimen/dimen_18sp"
        android:textColor="@color/no_change_white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textAlignment="center"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/rashi_number_intro_tv"
        android:text="@string/swipe_help"/>
    <ImageView
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/left_arrow_white_144"
        app:layout_constraintTop_toTopOf="@+id/swipe_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/swipe_tv"
        app:layout_constraintBottom_toBottomOf="@+id/swipe_tv"/>
    <ImageView
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/right_arrow_white_144"
        app:layout_constraintTop_toTopOf="@+id/swipe_tv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@+id/swipe_tv"
        app:layout_constraintStart_toEndOf="@+id/swipe_tv"/>


    <TextView
        android:id="@+id/rashi_number_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="11"
        android:textSize="@dimen/dimen_18sp"
        android:textAlignment="center"
        android:padding="@dimen/dimen_12dp"
        android:textStyle="bold"
        android:textColor="@color/no_change_black"
        android:background="@drawable/no_change_white_circle_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/nav_menu_tv"
        android:layout_marginTop="80dp"
        app:layout_constraintEnd_toEndOf="parent"/>
    <ImageView
        android:id="@+id/arrow_facing_rashi_number"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/up_arrow_white"
        android:layout_marginTop="@dimen/dimen_8dp"
        app:layout_constraintTop_toBottomOf="@+id/rashi_number_tv"
        app:layout_constraintEnd_toEndOf="@id/rashi_number_tv"
        app:layout_constraintStart_toStartOf="@+id/rashi_number_tv"/>
    <TextView
        android:id="@+id/rashi_number_intro_tv"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="@string/rorate_help"
        android:textColor="@color/no_change_white"
        android:textSize="18sp"
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@+id/arrow_facing_rashi_number"
        app:layout_constraintEnd_toEndOf="@+id/arrow_facing_rashi_number"
        app:layout_constraintTop_toBottomOf="@+id/arrow_facing_rashi_number"/>
    <ImageView
        android:id="@+id/arrow_for_bookmark"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:src="@drawable/up_arrow_white"
        android:layout_marginTop="@dimen/dimen_45dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/swipe_tv"/>
    <TextView
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="@string/double_touch_help"
        android:textColor="@color/no_change_white"
        android:textSize="@dimen/dimen_18sp"
        android:layout_marginTop="@dimen/dimen_8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/arrow_for_bookmark"
        android:textAlignment="center"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <RelativeLayout
        android:id="@+id/north_kundli_house_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/kundli_house"
            android:layout_width="158dp"
            android:layout_height="150dp"
            android:layout_centerHorizontal="true"/>
        <ImageView
            android:id="@+id/arrow_up"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_below="@id/kundli_house"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="38dp"
            android:src="@drawable/up_arrow_white"/>

            <TextView
                android:id="@+id/kundliHouseHelpText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:maxWidth="280dp"
                android:gravity="center"
                android:layout_marginTop="@dimen/dimen_8dp"
                android:layout_below="@id/arrow_up"
                android:maxLines="2"
                android:layout_centerHorizontal="true"
                android:text="@string/click_and_ask_about_any_house"
                android:textColor="@color/no_change_white" />


    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/east_kundli_house_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/east_kundli_house"
            android:layout_width="145dp"
            android:layout_height="145dp"
            android:layout_alignParentEnd="true"/>
        <ImageView
            android:id="@+id/east_arrow_right"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginHorizontal="@dimen/dimen_5dp"
            android:layout_centerVertical="true"
            android:layout_toLeftOf="@id/east_kundli_house"
            android:src="@drawable/right_arrow_white_144"/>

        <TextView
            android:id="@+id/east_kundliHouseHelpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:maxWidth="250dp"
            android:gravity="center"
            android:layout_toLeftOf="@id/east_arrow_right"
            android:maxLines="2"
            android:layout_centerVertical="true"
            android:text="@string/click_and_ask_about_any_house"
            android:textColor="@color/no_change_white" />


    </RelativeLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ask_question_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone"
        android:layout_marginTop="48dp"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@color/bg_transparent">

        <ImageView
            android:id="@+id/arrow_facing_chat_box"
            android:layout_width="38dp"
            android:layout_height="30dp"
            android:layout_above="@+id/tv_ask_que"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="@dimen/dimen_10dp"
            android:src="@drawable/down_arrow_white"
            app:layout_constraintBottom_toTopOf="@+id/tv_ask_que"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ask_and_learn_with_ai"
            app:layout_constraintBottom_toTopOf="@+id/arrow_facing_chat_box"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:textAlignment="center"
            android:textSize="18sp"
            android:layout_marginBottom="@dimen/dimen_10dp"
            android:textColor="@color/no_change_white"/>



        <TextView
            android:id="@+id/tv_ask_que"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_20dp"
            android:layout_marginEnd="@dimen/dimen_10dp"
            android:background="@drawable/circle_border_chat_input_box"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/buttonSend"
            app:layout_constraintStart_toStartOf="parent"
            android:textColorHint="@color/transparent"
            android:text="@string/ask_anything_to_kundli"
            android:textColor="@color/hint_text_color" />


        <RelativeLayout
            android:id="@+id/buttonSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            app:layout_constraintStart_toEndOf="@+id/tv_ask_que"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/tv_ask_que"
            app:layout_constraintTop_toTopOf="@+id/tv_ask_que"
            android:layout_marginEnd="10dp"
            android:background="@drawable/circle_yellow"
            android:gravity="center">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/icon_send"
                app:tint="@color/white" />
        </RelativeLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>