<?xml version="1.0" encoding="utf-8"?>


<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:background="@color/bg_card_view_color"
    android:layout_height="match_parent"
    android:orientation="vertical">




    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"


        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtyoupay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="left"
            android:layout_weight="1"
            android:layout_gravity="left"
            android:padding="2dp"
            android:text="@string/you_pay"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right"
            android:padding="2dp"
            android:layout_weight="1"
            android:gravity="right|end"
            android:text="50"
            android:textColor="@color/colorPrimary_day_night"
            android:textSize="16sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/txtMsg"
        android:minWidth="@dimen/min_height"
        android:minHeight="@dimen/min_height"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:alpha="0.5"
        android:layout_gravity="center"
        android:padding="2dp"
        android:text="@string/no_saved_msg"
        android:textSize="16sp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/my_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:visibility="visible"
        />

    <TextView
        android:id="@+id/tvOptoins"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/min_height"
        android:minHeight="@dimen/min_height"
        android:layout_gravity="right"
        android:padding="5dp"
        android:gravity="right|end"
        android:text="@string/other_payment_options"
        android:textColor="@color/colorPrimary_day_night"
        android:textSize="16sp" />

</LinearLayout>

