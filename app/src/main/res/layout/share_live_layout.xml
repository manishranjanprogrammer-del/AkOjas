<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sllConstraintLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/share_live_background"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:weightSum="10"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen_0dp"
            android:layout_weight="5"
            android:src="@drawable/sp_logo"/>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:padding="@dimen/dimen_20dp"
                android:background="@drawable/droplet_image_border"
                android:layout_centerInParent="true"/>

            <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                android:id="@+id/sllImage"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:padding="5dp"
                android:background="@drawable/circle_white"
                android:layout_centerInParent="true"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:background="@drawable/bg_button_white_color"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/dimen_3dp"
                android:paddingHorizontal="@dimen/dimen_10dp"
                android:visibility="visible"
                android:layout_below="@id/sllImage">

                <ImageView
                    android:layout_width="@dimen/dimen_12dp"
                    android:layout_height="@dimen/dimen_12dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="@dimen/dimen_5dp"
                    android:gravity="center"
                    android:text="@string/text_live"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:textColor="@color/color_red"
                    android:textSize="@dimen/dimen_16sp" />

            </LinearLayout>

        </RelativeLayout>

        <View
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen_0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/sllName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mrunal"
            android:textColor="@color/no_change_white"
            android:textSize="30sp"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen_0dp"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/watch_live_on"
            android:textColor="@color/no_change_white"
            android:textSize="@dimen/tv_size_25"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen_0dp"
            android:layout_weight="0.3"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_white_rounded"
            android:padding="@dimen/dimen_15dp">

            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/icon_varta_white"
                android:tint="@color/Orangecolor"/>

            <TextView
                android:typeface="sans"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:gravity="center"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_15dp"
                android:text="AstroSage Varta App"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_20"/>

        </LinearLayout>

        <View
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen_0dp"
            android:layout_weight="1.5"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/download_now"
            android:textColor="@color/white"
            android:textSize="@dimen/tv_size_25"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/playstore_icon"
            android:layout_marginHorizontal="@dimen/dimen_50dp"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dimen_0dp"
            android:layout_weight=".2"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/varta_astrosage_com"
            android:textColor="@color/no_change_white"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>