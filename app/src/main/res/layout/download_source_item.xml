<LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >

    <androidx.cardview.widget.CardView
        android:id="@+id/card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="5dp"
        app:cardBackgroundColor="@color/bg_card_exit_color"
        android:layout_marginBottom="@dimen/cardview_keyline_1_minus_8dp"
        android:layout_marginLeft="@dimen/cardview_keyline_1_minus_8dp"
        android:layout_marginRight="@dimen/cardview_keyline_1_minus_8dp"
        android:layout_marginTop="@dimen/cardview_keyline_1_minus_8dp">

        <LinearLayout
            android:id="@+id/ll_fb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:layout_margin="@dimen/dimen_5dp">
            <ImageView
                android:id="@+id/image_icon"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:padding="@dimen/dimen_4dp"
                android:src="@drawable/facebook"/>

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:textSize="@dimen/app_exit_font_size"
                android:layout_marginStart="@dimen/dimen_5dp"
                android:text="" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>