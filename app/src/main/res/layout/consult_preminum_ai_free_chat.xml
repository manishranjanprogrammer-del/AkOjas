<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/transparent"
    android:paddingVertical="70dp"
    android:paddingHorizontal="10dp"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="@color/bg_card_view_color"
        app:cardCornerRadius="@dimen/dimen_20dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/cancel_tv"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/dimen_12dp"
                android:padding="6dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:clickable="true"
                android:elevation="@dimen/dimen_10dp"
                app:backgroundTint="@color/white"
                android:background="@drawable/circle_orange"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:src="@drawable/ic_close_black"
                app:tint="@color/black"
                android:focusable="true" />

            <View
                android:id="@+id/innerView"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:elevation="@dimen/dimen_10dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_astrologer_image"
                android:background="@drawable/white_trans_gradient" />

            <ImageView
                android:id="@+id/iv_astrologer_image"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toTopOf="@+id/clBottomView"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                tools:layout_editor_absoluteX="0dp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clBottomView"
                android:layout_width="match_parent"
                android:background="@color/backgroundColorWhiteBlack"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:id="@+id/bottom_top_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="@dimen/dimen_10dp"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <TextView
                        android:id="@+id/consult_premium_astrologers_tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginHorizontal="@dimen/dimen_10dp"
                        android:text="@string/consult_premium_ai_astrologers"
                        android:textColor="@color/black"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/first_call_in_1rs_tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dimen_10dp"
                        android:layout_marginVertical="@dimen/dimen_5dp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="@string/get_your_free_chat"
                        android:textColor="@color/black"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnAiChatNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/bg_button_yellow_less_round"
                        android:backgroundTint="@color/colorPrimary_day_night"
                        android:paddingLeft="40dp"
                        android:layout_marginHorizontal="@dimen/dimen_10dp"
                        android:paddingRight="40dp"
                        android:layout_marginBottom="@dimen/dimen_10dp"
                        android:text="@string/chat_free_now"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>



