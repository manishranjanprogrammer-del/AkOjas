<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingEnd="10dp"
    android:paddingStart="10dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
    android:background="@color/white">

    <TextView
        android:id="@+id/ctnHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chat Request Accepted"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="5dp"/>

    <TextView
        android:id="@+id/ctnTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Astrologer has accepted your chat Request"
        android:textColor="@color/black"
        android:textSize="11sp"
        android:layout_marginBottom="5dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:weightSum="2"
        android:layout_marginBottom="5dp">

        <TextView
            android:id="@+id/ctnCancel"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:textSize="@dimen/tv_size_14"
            android:text="@string/reject_chat"
            android:gravity="center"
            android:textColor="@color/red"
            android:paddingEnd="5dp"
            android:paddingStart="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_marginEnd="2.5dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/ctnContinue"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:textSize="@dimen/tv_size_14"
            android:layout_weight="1"
            android:ellipsize="end"
            android:text="@string/accept_chat"
            android:gravity="center"
            android:textColor="@color/green"
            android:textStyle="bold"
            android:paddingEnd="5dp"
            android:paddingStart="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_marginStart="2.5dp"/>

    </LinearLayout>

</LinearLayout>