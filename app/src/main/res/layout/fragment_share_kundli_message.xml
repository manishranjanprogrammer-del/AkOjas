<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/container_layout"
    android:overScrollMode="never"
    android:scrollbars="none"
    android:background="@color/backgroundColorView"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_5dp"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="@dimen/dimen_50dp"
                android:layout_height="@dimen/dimen_50dp"
                android:layout_marginStart="@dimen/dimen_16dp"
                android:scaleType="fitStart"
                android:src="@drawable/astrosage_app_icon" />

            <ImageView
                android:id="@+id/imageViewKundli"
                android:layout_width="120dp"
                android:layout_height="35dp"
                android:scaleType="fitXY"
                android:textColor="@color/Orangecolor"
                android:src="@drawable/splash_icon_astrosage_ai_logo" />
        </LinearLayout>

            <LinearLayout
                android:id="@+id/rel_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@color/backgroundColorView"
                android:layout_marginTop="@dimen/dimen_10dp">
                <LinearLayout
                    android:id="@+id/ll_transit_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/chandra_btn"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:textAlignment="center"
                        android:background="@color/lightt_gray"
                        android:textColor="@color/no_change_black"
                        android:text="@string/chandra_chart" />

                    <TextView
                        android:id="@+id/lagna_btn"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@color/colorPrimary_day_night"
                        android:text="@string/lagna_Chart"
                        android:textAlignment="center"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>

        <LinearLayout
            android:id="@+id/question_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/backgroundColorView"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimen_16dp"
                android:layout_marginTop="@dimen/dimen_10dp"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_22" />

            <TextView
                android:id="@+id/tv_birth_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimen_16dp"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:textColor="@color/black"
                android:paddingBottom="10dp"
                android:textSize="@dimen/dimen_18sp"
                android:visibility="gone"
                />
            <TextView
                android:id="@+id/tv_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimen_16dp"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:textColor="@color/black"
                android:paddingBottom="10dp"
                android:textSize="@dimen/dimen_18sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>