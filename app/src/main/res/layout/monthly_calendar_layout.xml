<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:elevation="7dp">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            android:id="@+id/appbarAppModule"
            layout="@layout/tool_bar_app_module"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true" />

        <com.ojassoft.astrosage.ui.customcontrols.CustomViewPager
            android:id="@+id/pager"
            android:layout_width="match_parent"
            android:layout_height="0dip"
            android:layout_above="@+id/advLayout"
            android:layout_weight="1"/>

        <LinearLayout
            android:id="@+id/advLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical" />
    </LinearLayout>

    <fragment
        android:id="@+id/myDrawerFrag"
        android:name="com.ojassoft.astrosage.ui.fragments.HomeNavigationDrawerFragment"
        android:layout_width="309dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:layout="@layout/lay_home_navigation_drawer_fragment" />

</androidx.drawerlayout.widget.DrawerLayout>