<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_layout"
    tools:context=".ui.act.FlashOtpVerifyActivity"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:layout_gravity="bottom"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/backgroundColorView"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@mipmap/icon" />

            <TextView
                android:id="@+id/astrosage_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dip"
                android:text="@string/astrosage_name"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_32"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginLeft="@dimen/dimen_15dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="@dimen/dimen_15dp"
            android:layout_marginBottom="@dimen/dimen_15dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/dismissDialog"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/dimen_12dp"
                android:background="@drawable/circle_orange"
                android:clickable="true"
                android:layout_gravity="end"
                android:elevation="@dimen/dimen_4dp"
                android:focusable="true"
                android:padding="6dp"
                android:src="@drawable/ic_close_black"
                app:backgroundTint="@color/white"
                app:tint="@color/black" />

            <TextView
                android:id="@+id/otp_heading_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/otp_verification"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_32"
                android:textStyle="bold"></TextView>

            <LinearLayout
                android:id="@+id/otp_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/otp_msg_txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="5dp"
                        android:text="@string/otp_verify_msg"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_16" />


                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">


                    <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
                        android:id="@+id/otp_edt1"
                        style="@style/OtpEdittext"
                        android:layout_marginRight="6dp"
                        android:focusable="true"
                        android:imeOptions="actionNext" />

                    <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
                        android:id="@+id/otp_edt2"
                        style="@style/OtpEdittext"
                        android:layout_marginLeft="6dp"
                        android:layout_marginRight="6dp"
                        android:imeOptions="actionNext" />


                    <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
                        android:id="@+id/otp_edt3"
                        style="@style/OtpEdittext"
                        android:layout_marginLeft="6dp"
                        android:layout_marginRight="6dp"
                        android:imeOptions="actionNext" />

                    <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
                        android:id="@+id/otp_edt4"
                        style="@style/OtpEdittext"
                        android:layout_marginLeft="6dp"
                        android:layout_marginRight="6dp"
                        android:imeOptions="actionNext" />

                    <!--<EditText
                        android:id="@+id/otp_edt5"
                        android:layout_marginRight="6dp"
                        android:layout_marginLeft="6dp"
                        style="@style/OtpEdittext"
                        android:imeOptions="actionNext">

                    </EditText>

                    <EditText
                        android:id="@+id/otp_edt6"
                        android:layout_marginLeft="6dp"
                        style="@style/OtpEdittext"
                        android:imeOptions="actionDone">

                    </EditText>-->


                </LinearLayout>

            </LinearLayout>

            <Button
                android:id="@+id/verify_btn"
                style="@style/buttonBackground"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:background="@drawable/drawable_bg_yellow"
                android:backgroundTint="@color/colorPrimary_day_night"
                android:paddingStart="@dimen/dimen_50dp"
                android:paddingEnd="@dimen/dimen_50dp"
                android:text="@string/verify"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/dimen_22sp" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/didt_get_otp"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_17" />

                <LinearLayout
                    android:id="@+id/llResendOTPLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtViewResendOtp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dimen_5dp"
                        android:text="@string/resend_sms_in"
                        android:textColor="@color/new_theme_darker_gray"
                        android:textSize="@dimen/dimen_15sp" />

                    <TextView
                        android:id="@+id/textViewTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginTop="@dimen/margin_small"
                        android:layout_marginRight="@dimen/activity_vertical_margin"
                        android:text="00"
                        android:textColor="@color/new_theme_darker_gray"
                        android:textSize="@dimen/dimen_15sp"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>


            <TextView
                android:id="@+id/resend_otp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:padding="@dimen/margin_small"
                android:text="@string/resend_otp"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_17" />

            <TextView
                android:id="@+id/get_otp_via_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:padding="@dimen/margin_small"
                android:text="@string/get_otp_via_phone"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_17" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>