<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:elevation="7dp">

    <RelativeLayout
        android:id="@+id/parent_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:descendantFocusability="beforeDescendants"
        android:focusableInTouchMode="true"
        android:orientation="vertical">

        <include
            android:id="@+id/appbarAppModule"
            layout="@layout/tool_bar_app_module"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/NScrollViewTabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/appbarAppModule"
            android:background="@color/toolbarBGColor"
            android:elevation="3dp">


            <com.google.android.material.tabs.TabLayout
                android:id="@+id/kundliTabLayout"
                style="@style/CustomTabText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:tabGravity="fill"
                app:tabIndicatorColor="@color/black"
                app:tabIndicatorHeight="2dp"
                app:tabMaxWidth="0dp"
                app:tabMode="scrollable"
                app:tabPaddingEnd="0dp"
                app:tabPaddingStart="0dp"
                app:tabRippleColor="@color/appRippleEffectColor"
                app:tabTextColor="@color/black"

                />
        </androidx.core.widget.NestedScrollView>

        <include
            layout="@layout/kundli_menu_layout"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/appbarAppModule" />

        <RelativeLayout
            android:id="@+id/ask_question_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/NScrollViewTabLayout"
            android:background="@color/white">

            <View
                android:id="@+id/ask_layoutBorder"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_alignParentTop="true"
                android:visibility="gone"
                android:background="@drawable/shadow_gray_outline" />

            <com.ojassoft.astrosage.varta.utils.TypeWriter
                android:id="@+id/tv_ask_que"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/dimen_20dp"
                android:layout_marginTop="@dimen/dimen_14dp"
                android:layout_marginEnd="@dimen/dimen_10dp"
                android:layout_marginBottom="@dimen/dimen_14dp"
                android:layout_toStartOf="@+id/buttonSend"
                android:background="@drawable/circle_border_chat_input_box"
                android:hint="@string/ask_anything_to_kundli"
                android:padding="16dp"
                android:text="@string/ask_anything_to_kundli"
                android:textColor="@color/hint_text_color"
                android:textColorHint="@color/transparent" />


            <RelativeLayout
                android:id="@+id/buttonSend"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:background="@drawable/circle_yellow"
                android:gravity="center">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:src="@drawable/icon_send"
                    app:tint="@color/white" />
            </RelativeLayout>

        </RelativeLayout>

        <com.ojassoft.astrosage.ui.customcontrols.CustomViewPager
            android:id="@+id/pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/bottomNavBorder"
            android:layout_below="@+id/ask_question_layout"
            android:layout_marginTop="2dp" />

        <com.android.volley.toolbox.NetworkImageView
            android:id="@+id/topAdImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@+id/ask_question_layout"
            android:adjustViewBounds="true"
            android:visibility="gone" />


        <View
            android:id="@+id/bottomNavBorder"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_above="@+id/homeBottomNav"
            android:background="@color/dividerColor" />

        <include
            android:id="@+id/homeBottomNav"
            layout="@layout/custom_bottom_nav_with_gif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true" />

    </RelativeLayout>

    <fragment
        android:id="@+id/myDrawerFrag"
        android:name="com.ojassoft.astrosage.ui.fragments.HomeNavigationDrawerFragment"
        android:layout_width="309dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:layout="@layout/lay_home_navigation_drawer_fragment" />

</androidx.drawerlayout.widget.DrawerLayout>