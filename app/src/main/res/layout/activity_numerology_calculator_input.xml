<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/backgroundColor"
    android:orientation="vertical">

    <include
        android:id="@+id/appbarAppModule"
        layout="@layout/tool_bar_app_module"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <!--<ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">-->

    <!-- <LinearLayout
         android:layout_width="match_parent"
         android:layout_height="match_parent"
         android:layout_marginLeft="@dimen/margin_mlarge"
         android:layout_marginTop="@dimen/margin_mlarge"
         android:layout_marginRight="@dimen/margin_mlarge"
         android:orientation="vertical"
         android:paddingBottom="16dp">-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginRight="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textViewUserName"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical"
            android:alpha=".9"
            android:clickable="true"
            app:drawableStartCompat="@drawable/ic_person_black"
            app:drawableTint="@color/text_color_black" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_layout_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="@color/text_day_gray_night_white"
            android:layout_marginStart="24dp">

            <EditText
                android:id="@+id/etUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/currentThemeColor"
                android:hint="@string/numrology_name_hint"
                android:inputType="textCapWords|textNoSuggestions"
                android:importantForAutofill="no"
                android:textColor="@color/text_color_black"
                android:textSize="@dimen/tv_size_16"
                android:cursorVisible="true"/>
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginRight="8dp"
        android:gravity="center">

        <TextView
            android:id="@+id/textViewDob"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:alpha=".9"
            android:clickable="true"
            app:drawableStartCompat="@drawable/ic_today_black"
            app:drawableTint="@color/text_color_black" />

        <Button
            android:id="@+id/buttonCalendar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/custom_btn_height"
            android:layout_marginStart="24dp"
            android:background="@drawable/rect_rounded_background"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/margin_mlarge"
            android:text="Birth Date"
            android:textSize="@dimen/input_screen_text_size"
            android:textColor="@color/text_color_black"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="@dimen/margin_medium"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="@dimen/margin_medium"
        android:gravity="center">

        <TextView
            android:id="@+id/textViewType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:alpha=".9"
            android:clickable="true"
            app:drawableStartCompat="@drawable/ic_type"
            app:drawableTint="@color/text_color_black" />

        <Spinner
            android:id="@+id/ics_spinner_type"
            android:layout_width="match_parent"
            android:layout_height="@dimen/custom_btn_height"
            android:layout_marginStart="24dp"
            android:background="@drawable/rect_rounded_background"
            android:paddingStart="@dimen/margin_mlarge"
            android:spinnerMode="dropdown"
            android:theme="@style/ActionBarThemeOverlay" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonSubmit"
        android:layout_width="match_parent"
        android:layout_height="@dimen/custom_btn_height"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:foreground="?attr/selectableItemBackground"
        android:backgroundTint="@color/colorPrimary_day_night"
        android:text="@string/btn_submit"
        android:theme="@style/buttonstyle"
        android:textColor="@color/white" />
    <!-- </LinearLayout>-->
    <!--</ScrollView>-->
</LinearLayout>