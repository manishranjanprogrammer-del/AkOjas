<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/rlLiveRoom"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include layout="@layout/share_live_layout" />

        <com.ojassoft.astrosage.vartalive.widgets.VideoGridContainer
            android:id="@+id/live_video_grid_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/dimen_20dp"
                    android:src="@drawable/bg_live_default_new_center">

                </ImageView>

            </RelativeLayout>

        </com.ojassoft.astrosage.vartalive.widgets.VideoGridContainer>

        <RelativeLayout
            android:id="@+id/live_room_top_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:background="@drawable/bg_border_gradient"
            android:paddingBottom="@dimen/dimen_18dp"
            android:paddingTop="@dimen/status_bar_height">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_astro_profile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/leave_change_btn"
                android:layout_alignParentStart="true">

                <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
                    android:id="@+id/live_name_board_icon"
                    android:layout_width="@dimen/live_name_board_icon_size"
                    android:layout_height="@dimen/live_name_board_icon_size"
                    android:layout_marginStart="@dimen/dimen_18dp"
                    android:layout_marginTop="@dimen/dimen_18dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txt_live"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-14dp"
                    android:background="@drawable/bg_border_red_live"
                    android:paddingStart="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:paddingEnd="@dimen/dimen_8dp"
                    android:text="@string/text_live"
                    android:textColor="@color/no_change_white"
                    android:textSize="@dimen/font_very_small"
                    app:layout_constraintEnd_toEndOf="@+id/live_name_board_icon"
                    app:layout_constraintStart_toStartOf="@+id/live_name_board_icon"
                    app:layout_constraintTop_toBottomOf="@+id/live_name_board_icon" />

                <TextView
                    android:id="@+id/live_astrologer_name"
                    android:layout_width="280dp"
                    android:layout_height="@dimen/live_name_text_height"
                    android:layout_gravity="left|center"
                    android:layout_marginStart="@dimen/dimen_7dp"
                    android:gravity="start"
                    android:layout_marginEnd="@dimen/dimen_10dp"
                    android:layout_marginTop="@dimen/dimen_18dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:paddingRight="5dp"
                    android:scrollHorizontally="true"
                    android:textAlignment="gravity"
                    android:textColor="@color/no_change_white"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@+id/live_name_board_icon"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right|center"
                    android:layout_marginStart="@dimen/dimen_7dp"
                    android:layout_marginTop="@dimen/dimen_8dp"
                    android:layout_weight="0.25"
                    android:gravity="start"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toEndOf="@+id/live_name_board_icon"
                    app:layout_constraintTop_toBottomOf="@+id/live_astrologer_name">
                    <ImageView
                        android:layout_width="@dimen/dimen_20dp"
                        android:layout_height="@dimen/dimen_18dp"
                        android:src="@drawable/icon_whatching"
                        android:layout_gravity="center_vertical"
                        app:tint="@color/no_change_white" />
                    <TextView
                        android:id="@+id/tv_live_viewers_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:paddingHorizontal="@dimen/dimen_5dp"
                        android:textColor="@color/no_change_white"
                        android:textSize="@dimen/tv_size_16"/>


                    <ImageView
                        android:layout_width="@dimen/dimen_15dp"
                        android:layout_height="@dimen/dimen_15dp"
                        android:src="@drawable/user_icon"
                        android:layout_gravity="center_vertical"
                        android:tint="@color/no_change_white"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/followCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingLeft="5dp"
                        android:layout_gravity="center_vertical"
                        android:paddingRight="5dp"
                        android:textColor="@color/no_change_white"
                        android:textSize="@dimen/font_medium" />

                    <TextView
                        android:id="@+id/followTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_border_orange_live"
                        android:paddingStart="5dp"
                        android:layout_gravity="center_vertical"
                        android:paddingEnd="10dp"
                        android:text="@string/follow"
                        android:textColor="@color/white"
                        android:textSize="@dimen/font_medium" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
            <ImageView
                android:id="@+id/leave_change_btn"
                android:layout_width="@dimen/live_leave_btn_size"
                android:layout_height="@dimen/live_leave_btn_size"
                android:layout_gravity="bottom"
                android:layout_marginTop="@dimen/dimen_18dp"
                android:layout_marginEnd="@dimen/dimen_10dp"
                android:gravity="center"
                android:src="@drawable/ic_close_live"
                android:layout_alignParentRight="true" />
        </RelativeLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_mute_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/call_info"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="60dp"
            android:layout_marginTop="@dimen/dimen_50dp"
            android:layout_marginEnd="60dp"
            android:background="@drawable/bg_live_steaming_chat_trans"
            android:padding="@dimen/dimen_15dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/mute_image_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="7dp"
                android:src="@drawable/ic_live_mute"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/colorPrimary_day_night" />

            <TextView
                android:id="@+id/text_mute_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/no_change_white"
                android:textSize="@dimen/tv_size_14"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/mute_image_icon" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/text_private_call_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/cl_mute_info"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="@dimen/dimen_8dp"
            android:background="@drawable/bg_live_steaming_chat_trans"
            android:orientation="vertical"
            android:padding="@dimen/dimen_15dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:padding="7dp"
                android:src="@drawable/external_call_36"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/orange_color" />

            <TextView
                android:id="@+id/external_call"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_5dp"
                android:text="@string/astro_is_on_phone_call"
                android:textAlignment="center"
                android:textColor="@color/no_change_white"
                android:textSize="@dimen/tv_size_16" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@+id/relSendMessage">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewLiveStream"
                android:layout_width="match_parent"
                android:layout_height="256dp"
                android:layout_gravity="bottom"
                android:layout_marginTop="@dimen/margin_small"
                android:layout_marginEnd="@dimen/dimen_msg_width"
                android:fadingEdgeLength="20dp"
                android:requiresFadingEdge="vertical"
                android:scrollbars="none"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@+id/fl_pined" />

            <LinearLayout
                android:id="@+id/layout_action_btn"
                android:layout_width="@dimen/dimen_70dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                app:layout_constraintBottom_toTopOf="@+id/call_astrologer_btn"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/live_btn_share"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/dimen_10dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:padding="@dimen/dimen_7dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:src="@drawable/ic_share1"
                    app:tint="@color/no_change_white"/>

                <ImageView
                    android:id="@+id/live_btn_abuse_report"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/dimen_10dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:padding="@dimen/dimen_7dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/abuse_report_72"
                    app:tint="@color/no_change_white" />

                <ImageView
                    android:id="@+id/live_btn_mute_audio_2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/dimen_10dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:padding="@dimen/dimen_10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/btn_mute_audio"
                    app:tint="@color/no_change_white" />

                <ImageView
                    android:id="@+id/live_btn_mute_video_2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/dimen_10dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:padding="@dimen/dimen_10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/btn_mute_video"
                    android:visibility="visible"
                    app:tint="@color/no_change_white" />

                <ImageView
                    android:id="@+id/liveBtnEnableSpeaker"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/dimen_10dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:padding="@dimen/dimen_10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/btn_enable_speaker"
                    android:visibility="visible"
                    app:tint="@color/no_change_white" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/fl_pined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_marginTop="@dimen/dimen_10dp"
                android:layout_marginEnd="15dp"
                android:layout_marginBottom="@dimen/dimen_10dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/call_astrologer_btn"
                app:layout_constraintStart_toStartOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_live_steaming_chat_trans"
                    android:orientation="vertical"
                    android:padding="@dimen/dimen_7dp">

                    <TextView
                        android:id="@+id/text_astro_pinned_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/no_change_white"
                        android:maxLines="3"
                        android:textSize="@dimen/tv_size_12" />

                    <TextView
                        android:id="@+id/text_astro_pinned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/no_change_white"
                        android:maxLines="3"
                        android:textSize="@dimen/tv_size_12" />
                </LinearLayout>
            </LinearLayout>

            <RelativeLayout
                android:id="@+id/call_astrologer_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen_20dp"
                android:layout_marginBottom="@dimen/dimen_20dp"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/ll_inner_call_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_border_live_call"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginLeft="18dp"
                        android:layout_marginRight="10dp"
                        android:gravity="center"
                        android:text="@string/call_now"
                        android:textColor="@color/white" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="18dp"
                        android:layout_marginRight="10dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvPriceToCross"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginRight="3dp"
                            android:singleLine="true"
                            android:text="₹56/Min"
                            android:textColor="@color/white"
                            android:textSize="@dimen/tv_size_12" />

                        <TextView
                            android:id="@+id/tvPriceToCall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:text="56/Min"
                            android:textColor="@color/white"
                            android:textSize="@dimen/tv_size_12" />

                    </LinearLayout>


                </LinearLayout>

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginLeft="6dp"
                    android:layout_marginTop="19dp"
                    android:src="@drawable/ic_call_live" />

                <RelativeLayout
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginLeft="110dp"
                    android:layout_marginRight="8dp"
                    android:background="@drawable/circle_red"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="3"
                        android:textColor="@color/no_change_white"
                        android:textSize="@dimen/dimen_10dp" />

                </RelativeLayout>

            </RelativeLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/relSendMessage"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_above="@+id/bottom_container"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="@dimen/dimen_16dp"
            android:layout_marginEnd="@dimen/dimen_16dp"
            android:layout_marginBottom="@dimen/dimen_10dp"
            android:background="@android:color/transparent"
            android:orientation="horizontal"
            android:padding="5dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/editTextMessage"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/message_input_shape_live"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="10dp"
                    android:text="@string/write_comment"
                    android:textColor="@color/black"
                    android:textSize="@dimen/tv_size_14"
                    app:drawableEndCompat="@drawable/icon_send"
                    android:drawableTint="@color/colorPrimary_day_night"/>

                <ImageView
                    android:id="@+id/imgliveGift"
                    android:layout_width="40dip"
                    android:layout_height="40dip"
                    android:layout_marginLeft="10dp"
                    android:scaleType="fitCenter"
                    android:padding="8dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:src="@drawable/gift_icon"
                    app:layout_constraintLeft_toRightOf="@+id/editTextMessage"
                    app:tint="@color/no_change_white" />

            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


        <RelativeLayout
            android:id="@+id/bottom_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/live_room_top_layout"
            android:visibility="gone">

            <ImageView
                android:id="@+id/live_btn_switch_camera"
                android:layout_width="@dimen/live_bottom_btn_size"
                android:layout_height="@dimen/live_bottom_btn_size"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:background="@drawable/rounded_bg_full_transparent"
                android:scaleType="centerCrop"
                android:src="@drawable/btn_switch_camera" />

            <ImageView
                android:id="@+id/live_btn_beautification"
                android:layout_width="@dimen/live_bottom_btn_size"
                android:layout_height="@dimen/live_bottom_btn_size"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/live_bottom_btn_margin"
                android:layout_marginLeft="@dimen/live_bottom_btn_margin"
                android:layout_toEndOf="@id/live_btn_switch_camera"
                android:layout_toRightOf="@id/live_btn_switch_camera"
                android:background="@drawable/rounded_bg_full_transparent"
                android:scaleType="centerCrop"
                android:src="@drawable/btn_beauty" />

            <ImageView
                android:id="@+id/live_btn_more"
                android:layout_width="@dimen/live_bottom_btn_size"
                android:layout_height="@dimen/live_bottom_btn_size"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/live_bottom_btn_margin"
                android:layout_marginLeft="@dimen/live_bottom_btn_margin"
                android:layout_toEndOf="@id/live_btn_beautification"
                android:layout_toRightOf="@id/live_btn_beautification"
                android:background="@drawable/rounded_bg_full_transparent"
                android:scaleType="centerCrop"
                android:src="@drawable/btn_more" />

            <ImageView
                android:id="@+id/live_btn_push_stream"
                android:layout_width="@dimen/live_bottom_btn_size"
                android:layout_height="@dimen/live_bottom_btn_size"
                android:layout_alignParentEnd="true"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:background="@drawable/rounded_bg_full_transparent"
                android:scaleType="centerCrop"
                android:src="@drawable/btn_push_stream" />

            <ImageView
                android:id="@+id/live_btn_mute_audio_1"
                android:layout_width="@dimen/live_bottom_btn_size"
                android:layout_height="@dimen/live_bottom_btn_size"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/live_bottom_btn_margin"
                android:layout_marginRight="@dimen/live_bottom_btn_margin"
                android:layout_toStartOf="@id/live_btn_push_stream"
                android:layout_toLeftOf="@id/live_btn_push_stream"
                android:background="@drawable/rounded_bg_full_transparent"
                android:scaleType="centerCrop"
                android:src="@drawable/btn_mute_audio" />

            <ImageView
                android:id="@+id/live_btn_mute_video_1"
                android:layout_width="@dimen/live_bottom_btn_size"
                android:layout_height="@dimen/live_bottom_btn_size"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/live_bottom_btn_margin"
                android:layout_marginRight="@dimen/live_bottom_btn_margin"
                android:layout_toStartOf="@id/live_btn_mute_audio_1"
                android:layout_toLeftOf="@id/live_btn_mute_audio_1"
                android:background="@drawable/rounded_bg_full_transparent"
                android:scaleType="centerCrop"
                android:src="@drawable/btn_mute_video" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center|bottom"
            android:gravity="center|bottom"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bottom_layer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <include
                    android:id="@+id/layout_back_live"
                    layout="@layout/close_live_layout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />


                <include
                    android:id="@+id/layout_live_login"
                    layout="@layout/live_login_layout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <include
                    android:id="@+id/layout_live_follow"
                    layout="@layout/live_follow_layout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <include
                    android:id="@+id/layout_live_unfollow"
                    layout="@layout/live_unfollow_layout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <include
                    android:id="@+id/layout_live_astrologer_description"
                    layout="@layout/live_astrologer_bottom_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:visibility="gone" />

                <include
                    android:id="@+id/layout_leave_live_session_dialog"
                    layout="@layout/layout_leave_live_session_dialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:visibility="gone" />

                <include
                    android:id="@+id/layout_gift"
                    layout="@layout/layout_gift_live_session_dialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:visibility="gone" />

                <include
                    android:id="@+id/layout_live_end_consultation"
                    layout="@layout/live_end_consultation_layout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <include
                    android:id="@+id/layout_live_end_consultation_msg"
                    layout="@layout/live_end_consultation_msg_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:visibility="gone" />

                <include
                    android:id="@+id/layout_live_end_consultation_from_astro"
                    layout="@layout/live_end_consultation_from_astro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:visibility="gone" />

                <include
                    android:id="@+id/layout_astro_not_live"
                    layout="@layout/lay_astro_not_live"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:visibility="gone" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/call_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/live_room_top_layout"
            android:background="@android:color/transparent"
            android:gravity="center|right"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/llAlr1"
                android:layout_width="100dp"
                android:layout_height="24dp"
                android:layout_gravity="left"
                android:layout_marginLeft="20dp"
                android:gravity="left"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_border_live_connecting_call"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:maxLines="1"
                            android:paddingLeft="2dp"
                            android:text="Connecting..."
                            android:textColor="@color/black"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="0.75">

                        <ImageView
                            android:id="@+id/userCallAnimationConnecting"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:layout_gravity="center_vertical"
                            android:layout_margin="@dimen/dimen_3dp"
                            android:src="@drawable/sound_gif"
                            app:tint="@color/colorPrimary_day_night"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/llAlr2"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:layout_marginLeft="20dp"
                android:gravity="left"
                android:orientation="vertical"
                android:visibility="gone"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_border_live_connect_call_upper">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="left|center"
                        android:layout_weight="0.25"
                        android:gravity="left|center">

                        <TextView
                            android:id="@+id/callingUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingLeft="4dp"
                            android:text="username"
                            android:textColor="@color/black"
                            android:textSize="13sp"
                            android:visibility="visible" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        android:layout_weight="0.75">

                        <ImageView
                            android:id="@+id/userCallAnimation"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:layout_gravity="center_vertical"
                            android:layout_margin="5dp"
                            android:src="@drawable/sound_gif" />

                    </LinearLayout>


                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:background="@drawable/bg_border_live_connect_call_bottom">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="left|center"
                        android:layout_weight="0.35"
                        android:gravity="left|center">

                        <TextView
                            android:id="@+id/tvTimeDown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingLeft="4dp"
                            android:text=""
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:visibility="visible" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="0.65">

                        <ImageView
                            android:id="@+id/callDisconnect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="right|center_vertical"
                            android:layout_margin="@dimen/dimen_3dp"
                            android:src="@drawable/cal_cut_72" />


                    </LinearLayout>

                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/llAlrOtherUser"
                android:layout_width="110dp"
                android:layout_height="48dp"
                android:layout_gravity="left"
                android:layout_marginLeft="20dp"
                android:gravity="left"
                android:orientation="vertical"
                android:visibility="gone"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_border_live_connect_call_upper">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="left|center"
                        android:layout_weight="0.25"
                        android:gravity="left|center">

                        <TextView
                            android:id="@+id/otherUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:maxLines="1"
                            android:paddingLeft="2dp"
                            android:text="username"
                            android:textColor="@color/black"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        android:layout_weight="0.75">

                        <ImageView
                            android:id="@+id/otherUserCallAnimation"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:layout_gravity="center_vertical"
                            android:layout_margin="@dimen/dimen_3dp"
                            android:src="@drawable/sound_gif"
                            app:tint="@color/colorPrimary_day_night" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_border_live_connect_call_bottom">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="left|center"
                        android:layout_weight="0.25"
                        android:gravity="left|center">

                        <TextView
                            android:id="@+id/tvTimeDownOtherUser"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingLeft="2dp"
                            android:text=" 30:48 "
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:visibility="visible" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="0.75">


                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="@dimen/dimen_60dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="left|center"
                android:layout_weight="1"
                android:gravity="left|center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/previous"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginLeft="@dimen/dimen_16dp"
                    android:layout_marginBottom="@dimen/dimen_50dp"
                    android:background="@drawable/rounded_bg_full_transparent"
                    android:padding="@dimen/dimen_10dp"
                    android:src="@drawable/btn_back_arrow" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="right|center"
                android:layout_weight="1"
                android:gravity="right|center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/next"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginRight="@dimen/dimen_16dp"
                    android:layout_marginBottom="@dimen/dimen_50dp"
                    android:background="@drawable/rounded_bg_full_transparent"
                    android:padding="@dimen/dimen_10dp"
                    android:rotation="180"
                    android:src="@drawable/btn_back_arrow" />


            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/bgMsgLL"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|bottom"
        android:layout_marginBottom="100dip"
        android:background="@drawable/bg_live_steaming_chat_gift"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="@dimen/margin_xlarge"
        android:paddingTop="@dimen/margin_medium"
        android:paddingRight="@dimen/margin_xlarge"
        android:paddingBottom="@dimen/margin_medium"
        android:visibility="gone">

        <TextView
            android:id="@+id/fromTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:textColor="@color/white"
            android:textSize="@dimen/font_large" />

        <TextView
            android:id="@+id/messageTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:includeFontPadding="false"
            android:textColor="@color/white"
            android:textSize="40sp" />

    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/frameLiveIntro"
        android:visibility="gone"/>

</FrameLayout>