<androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardUseCompatPadding="true"
    app:cardElevation="5dp"
    app:cardCornerRadius="10dp"
    android:background="@color/bg_card_view_color">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card_view_color"
        android:padding="10dp">

        <TextView
            android:id="@+id/thanku_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/thank_you"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_20"
            android:textStyle="bold"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/popup_open"
            android:layout_alignParentRight="true"/>

        <TextView
            android:id="@+id/get_call_shortly_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/thanku_txt"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:paddingLeft="5dp"
            android:text="@string/get_call_from_our_astrologer"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_15"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
