<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/cardview_color">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imageAboutUs"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:scaleType="centerInside"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            android:paddingLeft="8dp"
            android:layout_alignParentLeft="true"
            android:src="@drawable/ic_public_black"
            android:clickable="false"
            android:layout_centerVertical="true"
            />

        <TextView
            android:id="@+id/textAboutUs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:minWidth="@dimen/min_height"
            android:minHeight="55dp"
            android:gravity="center_vertical"
            android:layout_centerVertical="true"
            android:paddingLeft="60dp"
            android:clickable="true"
            android:theme="@style/SelectableItemTheme"
            android:background="?attr/selectableItemBackground"
            android:textSize="@dimen/tv_size_20"
            android:text="Social Media Sharing"
            android:textColor="@color/black"/>
    </RelativeLayout>

</LinearLayout>