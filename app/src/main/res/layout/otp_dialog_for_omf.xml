<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="2dp"
    android:layout_marginLeft="12dp"
    android:layout_marginRight="12dp"
    android:paddingBottom="10dp"
    android:gravity="center">

    <LinearLayout
        android:id="@+id/upper_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_weight="1"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="30dp"
            android:layout_marginTop="5dp"
            android:layout_gravity="center_vertical"
            android:alpha="0.0"
            android:visibility="gone"
            android:background="@drawable/ic_call_black"/>

        <LinearLayout
            android:id="@+id/enter_otp_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="15dp"
            android:gravity="center">

            <TextView
                android:id="@+id/phone_verification_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:layout_marginLeft="0dp"
                android:textSize="20sp"
                android:textStyle="normal"
                android:textColor="@color/black"
                android:layout_gravity="center_horizontal"
                android:text="@string/phone_verification" />

            <TextView
                android:id="@+id/enter_otp_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="15dp"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="10dp"
                android:textSize="13sp"
                android:gravity="center"
                android:textStyle="bold"
                android:justificationMode="none"
                android:textColor="@color/print_divider_color"
                android:layout_gravity="center_horizontal"
                android:text="@string/trying_msg1" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginRight="15dp"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/trying_txt2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:layout_marginLeft="0dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:justificationMode="inter_word"
                    android:textColor="@color/black"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/trying_msg2" />

                <TextView
                    android:id="@+id/edit_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:layout_marginLeft="5dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/platinum_color"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/edit_txt" />

            </LinearLayout>


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical">


                <EditText
                    android:id="@+id/otp_edt1"
                    style="@style/OtpEdittext_omf"
                    android:layout_marginRight="6dp"
                    android:focusable="true"
                    android:imeOptions="actionNext">

                </EditText>

                <EditText
                    android:id="@+id/otp_edt2"
                    android:layout_marginRight="6dp"
                    android:layout_marginLeft="6dp"
                    style="@style/OtpEdittext_omf"
                    android:imeOptions="actionNext">

                </EditText>

                <EditText
                    android:id="@+id/otp_edt3"
                    android:layout_marginRight="6dp"
                    android:layout_marginLeft="6dp"
                    style="@style/OtpEdittext_omf"
                    android:imeOptions="actionNext">

                </EditText>

                <EditText
                    android:id="@+id/otp_edt4"
                    android:layout_marginRight="6dp"
                    android:layout_marginLeft="6dp"
                    style="@style/OtpEdittext_omf"
                    android:imeOptions="actionDone">

                </EditText>

                <EditText
                    android:id="@+id/otp_edt5"
                    android:layout_marginRight="6dp"
                    android:layout_marginLeft="6dp"
                    style="@style/OtpEdittext"
                    android:imeOptions="actionNext"
                    android:visibility="gone">

                </EditText>

                <EditText
                    android:id="@+id/otp_edt6"
                    android:layout_marginLeft="6dp"
                    style="@style/OtpEdittext"
                    android:imeOptions="actionDone"
                    android:visibility="gone">

                </EditText>


            </LinearLayout>

            <TextView
                android:id="@+id/not_recieved_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="10dp"
                android:layout_marginRight="8dp"
                android:text="@string/otp_not_recieved_txt"
                android:textColor="@color/print_unselected_text_color"
                android:textSize="15sp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/resend_otp_via_sms_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:layout_marginLeft="0dp"
                android:layout_marginTop="10dp"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/platinum_color"
                android:layout_gravity="center_horizontal"
                android:text="@string/resend_otp_via_sms_txt" />


        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="right"
        android:layout_below="@+id/upper_layout"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/btnback"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/ColorPrimaryDark" />


        <Button
            android:id="@+id/btnconfirm"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ok"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/ColorPrimaryDark" />


    </LinearLayout>

</RelativeLayout>