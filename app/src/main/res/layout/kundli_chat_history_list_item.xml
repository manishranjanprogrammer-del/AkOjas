<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?selectableItemBackground"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.ojassoft.astrosage.beans.CircularNetworkImageView
        android:id="@+id/iv_astrologer_image"
        android:layout_width="@dimen/dimen_50dp"
        android:layout_height="@dimen/dimen_50dp"
        android:layout_marginVertical="@dimen/dimen_15dp"
        android:layout_marginStart="@dimen/dimen_20dp"
        android:src="@drawable/kundli_icon_96"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <TextView
        android:id="@+id/tv_screen_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:ellipsize="end"
        android:textSize="@dimen/tv_size_17"
        android:textColor="@color/black"
        android:text="@string/txt_kundli"
        android:layout_marginHorizontal="@dimen/tv_size_10"
        app:layout_constraintTop_toTopOf="@id/tv_consult_time"
        app:layout_constraintStart_toEndOf="@id/iv_astrologer_image"
        app:layout_constraintEnd_toStartOf="@id/tv_consult_time"/>

    <TextView
        android:id="@+id/tv_heading"
        android:layout_width="@dimen/dimen_0dp"
        android:layout_height="wrap_content"
        android:text="@string/hi"
        android:maxLines="1"
        android:ellipsize="end"
        android:textSize="@dimen/tv_size_16"
        android:layout_marginHorizontal="@dimen/dimen_10dp"
        android:textColor="@color/black"
        app:layout_constraintStart_toEndOf="@id/iv_astrologer_image"
        app:layout_constraintEnd_toStartOf="@id/tv_consult_time"
        app:layout_constraintTop_toBottomOf="@id/tv_screen_name"/>
    <TextView
        android:id="@+id/tv_consult_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/dimen_12sp"
        android:layout_marginTop="@dimen/dimen_15dp"
        android:layout_marginStart="@dimen/dimen_10dp"
        android:layout_marginEnd="@dimen/dimen_16sp"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="2 minutes ago"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/get_100_extra_on_next_recharge"
        android:layout_marginStart="@dimen/dimen_10dp"
        android:layout_marginEnd="@dimen/tv_size_16"
        android:layout_marginBottom="@dimen/dimen_10dp"
        android:textSize="@dimen/dimen_16sp"
        android:textColor="@color/black"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_astrologer_image"
        app:layout_constraintTop_toBottomOf="@id/tv_heading"
        app:layout_constraintEnd_toEndOf="parent"/>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/separator_line"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>