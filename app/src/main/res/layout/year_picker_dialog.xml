<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/bg_card_view_color">

    <!-- HEADER -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_70dp"
        android:background="@color/colorPrimary_day_night"
        android:gravity="center"
        android:text="@string/year"
        android:textColor="@color/white"
        android:textSize="@dimen/dimen_22sp"
        android:textStyle="bold"/>


    <com.ojassoft.astrosage.utils.NumberPicker
        android:id="@+id/numberPickerYear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:layout_weight="1"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:padding="5dp"
        android:layout_gravity="center"
        android:theme="@style/DefaultNumberPickerTheme" />

    <!-- BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:padding="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="@color/colorPrimary_day_night"
            android:textSize="@dimen/dimen_16sp"
            android:layout_marginHorizontal="@dimen/dimen_20dp"/>

        <TextView
            android:id="@+id/btnOk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ok"
            android:textSize="@dimen/dimen_16sp"
            android:textColor="@color/colorPrimary_day_night"
            android:layout_marginHorizontal="@dimen/dimen_20dp"/>


    </LinearLayout>
</LinearLayout>