<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/dimen_10dp">

    <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
        android:id="@+id/image_view"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_profile_view"
        android:tint="@color/dot_gray" />

    <TextView
        android:id="@+id/txt1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:ellipsize="end"
        android:minWidth="@dimen/dimen_70dp"
        android:layout_marginTop="2dp"
        android:background="@color/dot_gray"
        android:maxLines="1"
        android:textColor="@color/txtColorBlWh"
        android:textSize="@dimen/tv_size_10" />
    <TextView
        android:id="@+id/txt2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:ellipsize="end"
        android:minWidth="40dp"
        android:layout_marginTop="2dp"
        android:background="@color/dot_gray"
        android:maxLines="1"
        android:textColor="@color/txtColorBlWh"
        android:textSize="8sp" />
</LinearLayout>