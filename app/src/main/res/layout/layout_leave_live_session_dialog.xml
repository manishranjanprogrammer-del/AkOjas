<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_top_curved_corners"
        android:paddingTop="@dimen/dimen_10dp">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="40dp"
            android:gravity="center_horizontal"
            android:layout_marginTop="@dimen/dimen_10dp"
            android:paddingEnd="40dp"
            android:text="@string/check_other_live_sessions"
            android:textColor="@color/black"
            android:textSize="@dimen/font_large"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/close"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="@dimen/dimen_20dp"
            android:contentDescription="Close"
            android:src="@drawable/ic_close_live"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_day_gray_night_white" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="@dimen/dimen_15dp"
            android:layout_marginTop="@dimen/dimen_15dp"
            android:layout_marginEnd="@dimen/dimen_15dp"
            android:background="#C3C2C2"
            app:layout_constraintTop_toBottomOf="@+id/title_text" />
        <FrameLayout
            android:id="@+id/fr_data_items"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:layout_constraintTop_toBottomOf="@+id/divider">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/astrologer_list"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginStart="@dimen/dimen_5dp"
                android:layout_marginEnd="@dimen/dimen_5dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:layout_constraintTop_toBottomOf="@+id/divider"
                app:spanCount="5"
                tools:listitem="@layout/layout_circular_astrologer" />
            <TextView
                android:id="@+id/astrologer_not_found"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:gravity="center"
                android:textStyle="bold"
                android:visibility="gone"
                android:textSize="@dimen/tv_size_20"
                android:textColor="@color/colorPrimary_day_night"
                android:text="@string/no_strologer_is_live"
                android:layout_marginStart="@dimen/dimen_20dp"
                android:layout_marginEnd="@dimen/dimen_20dp"
                app:layout_constraintTop_toBottomOf="@+id/divider"
                />
        </FrameLayout>

        <View
            android:id="@+id/divider_bottom"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="@dimen/dimen_15dp"
            android:layout_marginTop="@dimen/dimen_0dp"
            android:layout_marginEnd="@dimen/dimen_15dp"
            android:background="#C3C2C2"
            app:layout_constraintTop_toBottomOf="@+id/fr_data_items" />

        <Button
            android:id="@+id/followAndLeave"
            android:layout_width="0dp"
            android:layout_height="@dimen/dimen_45dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_button_orange"
            android:textAllCaps="false"

            android:textColor="@color/white"
            android:textSize="@dimen/dimen_16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/leave"
            app:layout_constraintTop_toBottomOf="@+id/divider_bottom" />

        <Button
            android:id="@+id/leave"
            android:layout_width="0dp"
            android:layout_height="@dimen/dimen_45dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_button_gray"
            android:text="@string/text_leave"
            android:textAllCaps="false"
            android:textColor="@color/no_change_black"
            android:textSize="@dimen/dimen_16sp"
            app:layout_constraintEnd_toStartOf="@+id/followAndLeave"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider_bottom" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/dimen_20dp"
            app:layout_constraintTop_toBottomOf="@+id/leave" />
    </androidx.constraintlayout.widget.ConstraintLayout>


</FrameLayout>
