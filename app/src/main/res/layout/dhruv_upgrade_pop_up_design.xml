<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/planDhruvRootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColorView">

    <!-- ScrollView has been removed. This ConstraintLayout is now the main content area. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_layout"
        android:background="@color/backgroundColorView">

        <!-- 1. Flexible Image: Height is now 0dp to fill available dpace. -->
        <ImageView
            android:id="@+id/kundli_img"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:src="@drawable/kundli_ai_image"
            app:layout_constraintBottom_toTopOf="@+id/heading_layout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivClosePage"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:padding="8dp"
            android:src="@drawable/ic_close_live"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/adTimerLayout"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ProgressBar
                android:id="@+id/ADprogressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="5000"
                android:progress="5000"
                android:progressDrawable="@drawable/circle_progress"
                android:rotation="-90" />

            <TextView
                android:id="@+id/ADtvCountdown"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="5"
                android:textAlignment="center"
                android:textColor="@color/no_change_white"
                android:textSize="20dp" />

        </FrameLayout>


        <!-- 2. Correctly constrained fade overlay. -->
        <ImageView
            android:id="@+id/fade_overlay"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:src="@drawable/bg_image_fade_down_to_up"
            app:layout_constraintBottom_toBottomOf="@+id/kundli_img"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- This is the logo -->
        <ImageView
            android:id="@+id/heading_layout"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:scaleType="centerInside"
            android:src="@drawable/dhruv_astro_software_logo"
            app:layout_constraintBottom_toTopOf="@+id/premium_layout_view"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />


        <!-- 3. Feature list is now constrained to the bottom, ensuring it's always visible. -->
        <LinearLayout
            android:id="@+id/premium_layout_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="10dp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <CheckBox
                    android:id="@+id/ivRightTick5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:enabled="false"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:tint="@color/colorPrimary_day_night" />

                <TextView
                    android:id="@+id/unlimited_chat_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="2dp"
                    android:text="@string/ask_num_ques_a_day"
                    android:textColor="@color/text_color"
                    android:textSize="18dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <CheckBox
                    android:id="@+id/ivRightTick9"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:enabled="false"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:tint="@color/colorPrimary_day_night" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="2dp"
                    android:id="@+id/font_auto_dhruv_upgrade_pop_up_design_2"
                    android:text="@string/our_most_advanced_AI_model"
                    android:textColor="@color/text_color"
                    android:textSize="18dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <CheckBox
                    android:id="@+id/ivRightTick8"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:enabled="false"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:tint="@color/colorPrimary_day_night" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="2dp"
                    android:id="@+id/font_auto_dhruv_upgrade_pop_up_design_3"
                    android:text="@string/hun_premium_kundli_worth_rs50000"
                    android:textColor="@color/text_color"
                    android:textSize="18dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <CheckBox
                    android:id="@+id/ivRightTick7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:enabled="false"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:tint="@color/colorPrimary_day_night" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="2dp"
                    android:id="@+id/font_auto_dhruv_upgrade_pop_up_design_4"
                    android:text="@string/personalized_branding_on_kundli"
                    android:textColor="@color/text_color"
                    android:textSize="18dp" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <CheckBox
                    android:id="@+id/ivRightTick6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:enabled="false"
                    android:scaleX="0.8"
                    android:scaleY="0.8"
                    android:theme="@style/MyCheckBox"
                    app:tint="@color/colorPrimary_day_night" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="2dp"
                    android:id="@+id/font_auto_dhruv_upgrade_pop_up_design_5"
                    android:text="@string/additional_10_per_discount"
                    android:textColor="@color/text_color"
                    android:textSize="18dp" />
            </LinearLayout>

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- The bottom layout remains anchored to the bottom of the screen. -->
    <LinearLayout
        android:id="@+id/bottom_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:background="@color/backgroundColorView"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/errorHeadingLL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_24dp"
            android:layout_marginEnd="@dimen/dimen_24dp"
            android:layout_marginBottom="@dimen/dimen_10dp"
            android:background="@drawable/limit_reached_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/dimen_10dp"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/errorHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:paddingBottom="20dip"
                android:text="@string/chat_limit_reached"
                android:textColor="@color/no_change_white"
                android:textSize="@dimen/tv_size_18"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/phonePePaymentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/sectionColor"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="@dimen/dimen_10dp"
            android:visibility="gone">
            <Spinner
                android:id="@+id/spinnerApps"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:spinnerMode="dropdown"
                android:layout_marginStart="@dimen/dimen_12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:visibility="visible" />
            <!-- Left: payment chooser (icon + label + arrow) -->
            <LinearLayout
                android:id="@+id/llPaymentChooser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@color/sectionColor"
                android:clipToPadding="false"
                android:paddingTop="@dimen/dimen_10dp"
                android:paddingStart="@dimen/dimen_24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:minHeight="40dp"
                app:layout_constraintEnd_toStartOf="@+id/btnStartSubsPayment"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <!-- Hidden Spinner used to show choices -->


                <ImageView
                    android:id="@+id/ivSelectedAppIcon"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:contentDescription="app icon"
                    />

                <LinearLayout
                    android:id="@+id/llSelectedAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <TextView
                        android:id="@+id/txtSelectedAppName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/pay_via"
                        android:textColor="@color/black"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvSelectedAppName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivDropArrow"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="@dimen/dimen_5dp"
                            android:contentDescription="open"
                            android:src="@drawable/ic_arrow_down_24px"
                            app:tint="@color/ivTintColorDN" />

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <!-- Right: Pay button -->
            <Button
                android:id="@+id/btnStartSubsPayment"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_button_yellow"
                android:backgroundTint="@color/colorPrimary_day_night"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_marginTop="@dimen/dimen_10dp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/tv_size_17"
                android:layout_marginEnd="@dimen/dimen_24dp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/llPaymentChooser"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/llPaymentChooser"
                app:layout_constraintTop_toTopOf="@+id/llPaymentChooser" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <RelativeLayout
            android:id="@+id/subscribeForBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dimen_12dp"
            android:layout_marginBottom="@dimen/dimen_20dp"
            android:background="@drawable/bg_button_choose_kundli"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:foreground="?attr/selectableItemBackground"
            android:paddingVertical="@dimen/dimen_8dp">

            <TextView
                android:id="@+id/tv_btn_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/dimen_20dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/subscribe_for_text"
                android:textColor="@color/white"
                android:textSize="@dimen/dimen_20dp" />

            <ImageView
                android:layout_width="25dp"
                android:layout_height="30dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/dimen_20dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_keyboard_arrow_right_black"
                app:tint="@color/white" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/subscribeForBtnDiable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dimen_16dp"
            android:layout_marginBottom="@dimen/dimen_35dp"
            android:background="@drawable/bg_button_choose_kundli"
            android:backgroundTint="@color/colorPrimary_day_night_very_lighter"
            android:paddingVertical="@dimen/dimen_8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_btn_txt_diable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/dimen_20dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/subscribe_for_text"
                android:textColor="@color/white"
                android:textSize="@dimen/dimen_20dp" />

            <ImageView
                android:layout_width="25dp"
                android:layout_height="30dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/dimen_20dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_keyboard_arrow_right_black"
                app:tint="@color/white" />
        </RelativeLayout>

    </LinearLayout>
</RelativeLayout>
