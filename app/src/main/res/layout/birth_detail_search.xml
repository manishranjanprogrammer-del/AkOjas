<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:fillViewport="true">


    <LinearLayout
        android:id="@+id/birth_detail_serch_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:descendantFocusability="beforeDescendants"
        android:focusableInTouchMode="true"
        android:orientation="vertical">


        <TextView
            android:id="@+id/viweForStatusBar"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:background="@color/ColorPrimary"
            android:visibility="gone"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/search_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cardview_color"
            app:cardElevation="@dimen/dimen_10dp"
            android:layout_marginRight="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginLeft="10dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/text_day_gray_night_white" />

                    <!-- <AutoCompleteTextView
                         android:id="@+id/editTextSearchKundli"
                         android:layout_width="0dp"
                         android:layout_height="match_parent"
                         android:layout_gravity="center_vertical"
                         android:layout_weight=".75"
                         android:background="@color/white"
                         android:hint="Search Kundli"
                         android:maxLength="50"
                         android:theme="@style/Autocomplete"
                         android:maxLines="1"
                         android:paddingLeft="10dp"
                         android:singleLine="true"
                         style="@style/Theme.App.Base" />-->
                    <AutoCompleteTextView
                        android:id="@+id/editTextSearchKundli"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="center_vertical"
                        android:layout_weight=".75"
                        android:background="@android:color/transparent"
                        android:dropDownHeight="wrap_content"
                        android:hint="@string/Searchkundli"
                        android:maxLength="50"
                        android:maxLines="1"
                        android:paddingLeft="10dp"
                        android:singleLine="true"
                        android:textColorHint="@color/text_day_gray_night_white"
                        android:textColor="@color/ivTintColorDN"
                        android:theme="@style/Autocomplete" />

                    <ProgressBar
                        android:id="@+id/progressbar"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:visibility="invisible" />

                </LinearLayout>

               <!-- <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">-->

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:visibility="gone"
                        android:background="@color/light_gray" />

                    <TextView
                        android:id="@+id/no_kundli_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:padding="10dp"
                        android:text="@string/no_kundli_error"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:visibility="gone" />
                <!--</LinearLayout>-->
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <RadioGroup
            android:id="@+id/rbGroupKundliSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="16dp"
            android:layout_marginRight="10dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="visible">

            <RadioButton
                android:id="@+id/rbKundliSearchLocal"
                android:layout_width="0dp"
                android:layout_height="@dimen/custom_btn_height"
                android:layout_weight="1"
                android:background="@drawable/rbtn_selector"
                android:button="@null"
                android:checked="true"
                android:gravity="center"
                android:text="@string/Load_All_Local_Kundli"
                android:textColor="@drawable/rbtn_textcolor_selector"
                android:textStyle="bold" />

            <!--<RadioButton
                android:id="@+id/rbKundliSearchAll"
                android:layout_width="0dp"
                android:layout_height="@dimen/custom_btn_height"
                android:layout_weight="1"
                android:background="@drawable/rbtn_selector"
                android:button="@null"
                android:gravity="center"
                android:text="all"
                android:textColor="@drawable/rbtn_textcolor_selector"
                android:textStyle="bold" />-->

            <RadioButton
                android:id="@+id/rbKundliSearchOnline"
                android:layout_width="0dp"
                android:layout_height="@dimen/custom_btn_height"
                android:layout_weight="1"
                android:background="@drawable/rbtn_selector"
                android:button="@null"
                android:gravity="center"
                android:text="@string/cloud_kundlis"
                android:textColor="@drawable/rbtn_textcolor_selector"
                android:textStyle="bold" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/recent_text_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="16dp"
            android:layout_marginRight="10dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/recent_view_kundli_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lastfivecharts"
                android:visibility="visible" />

            <TextView
                android:id="@+id/load_local_kundli"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_gravity="right"
                android:background="@drawable/rect_rounded_image"
                android:drawablePadding="2dp"
                android:gravity="center"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:text="@string/Load_All_Local_Kundli"
                android:textAllCaps="false"
                android:textSize="@dimen/input_screen_text_size" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:weightSum="1">

            <ImageButton
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="10dip"
                android:layout_weight=".25" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight=".75"
                android:gravity="center_horizontal"
                android:text="@string/lastfivecharts" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/personKundaliDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="16dp"
            android:layout_marginRight="8dp"
            app:cardBackgroundColor="@color/bg_card_view_color"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="0dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:padding="2dp"
                    android:text="@string/your_personal_kundli"
                    android:textSize="@dimen/heading_text_size" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="1dp"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/genderImagePersonal"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:paddingLeft="5dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:src="@drawable/ic_male" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginRight="5dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/name_value_only"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Person Name"
                                android:textSize="18dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/birthDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/birth_date" />

                            <TextView
                                android:id="@+id/birthDateTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12-01-2016" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/bTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/birth_time" />

                            <TextView
                                android:id="@+id/birthTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="08:01" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/bPlace"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/birth_place" />

                            <TextView
                                android:id="@+id/birthPlace"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Agra,Utter Pradesh,India" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <Button
            android:id="@+id/create_kundli"
            style="@style/buttonstyle"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/button_top_margin_small"
            android:backgroundTint="@color/ColorPrimaryDark"
            android:gravity="center"
            android:minHeight="56dp"
            android:text="@string/create_yourFirst_kundali"
            android:theme="@style/buttonstyle"
            android:visibility="gone" />
        <!--  <android.support.design.widget.FloatingActionButton
              android:id="@+id/fab"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="bottom|end"
              android:layout_margin="16dp"
              android:src="@android:drawable/ic_dialog_email" />-->


        <LinearLayout
            android:id="@+id/select_from_below_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingLeft="5dp"
            android:paddingTop="5dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="5dp"
                android:paddingTop="5dp"
                android:text="@string/select_from_below"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/lstSearchKundli"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="8dp" />

                <LinearLayout
                    android:id="@+id/error_conteainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/error_image"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_portable_wifi_off_black" />

                    <TextView
                        android:id="@+id/error_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No Internet Connection." />


                    <Button
                        android:id="@+id/login_btn"
                        style="@style/buttonstyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="30dp"
                        android:layout_marginRight="30dp"
                        android:backgroundTint="@color/colorPrimary_day_night"
                        android:textColor="@color/white"
                        android:text="@string/sign_in_capital"
                        android:theme="@style/buttonstyle" />

                </LinearLayout>


            </FrameLayout>

            <Button
                android:id="@+id/load_more_btn"
                style="@style/buttonstyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:layout_marginRight="30dp"
                android:backgroundTint="@color/ColorPrimaryDark"
                android:text="@string/load_more_capital"
                android:theme="@style/buttonstyle"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/custom_list_view_selector"
            android:drawableRight="@drawable/down_arrow"
            android:drawablePadding="5dp"
            android:text="@string/load_all_charts"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

