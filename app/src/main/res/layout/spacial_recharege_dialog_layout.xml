<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="@dimen/dimen_16dp"
    android:background="@drawable/top_round_corner"
    android:backgroundTint="@color/bg_color">

    <ImageView
        android:id="@+id/ivCancel"
        android:layout_width="@dimen/dimen_20dp"
        android:layout_height="@dimen/dimen_20dp"
        android:src="@drawable/ic_cancel_black"
        android:layout_marginTop="@dimen/dimen_5dp"
        android:layout_marginEnd="@dimen/dimen_5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvHeading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/leaving_already"
        android:textSize="@dimen/tv_size_25"
        android:gravity="center"
        android:textColor="@color/black"
        android:layout_marginHorizontal="@dimen/dimen_16dp"
        app:layout_constraintTop_toBottomOf="@id/ivCancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Sub Text -->
    <TextView
        android:id="@+id/tvSubText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/continue_your_chat"
        android:textSize="@dimen/tv_size_22"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="@dimen/dimen_16dp"

        app:layout_constraintTop_toBottomOf="@id/tvHeading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Validity Text -->
    <TextView
        android:id="@+id/tvValidity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/valid_today_only"
        android:textSize="@dimen/tv_size_20"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:layout_marginHorizontal="@dimen/dimen_16dp"
        android:textStyle="italic"
        android:alpha="0.9"
        app:layout_constraintTop_toBottomOf="@id/tvSubText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Recharge Button -->
    <Button
        android:id="@+id/btnRecharge"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="@string/recharge_now"
        android:textAllCaps="false"
        android:textSize="@dimen/tv_size_22"
        android:background="@drawable/bg_button_choose_kundli"
        android:backgroundTint="@color/colorPrimary_day_night"
        android:textColor="@color/white"
        android:layout_marginTop="@dimen/dimen_20dp"
        android:layout_marginBottom="@dimen/dimen_5dp"
        android:layout_marginHorizontal="@dimen/dimen_16dp"
        app:layout_constraintTop_toBottomOf="@id/tvValidity"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
