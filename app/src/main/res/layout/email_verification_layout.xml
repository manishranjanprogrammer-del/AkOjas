<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@+id/back_arrow"
        android:layout_width="42dp"
        android:layout_height="38dp"
        android:layout_margin="@dimen/dimen_16dp"
        android:src="@drawable/ic_back"
        app:tint="@color/black"
        android:foreground="?android:attr/selectableItemBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/heading_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/email_verification"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/back_arrow"
        app:layout_constraintStart_toEndOf="@+id/back_arrow"
        app:layout_constraintTop_toTopOf="@id/back_arrow" />

    <TextView
        android:id="@+id/tv1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_32dp"
        android:paddingHorizontal="@dimen/dimen_20dp"
        android:text="@string/please_enter_code_to_verify_mail_msg"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/heading_text" />

    <LinearLayout
        android:id="@+id/otp_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tv1"
        android:layout_marginStart="@dimen/dimen_20dp">


        <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
            android:id="@+id/otp_edt1"
            style="@style/OtpEdittext"
            android:layout_marginRight="6dp"
            android:focusable="true"
            android:textColor="@color/black"
            android:imeOptions="actionNext" />

        <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
            android:id="@+id/otp_edt2"
            style="@style/OtpEdittext"
            android:textColor="@color/black"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:imeOptions="actionNext" />


        <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
            android:id="@+id/otp_edt3"
            style="@style/OtpEdittext"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:textColor="@color/black"
            android:imeOptions="actionNext" />

        <com.ojassoft.astrosage.varta.customwidgets.CustomEditText
            android:id="@+id/otp_edt4"
            style="@style/OtpEdittext"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:textColor="@color/black"
            android:imeOptions="actionNext" />

        <!--<EditText
            android:id="@+id/otp_edt5"
            android:layout_marginRight="6dp"
            android:layout_marginLeft="6dp"
            style="@style/OtpEdittext"
            android:imeOptions="actionNext">

        </EditText>

        <EditText
            android:id="@+id/otp_edt6"
            android:layout_marginLeft="6dp"
            style="@style/OtpEdittext"
            android:imeOptions="actionDone">

        </EditText>-->


    </LinearLayout>

    <TextView
        android:id="@+id/verify_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/verify"
        android:background="@drawable/bg_button_choose_kundli"
        android:paddingHorizontal="@dimen/dimen_32dp"
        android:textSize="@dimen/dimen_16sp"
        android:includeFontPadding="false"
        android:foreground="?android:attr/selectableItemBackground"
        android:paddingVertical="@dimen/dimen_10dp"
        app:layout_constraintTop_toBottomOf="@+id/otp_layout"
        android:layout_marginStart="@dimen/dimen_20dp"
        app:layout_constraintStart_toStartOf="parent"
        android:textAllCaps="false"
        android:layout_marginTop="@dimen/dimen_24dp"
        android:textColor="@color/white"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/verify_btn"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="@dimen/dimen_20dp"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/didt_get_otp"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_17" />

        <LinearLayout
            android:id="@+id/llResendOTPLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <TextView
                android:id="@+id/txtViewResendOtp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/resend_sms_in"
                android:layout_marginStart="@dimen/dimen_5dp"
                android:textColor="@color/gray_text_day_night"
                android:textSize="@dimen/dimen_15sp" />


        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>