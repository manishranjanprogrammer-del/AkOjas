<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:cardCornerRadius="12dp"
        android:layout_margin="25dp"
        app:cardBackgroundColor="@color/bg_card_view_color">

        <LinearLayout
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:id="@+id/live_login_text"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:textColor="@color/black"
                android:layout_gravity="center"
                android:gravity="center"
                android:textSize="@dimen/tv_size_18"
                android:text="@string/live_login_txt" />

            <LinearLayout
                android:layout_marginTop="25dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:gravity="center"
                android:weightSum="2"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1.0dip">

                <Button
                    android:layout_weight="1"
                    style="@style/buttonBackgroundBorder"
                    android:id="@+id/live_login_cancel_btn"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:text="@string/cancel"/>

                <Button
                    android:layout_weight="1"
                    style="@style/buttonBackground"
                    android:layout_marginLeft="@dimen/dimen_10dp"
                    android:id="@+id/live_login_ok_btn"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:text="@string/ok"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>