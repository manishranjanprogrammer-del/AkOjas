<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/planDhruvRootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColorView">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/backgroundColorView"
        android:layout_above="@+id/bottom_layout"
        android:fillViewport="true">


<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/planAiConsultationPlanRootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColorView"
    tools:context=".ui.act.PurchaseAiConsultationPlan">

    <FrameLayout
        android:id="@+id/astro_img_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_0dp"
        android:scaleType="centerCrop"
        android:layout_marginBottom="@dimen/dimen_20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tab_layout"
        app:layout_constraintVertical_weight="1" >

        <ImageView
            android:id="@+id/kundli_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ai_astrologers" />

        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_overlay" />

    </FrameLayout>


    <ImageView
        android:id="@+id/ivClosePage"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="@dimen/dimen_7dp"
        android:layout_marginEnd="@dimen/dimen_5dp"
        android:src="@drawable/cancel_icon_64"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
