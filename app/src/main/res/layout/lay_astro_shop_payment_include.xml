<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <LinearLayout
            android:id="@+id/layout_creditcard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="left|center_vertical"
                android:paddingLeft="45dp"
                android:text="@string/astroshop_tap_to_select"

                android:visibility="gone" />

            <LinearLayout

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="3">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">


                    <ImageView
                        android:id="@+id/imgVisa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/circle_gray"
                        android:src="@drawable/ic_visa"
                        android:text="" />

                    <TextView
                        android:id="@+id/txtvisa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="@string/astroshop_visa_card"
                        android:textSize="16sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">


                    <ImageView
                        android:id="@+id/imgmaesrtocard"
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"
                        android:layout_gravity="center"

                        android:background="@drawable/circle_gray"
                        android:src="@drawable/ic_mestrocard"
                        android:text="" />

                    <TextView
                        android:id="@+id/txtmaesrtocard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="@string/astroshop_maestro_card"
                        android:textSize="16sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">


                    <ImageView
                        android:id="@+id/imgmastercard"
                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"
                        android:layout_gravity="center"

                        android:background="@drawable/circle_gray"
                        android:src="@drawable/ic_mastercard"
                        android:text="" />

                    <TextView
                        android:id="@+id/txtmastercard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="@string/astroshop_master_card"
                        android:textSize="16sp" />

                </LinearLayout>
            </LinearLayout>

            <Spinner
                android:id="@+id/spnrdrop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:gravity="left"
                style="@style/Spinnerwithunderline"
                android:padding="4dp"
                android:spinnerMode="dropdown" />

            <!--     <Spinner
                     android:id="@+id/spnrdrop"
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:layout_margin="20dip"
                     android:background="@drawable/spinner_drawable"
                     android:padding="8dp"
                     android:spinnerMode="dialog" />-->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="25dp"
                android:layout_marginRight="25dp"
                android:layout_marginTop="5dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtyoupay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="left"
                    android:text="@string/astroshop_you_pay"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txtyopayrs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="right|end"
                    android:text="2777Rs"
                    android:textSize="16sp" />
            </LinearLayout>


            <Button
                android:id="@+id/btn_pay_proceed"
                style="@style/buttonstyle"
                android:layout_height="56dp"
                android:layout_marginLeft="25dp"
                android:layout_marginRight="25dp"
                android:layout_marginTop="@dimen/button_top_margin_small"
                android:backgroundTint="@color/ColorPrimaryDark"
                android:text="@string/astroshop_complete_payment"
                android:textColor="#FFFFFF"
                android:visibility="gone"
                android:theme="@style/buttonstyle" />

        </LinearLayout>
    </LinearLayout>


</LinearLayout>