<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColorView">

    <LinearLayout
        android:id="@+id/toolbar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/back_arrow"
            android:layout_width="42dp"
            android:layout_height="38dp"
            android:layout_gravity="center_vertical"
            android:layout_margin="@dimen/dimen_16dp"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/ic_back"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/heading_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enter_email"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/back_arrow"
            app:layout_constraintStart_toEndOf="@+id/back_arrow"
            app:layout_constraintTop_toTopOf="@id/back_arrow" />
    </LinearLayout>


    <TextView
        android:id="@+id/tv1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_20dp"
        android:paddingHorizontal="@dimen/dimen_20dp"
        android:text="@string/please_enter_email_for_brihat_msg"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_layout" />
    <TextView
        android:id="@+id/tv2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/code_will_send_to_mail_msg"
        android:paddingHorizontal="@dimen/dimen_20dp"
        android:textSize="@dimen/dimen_16sp"
        app:layout_constraintTop_toBottomOf="@+id/tv1"
        android:layout_marginTop="@dimen/dimen_5dp"/>

    <EditText
        android:id="@+id/edit_text_email"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dimen_20dp"
        android:textSize="16sp"
        android:inputType="textEmailAddress"
        android:textColor="@color/black"
        android:hint="admin@gmail.com"
        android:textColorHint="@color/gray_text_day_night"
        app:layout_constraintTop_toBottomOf="@+id/tv2"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="30dp"
        android:paddingHorizontal="@dimen/dimen_12dp"
        android:paddingVertical="@dimen/dimen_12dp"
        android:background="@drawable/bg_grey_box_rounded"/>

    <TextView
        android:id="@+id/send_code_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/send_code"
        android:background="@drawable/bg_button_choose_kundli"
        android:paddingHorizontal="@dimen/dimen_20dp"
        android:textSize="@dimen/dimen_16sp"
        android:includeFontPadding="false"
        android:foreground="?android:attr/selectableItemBackground"
        android:paddingVertical="@dimen/dimen_12dp"
        app:layout_constraintTop_toBottomOf="@+id/edit_text_email"
        android:layout_marginStart="@dimen/dimen_20dp"
        app:layout_constraintStart_toStartOf="parent"
        android:textAllCaps="false"
        android:layout_marginTop="30dp"
        android:textColor="@color/white"/>

</androidx.constraintlayout.widget.ConstraintLayout>