<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <include
        android:id="@+id/toolBar_InputKundli"
        layout="@layout/tool_bar_app_module"
        android:layout_alignParentTop="true"
        android:layout_height="wrap_content"
        android:layout_width="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingRight="@dimen/activity_horizontal_margin"
            android:paddingLeft="@dimen/activity_horizontal_margin">

            <TextView
                android:id="@+id/tvRequestPasswordHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/request_password_heading"
                android:minWidth="@dimen/min_height"
                android:minHeight="@dimen/min_height"
                style="@style/title_style_new"
                android:gravity="center"
                />

            <TextView
                android:id="@+id/tvRequestPasswordDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/request_password_tag"
                style="@style/subheading_style"
                android:gravity="center|left"
                android:layout_marginTop="@dimen/activity_horizontal_margin"
                android:layout_marginBottom="@dimen/activity_horizontal_margin"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                app:cardBackgroundColor="@color/bg_card_view_color">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/activity_horizontal_margin"
                    android:paddingRight="@dimen/activity_horizontal_margin">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginRight="20dp"
                                android:layout_marginTop="5dp"
                                android:alpha="0.8"
                                android:src="@drawable/ic_person_black"
                                app:tint="@color/black" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/userTextInputLay"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColorHint="@color/text_day_gray_night_white">

                                <EditText
                                    android:id="@+id/etUserName"
                                    style="@style/Theme.App.Base"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:ems="10"
                                    android:layout_weight="1"
                                    android:textColor="@color/black"
                                    android:backgroundTint="@color/colorPrimary_day_night"
                                    android:hint="@string/text_email_id_or_user_name"
                                    android:contentDescription="@string/text_email_id_or_user_name"
                                    android:inputType="text" >
                                </EditText>

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <Button
                            android:id="@+id/btnSendPass"
                            android:layout_marginTop="@dimen/button_margin_bottom"
                            android:backgroundTint="@color/colorPrimary_day_night"
                            style="@style/buttonstyle"
                            android:textColor="@color/white"
                            android:text="@string/forget_pass_text" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>


    </ScrollView>

</LinearLayout>