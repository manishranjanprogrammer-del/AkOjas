<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
   android:id="@+id/videoLayout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginStart="2dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.cardview.widget.CardView
        android:id="@+id/thumbLayout"
        android:layout_width="115dp"
        android:layout_height="78dp"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="@dimen/dimen_5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.android.volley.toolbox.NetworkImageView
            android:id="@+id/thumbnailIV"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"/>
        <ImageView
            android:layout_width="@dimen/dimen_32dp"
            android:layout_height="@dimen/dimen_32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_video_player" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/captionTV"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:paddingEnd="@dimen/dimen_5dp"
        app:layout_constraintTop_toBottomOf="@+id/thumbLayout"
        app:layout_constraintStart_toStartOf="@+id/thumbLayout"
        android:layout_marginTop="@dimen/dimen_5dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/txtColorBlWh"
        android:textSize="@dimen/tv_size_14"
        android:text="Kundli Secret"/>

</androidx.constraintlayout.widget.ConstraintLayout>