<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/dimen_20dp"
    android:background="@color/bg_transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_translucent_rounded_corner"
        android:paddingBottom="30dp">

        <ImageView
            android:id="@+id/closeAbuse"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="@dimen/dimen_10dp"
            android:background="?attr/selectableItemBackground"
            android:src="@drawable/ic_sdk_close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/top_text"
            app:tint="@color/orange_color" />

        <TextView
            android:id="@+id/top_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/concern_submit_text"
            android:textColor="@color/no_change_white"
            android:textSize="15sp"
            android:textStyle="normal"
            android:gravity="center"
            android:paddingHorizontal="@dimen/dimen_20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/closeAbuse" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</RelativeLayout>