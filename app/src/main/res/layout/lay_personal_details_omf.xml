<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp"
                android:background="@color/platinum_color">

                <TextView
                    android:id="@+id/textViewHeading"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/one_month_membership_txt"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

            <LinearLayout
                android:id="@+id/llEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="20dp"
                    android:layout_marginTop="5dp"
                    android:layout_gravity="center_vertical"
                    android:alpha="0.8"
                    android:background="@drawable/ic_email_black"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <EditText
                        android:id="@+id/edtMailId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        style="@style/Theme.App.Base"
                        android:ems="10"
                        android:layout_weight="1"
                        android:hint="@string/text_email"
                        android:contentDescription="@string/text_email"
                        android:backgroundTint="@color/ColorPrimary"
                        android:inputType="textEmailAddress"
                        android:maxLength="50"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="20dp"
                    android:layout_marginTop="5dp"
                    android:layout_gravity="center_vertical"
                    android:alpha="0.8"
                    android:background="@drawable/ic_call_black"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <EditText
                        android:id="@+id/edtCountryCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        style="@style/Theme.App.Base"
                        android:ems="8"
                        android:backgroundTint="@color/ColorPrimary"
                        android:hint="@string/code"
                        android:text="+91"
                        android:contentDescription="@string/phone"
                        android:textColorHint="@color/ColorPrimary"
                        android:inputType="number"
                        android:editable="false"
                        android:focusable="false"
                        android:clickable="true"
                        android:textSize="15sp"
                        android:drawableRight="@drawable/dropdown_icon"
                        android:maxLength="15"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_weight="1">
                    <EditText
                        android:id="@+id/edtPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        style="@style/Theme.App.Base"
                        android:ems="10"
                        android:backgroundTint="@color/ColorPrimary"
                        android:hint="@string/phone"
                        android:contentDescription="@string/phone"
                        android:inputType="number|textNoSuggestions"
                        android:maxLength="15"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/send_otp_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:layout_marginLeft="5dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="right|center_vertical"
                android:textColor="@color/platinum_color"
                android:layout_gravity="right|center_horizontal"
                android:text="@string/send_otp"
                android:visibility="gone"/>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_weight="1"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="30dp"
                    android:layout_marginTop="5dp"
                    android:layout_gravity="center_vertical"
                    android:alpha="0.0"
                    android:visibility="gone"
                    android:background="@drawable/ic_call_black"/>

            <LinearLayout
                android:id="@+id/enter_otp_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="15dp">

                <TextView
                    android:id="@+id/enter_otp_txt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:layout_marginLeft="0dp"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/print_unselected_text_color"
                    android:layout_gravity="left|center_horizontal"
                    android:text="@string/enter_otp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical">


                    <EditText
                        android:id="@+id/otp_edt1"
                        style="@style/OtpEdittext_omf"
                        android:layout_marginRight="6dp"
                        android:focusable="true"
                        android:imeOptions="actionNext">

                    </EditText>

                    <EditText
                        android:id="@+id/otp_edt2"
                        android:layout_marginRight="6dp"
                        android:layout_marginLeft="6dp"
                        style="@style/OtpEdittext_omf"
                        android:imeOptions="actionNext">

                    </EditText>

                    <EditText
                        android:id="@+id/otp_edt3"
                        android:layout_marginRight="6dp"
                        android:layout_marginLeft="6dp"
                        style="@style/OtpEdittext_omf"
                        android:imeOptions="actionNext">

                    </EditText>

                    <EditText
                        android:id="@+id/otp_edt4"
                        android:layout_marginRight="6dp"
                        android:layout_marginLeft="6dp"
                        style="@style/OtpEdittext_omf"
                        android:imeOptions="actionDone">

                    </EditText>

                    <EditText
                        android:id="@+id/otp_edt5"
                        android:layout_marginRight="6dp"
                        android:layout_marginLeft="6dp"
                        style="@style/OtpEdittext"
                        android:imeOptions="actionNext"
                        android:visibility="gone">

                    </EditText>

                    <EditText
                        android:id="@+id/otp_edt6"
                        android:layout_marginLeft="6dp"
                        style="@style/OtpEdittext"
                        android:imeOptions="actionDone"
                        android:visibility="gone">

                    </EditText>


                </LinearLayout>

                <TextView
                    android:id="@+id/not_recieved_txt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left|center_horizontal"
                    android:layout_marginLeft="0dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="8dp"
                    android:text="@string/otp_not_recieved_txt"
                    android:textColor="@color/print_unselected_text_color"
                    android:textSize="15sp"
                    android:textStyle="bold" />


                <TextView
                    android:id="@+id/resend_otp_via_sms_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:layout_marginLeft="0dp"
                    android:layout_marginTop="10dp"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/platinum_color"
                    android:layout_gravity="left"
                    android:text="@string/resend_otp_via_sms_txt" />


            </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:layout_marginTop="15dp">

                <Button
                    android:id="@+id/btnCancel"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cancel"
                    android:textAllCaps="false"
                    android:textColor="@color/ColorPrimaryDark"
                    android:visibility="visible"/>


                <Button
                    android:id="@+id/btnOk"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/send_otp"
                    android:textAllCaps="false"
                    android:textColor="@color/ColorPrimaryDark" />


            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>