<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="@dimen/dimen_10dp"
    android:layout_marginHorizontal="40dp"
    app:cardBackgroundColor="@color/bg_card_view_color"
    android:layout_marginBottom="60dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen_15dp"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:paddingVertical="@dimen/tv_size_20"
            android:textSize="@dimen/tv_size_18"
            android:text="@string/call_recording_error"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"/>
        <Button
            android:id="@+id/tv_ok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textSize="@dimen/tv_size_16"
            android:layout_gravity="center_horizontal"
            android:paddingHorizontal="@dimen/dimen_50dp"
            android:paddingVertical="@dimen/tv_size_10"
            android:textColor="@color/white"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:background="@drawable/button_bg"
            android:layout_marginTop="@dimen/dimen_5dp"
            android:text="@string/ok"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>