<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutCallParent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ImageView
        android:id="@+id/ivAstrologerImage"
        android:layout_width="@dimen/dimen_0dp"
        android:layout_height="@dimen/dimen_0dp"
        android:src="@drawable/ic_astro_place_holder"
        android:background="@color/white"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <LinearLayout
        android:id="@+id/llUserProfile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="@dimen/dimen_35dp"
        android:layout_marginEnd="@dimen/dimen_16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_user_image"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="6dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/circle_orange"
            android:src="@drawable/ic_female"/>

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="@color/no_change_black"
            android:textSize="@dimen/tv_size_13"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/dimen_3dp"
            android:text="A user"
            android:paddingHorizontal="@dimen/dimen_10dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_white_rounded"
            android:backgroundTint="@color/no_change_white"/>

    </LinearLayout>
    


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/recharge_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/dimen_15dp"
        android:paddingHorizontal="@dimen/dimen_14dp"
        android:layout_marginHorizontal="@dimen/dimen_16dp"
        android:background="@drawable/bg_white_top_rounded_rect"
        app:layout_constraintBottom_toTopOf="@id/guideView"
        android:layout_marginBottom="@dimen/dimen_16dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/tv_low_bal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/tv_size_22"
            android:text="@string/low_balance_txt"
            android:textColor="@color/red1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tv_60_sec"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/call_ends_in_txt"
            android:textSize="@dimen/tv_size_18"
            app:layout_constraintTop_toBottomOf="@id/tv_low_bal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <Button
            android:id="@+id/btn_recharge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/recharge_now"
            android:textAllCaps="false"
            android:textSize="@dimen/tv_size_20"
            android:layout_marginStart="@dimen/dimen_10dp"
            android:background="@drawable/bg_button"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_60_sec"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/guideView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dimen_16dp"
        android:layout_marginBottom="40dp"
        android:visibility="visible"
        android:background="@drawable/bg_white_top_rounded_rect"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="16dp" >

        <View
            android:id="@+id/top_padding"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/margin_25dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/clInternetCallTVContainer"
            />

        <View
            android:id="@+id/paddingView"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            app:layout_constraintBottom_toTopOf="@id/consLayoutBottom"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clInternetCallTVContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:paddingBottom="@dimen/dimen_7dp"
        app:layout_constraintBottom_toTopOf="@+id/paddingView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAstrologerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:ellipsize="end"
            android:layout_marginHorizontal="@dimen/dimen_5dp"
            android:layout_marginTop="@dimen/dimen_7dp"
            android:textSize="@dimen/tv_size_28"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

        <TextView
            android:id="@+id/tv_call_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_5dp"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_20"
            android:layout_marginHorizontal="@dimen/dimen_5dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAstrologerName" />

        <LinearLayout
            android:id="@+id/linLyoutPoorConnection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="@dimen/dimen_6dp"
            android:paddingHorizontal="@dimen/dimen_10dp"
            android:paddingVertical="@dimen/dimen_5dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_call_duration"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/iv_signal_strength"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/ic_warning"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/dimen_5dp"/>

                <TextView
                    android:id="@+id/txtViewPoorConnection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/unstable_connection_warning"
                    android:textColor="@color/black"
                    android:textSize="@dimen/dimen_18sp"
                    android:layout_gravity="center_vertical"
                    android:visibility="visible"
                    />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/try_changing_your_location"
                android:textColor="@color/black"
                android:textSize="@dimen/dimen_18sp"
                android:visibility="visible"
                />

        </LinearLayout>

        <TextView
            android:id="@+id/remote_user_offline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/black"
            android:layout_margin="@dimen/tv_size_10"
            android:textSize="18sp"
            android:padding="@dimen/tv_size_10"
            android:textStyle="bold"
            android:text="@string/plz_wait_connt_your_voice_call"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/linLyoutPoorConnection"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/ivConnecting"
            android:layout_width="80dp"
            android:layout_height="25dp"
            android:src="@drawable/typing"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/linLyoutPoorConnection"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consLayoutBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:id="@+id/ivCallSpeaker"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:background="@drawable/bg_mute_call_background"
                android:padding="@dimen/dimen_10dp"
                android:src="@drawable/ic_speaker"
                android:visibility="visible"
                app:tint="@color/white"
                app:layout_constraintBottom_toBottomOf="@id/ivCallEnd"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@id/ivCallMic"
                app:layout_constraintTop_toTopOf="@id/ivCallEnd" />

            <ImageView
                android:id="@+id/ivCallMic"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:background="@drawable/bg_mute_call_background"
                android:foreground="?android:attr/selectableItemBackground"
                android:src="@drawable/btn_mute_audio"
                android:padding="@dimen/dimen_10dp"
                android:visibility="visible"
                android:layout_marginHorizontal="@dimen/margin_25dp"
                app:layout_constraintBottom_toBottomOf="@id/ivCallEnd"
                app:layout_constraintLeft_toRightOf="@id/ivCallSpeaker"
                app:layout_constraintRight_toLeftOf="@id/ivCallEnd"
                app:layout_constraintTop_toTopOf="@id/ivCallEnd"
                app:tint="@color/no_change_white" />

            <ImageView
                android:id="@+id/ivCallEnd"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_call_end"
                android:tint="@color/no_change_white"
                android:padding="@dimen/dimen_12dp"
                android:background="@drawable/bg_circle_red"
                android:visibility="visible"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="@dimen/dimen_20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@id/ivCallMic"
                app:layout_constraintRight_toRightOf="parent"
                />

            <ImageView
                android:id="@+id/call_again"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:src="@drawable/audio_call_icon"
                android:background="@drawable/bg_circle_green"
                android:tint="@color/no_change_white"
                android:visibility="gone"
                android:padding="@dimen/dimen_12dp"
                app:layout_constraintTop_toTopOf="@id/iv_cancel_call"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_chat_icon"/>
            <TextView
                android:id="@+id/tv_call_again"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/call_again"
                android:textColor="@color/black"
                android:layout_marginTop="10dp"
                android:textSize="@dimen/tv_size_12"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/call_again"
                app:layout_constraintStart_toStartOf="@id/call_again"
                app:layout_constraintEnd_toEndOf="@id/call_again"/>

            <ImageView
                android:id="@+id/iv_chat_icon"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:src="@drawable/icon_fc_chat"
                android:tint="@color/no_change_white"
                android:background="@drawable/circle_gray"
                android:padding="@dimen/dimen_8dp"
                android:scaleX="-1.0"
                android:layout_marginHorizontal="@dimen/margin_25dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="@+id/iv_cancel_call"
                app:layout_constraintStart_toEndOf="@id/call_again"
                app:layout_constraintEnd_toStartOf="@id/iv_cancel_call"/>

            <TextView
                android:id="@+id/tv_chat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chat"
                android:textColor="@color/black"
                android:layout_marginTop="10dp"
                android:textSize="@dimen/tv_size_12"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/iv_chat_icon"
                app:layout_constraintStart_toStartOf="@id/iv_chat_icon"
                app:layout_constraintEnd_toEndOf="@id/iv_chat_icon"/>

            <ImageView
                android:id="@+id/iv_cancel_call"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:background="@drawable/bg_circle_red"
                android:padding="7dp"
                android:src="@drawable/ic_close_black"
                android:tint="@color/no_change_white"
                android:layout_marginBottom="40dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_chat_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                />

            <TextView
                android:id="@+id/tv_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cancel"
                android:textColor="@color/black"
                android:layout_marginTop="10dp"
                android:textSize="@dimen/tv_size_12"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@+id/iv_cancel_call"
                app:layout_constraintStart_toStartOf="@id/iv_cancel_call"
                app:layout_constraintEnd_toEndOf="@id/iv_cancel_call"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <ListView
        android:id="@+id/audio_device_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="60dp"
        android:visibility="gone"
        android:background="@color/bg_card_view_color"
        app:layout_constraintBottom_toTopOf="@id/guideView"/>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="120dp"
        android:indeterminateTint="@color/colorPrimary_day_night"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="16dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/call_again_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/dimen_16dp"
        android:layout_marginBottom="40dp"
        android:visibility="gone"
        android:orientation="vertical"
        android:background="@drawable/bg_white_top_rounded_rect"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="16dp">

        <TextView
            android:id="@+id/tv_call_again_msg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textSize="@dimen/tv_size_21"
            android:text="@string/call_again_text"
            android:padding="@dimen/dimen_20dp"/>

        <Button
            android:id="@+id/btn_continue_call"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_20dp"
            android:layout_marginEnd="@dimen/dimen_20dp"
            android:layout_marginBottom="@dimen/dimen_20dp"
            android:text="@string/call_again"
            android:textSize="@dimen/tv_size_21"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/drawable_bg_orange"
            android:backgroundTint="@color/colorPrimary_day_night"
            app:layout_constraintTop_toBottomOf="@+id/txtViewAstrologerName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </LinearLayout>

    <View
        android:id="@+id/viewInternetCallBlackScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/no_change_black"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
