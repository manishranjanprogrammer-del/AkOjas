<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:elevation="7dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:descendantFocusability="beforeDescendants"
            android:focusableInTouchMode="true">


            <include
                android:id="@+id/appbarAppModule"
                layout="@layout/tool_bar_app_module"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true" />

            <!-- <LinearLayout
                 android:layout_width="fill_parent"
                 android:layout_height="wrap_content"

                 android:orientation="vertical">-->


            <com.ojassoft.astrosage.ui.customcontrols.CustomViewPager
                android:id="@+id/pager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/appbarAppModule"
                android:layout_above="@id/ask_question_layout"
                />
            <!-- </LinearLayout>-->

            <RelativeLayout
                android:id="@+id/ask_question_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/homeBottomNav"
                android:background="@color/white">

                <View
                    android:id="@+id/ask_layoutBorder"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_alignParentTop="true"
                    android:background="@drawable/shadow_gray_outline" />

                <com.ojassoft.astrosage.varta.utils.TypeWriter
                    android:id="@+id/tv_ask_que"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/dimen_20dp"
                    android:layout_marginEnd="@dimen/dimen_10dp"
                    android:layout_toStartOf="@+id/buttonSend"
                    android:layout_marginTop="@dimen/dimen_14dp"
                    android:layout_marginBottom="@dimen/dimen_14dp"
                    android:background="@drawable/circle_border_chat_input_box"
                    android:padding="12dp"
                    android:text="@string/ask_anything_to_kundli"
                    android:hint="@string/ask_anything_to_kundli"
                    android:textColorHint="@color/transparent"
                    android:textColor="@color/hint_text_color" />


                <RelativeLayout
                    android:id="@+id/buttonSend"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/circle_yellow"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:src="@drawable/icon_send"
                        app:tint="@color/white" />
                </RelativeLayout>

            </RelativeLayout>


            <LinearLayout
                android:id="@+id/advLayout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="vertical"
                android:visibility="gone"/>

            <include
                android:id="@+id/homeBottomNav"
                layout="@layout/custom_bottom_nav_with_gif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true" />

        </RelativeLayout>

        <ProgressBar
            android:id="@+id/progressbar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

    <fragment
        android:id="@+id/myDrawerFrag"
        android:name="com.ojassoft.astrosage.ui.fragments.HomeNavigationDrawerFragment"
        android:layout_width="309dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:layout="@layout/lay_home_navigation_drawer_fragment" />

</androidx.drawerlayout.widget.DrawerLayout>