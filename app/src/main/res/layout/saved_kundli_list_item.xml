<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_grey_outlined"
    android:clickable="true"
    android:focusable="true"
    android:id="@+id/clSavedKundli"
    android:layout_marginBottom="@dimen/dimen_3dp">

    <ImageView
        android:id="@+id/ivSavedKundli"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@drawable/ic_male"
        android:layout_margin="@dimen/dimen_8dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/tvSavedProfileSelected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selected profile"
        android:textColor="@color/Orangecolor"
        android:textSize="@dimen/dimen_12sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginRight="@dimen/dimen_10dp"
        android:layout_marginTop="@dimen/dimen_5dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvSavedKundliName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kunal Khurrana"
        android:textColor="@color/black"
        android:textSize="@dimen/dimen_16sp"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="@dimen/dimen_5dp"
        android:layout_marginStart="@dimen/dimen_10dp"
        app:layout_constraintLeft_toRightOf="@id/ivSavedKundli"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSavedKundliTime"/>

    <TextView
        android:id="@+id/tvSavedKundliTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kunal Khurrana"
        android:textSize="@dimen/tv_size_13"
        android:textColor="@color/text_day_gray_night_white"
        android:layout_marginBottom="@dimen/dimen_5dp"
        android:layout_marginStart="@dimen/dimen_10dp"
        app:layout_constraintLeft_toRightOf="@id/ivSavedKundli"
        app:layout_constraintTop_toBottomOf="@id/tvSavedKundliName"
        app:layout_constraintBottom_toTopOf="@id/tvSavedKundliPlace"/>

    <TextView
        android:id="@+id/tvSavedKundliPlace"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kunal Khurrana"
        android:textSize="@dimen/tv_size_13"
        android:textColor="@color/text_day_gray_night_white"
        android:layout_marginStart="@dimen/dimen_10dp"
        app:layout_constraintLeft_toRightOf="@id/ivSavedKundli"
        app:layout_constraintTop_toBottomOf="@id/tvSavedKundliTime"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>