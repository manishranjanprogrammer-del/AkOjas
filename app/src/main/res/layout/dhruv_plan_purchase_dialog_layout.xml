<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="10dp"
    app:cardBackgroundColor="@color/bg_card_view_color">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.ojassoft.astrosage.varta.customwidgets.TopCropImageView
            android:id="@+id/img_dhruv_plan"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:layout_alignParentTop="true"
            android:src="@drawable/dhruv_plan_img" />

        <View
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:alpha="2"
            android:layout_alignBottom="@id/img_dhruv_plan"
            android:background="@drawable/card_view_color_shadow" />

        <TextView
            android:id="@+id/heading_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/img_dhruv_plan"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="@dimen/dimen_16dp"
            android:text="@string/get_more_ans_faster"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_25" />

        <TextView
            android:id="@+id/dhruvPlan_desc_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/heading_tv"
            android:layout_margin="@dimen/dimen_16dp"
            android:layout_marginVertical="@dimen/dimen_10dp"
            android:background="@drawable/rounded_rect_with_border"
            android:backgroundTint="@color/light_gray_day_night"
            android:gravity="center_horizontal"
            android:padding="@dimen/dimen_7dp"
            android:text="@string/free_question_limit_exceed_msg"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_16" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/dhruvPlan_desc_tv"
            android:orientation="horizontal">

            <Button
                android:id="@+id/cancel_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_16dp"
                android:layout_marginTop="@dimen/dimen_10dp"
                android:layout_marginEnd="@dimen/dimen_10dp"
                android:layout_marginBottom="@dimen/dimen_16dp"
                android:layout_weight="1"
                android:background="@drawable/rect_rounded_background"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/black"
                android:textSize="@dimen/tv_size_18" />

            <Button
                android:id="@+id/purchase_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dimen_10dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/dimen_16dp"
                android:layout_marginBottom="16dp"
                android:layout_weight="1"
                android:background="@drawable/orange_rect_with_round_corner"
                android:text="@string/purchase_now"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/tv_size_18" />
        </LinearLayout>
    </RelativeLayout>

</androidx.cardview.widget.CardView>