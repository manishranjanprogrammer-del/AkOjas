<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="20dp"
    android:paddingTop="5dp"
    android:layout_marginTop="15dp"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    android:layout_marginBottom="100dp"
    android:background="@drawable/drawable_reduce_corner">

    <ImageView
        android:id="@+id/button_close"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:padding="10dp"
        android:src="@drawable/ic_close_white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

    <ImageView
        android:id="@+id/button_play_pause"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:src="@drawable/ic_play"
        app:layout_constraintTop_toBottomOf="@+id/button_close"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginTop="-15dp"/>

    <TextView
        android:id="@+id/txtViewCallRecording"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/call_recording"
        android:textSize="15sp"
        android:textColor="@color/no_change_white"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@+id/button_play_pause"
        app:layout_constraintStart_toEndOf="@+id/button_play_pause"
        android:gravity="left|top"
        android:layout_marginTop="-3dp"
        />

    <TextView
        android:id="@+id/current_time_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="@color/no_change_white"
        android:textSize="15sp"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toBottomOf="@+id/button_play_pause"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="15dp"/>

    <TextView
        android:id="@+id/total_time_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="15sp"
        android:textColor="@color/no_change_white"
        app:layout_constraintTop_toBottomOf="@+id/button_play_pause"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="15dp"/>

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:thumbTint="@color/yellow_seekbar"
        android:progressTint="@color/yellow_seekbar"
        app:layout_constraintTop_toBottomOf="@+id/current_time_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp"
        android:layout_marginStart="3dp"
        />

    <ImageView
        android:id="@+id/loader_image"
        android:layout_width="30dp"
        android:layout_height="10dp"
        app:layout_constraintTop_toTopOf="@id/current_time_text"
        app:layout_constraintStart_toEndOf="@id/current_time_text"
        app:layout_constraintEnd_toStartOf="@id/total_time_text"
        android:src="@drawable/loader"/>

</androidx.constraintlayout.widget.ConstraintLayout>