<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/white_rounded_rectangle"
    android:padding="@dimen/dimen_20dp">

    <TextView
        android:id="@+id/tvNoLiveAstro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/no_astrologer_is_live"
        android:textSize="@dimen/tv_size_18"
        android:textColor="@color/black"
        android:layout_marginBottom="@dimen/dimen_20dp"/>

    <Button
        android:id="@+id/btnNoLiveAstro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvNoLiveAstro"
        android:layout_centerInParent="true"
        android:background="@drawable/bg_button_orange"
        android:padding="10dp"
        android:text="@string/show_all_online_astrologers"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="@dimen/tv_size_15" />

</RelativeLayout>