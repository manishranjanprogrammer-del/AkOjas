<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/reportItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:orientation="vertical"
    android:padding="10dp"
    android:gravity="center"
    android:background="@drawable/bg_report_item_unselected">

    <ImageView
        android:id="@+id/reportIcon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/icon_brihat_home"
        android:contentDescription="Report Icon" />

    <TextView
        android:id="@+id/reportTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rajyoga"
        android:textAlignment="center"
        android:gravity="center_horizontal"
        android:textSize="13sp"
        android:textColor="@color/black"
        android:layout_marginTop="5dp" />
</LinearLayout>
