<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="112dp"
    android:id="@+id/mainlayoutLL"
    android:layout_height="150dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginStart="5dp"
    android:layout_marginTop="5dp"
    android:background="@drawable/bg_gradient_orange">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
            android:id="@+id/ri_profile_img"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerInParent="true"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="@null"
            android:src="@drawable/ic_profile_view" />
        <ImageView
            android:id="@+id/online_offline_img"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="@dimen/dimen_10dp"
            android:padding="2dp"
            android:layout_marginStart="-12dp"
            app:layout_constraintTop_toTopOf="@+id/ri_profile_img"
            app:layout_constraintStart_toEndOf="@+id/ri_profile_img"
            android:src="@drawable/green"/>

        <TextView
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/text_live"
            android:textStyle="bold"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:textAllCaps="true"
            android:layout_width="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="wrap_content"
            android:textColor="@color/color_red"
            android:layout_margin="@dimen/dimen_8dp"
            android:textSize="@dimen/font_mediumSmall"
            android:background="@drawable/bg_button_white_color"
            android:backgroundTint="@color/no_change_white"/>

        <TextView
            android:paddingTop="@dimen/dimen_4dp"
            android:gravity="center"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:id="@+id/astroTitleTV"
            android:layout_marginStart="@dimen/dimen_8dp"
            android:layout_marginEnd="@dimen/dimen_8dp"
            app:layout_constraintTop_toBottomOf="@+id/ri_profile_img"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="@dimen/tv_size_17"/>
        <TextView
            android:id="@+id/expertiseNameTV"
            style="@style/content_textview_live"
            android:maxLines="2"
            android:layout_gravity="left|top"
            android:gravity="left|top"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginRight="3dp"
            android:textSize="@dimen/tv_size_15" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>