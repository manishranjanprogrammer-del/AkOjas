<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="12dp">

        <TextView
            android:id="@+id/notification_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_height"
            android:minHeight="@dimen/min_height"
            android:text="@string/horoscope_notification_title"
            android:textColor="@color/black"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/textViewHeading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/min_height"
        android:minHeight="@dimen/min_height"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"
        android:text="@string/horoscope_heading"
        android:textColor="@color/black"
        android:textSize="@dimen/body_text_size" />

    <RadioGroup
        android:id="@+id/radioGroupHoroscope"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="24dp">

        <RadioButton
            android:id="@+id/radioYes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:minWidth="@dimen/min_height"
            android:minHeight="@dimen/min_height"
            android:paddingLeft="16dp"
            android:text="@string/yes"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="@dimen/body_text_size"
            android:theme="@style/MyCheckBox" />

        <RadioButton

            android:id="@+id/radioNo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/min_height"
            android:minHeight="@dimen/min_height"
            android:paddingLeft="16dp"
            android:text="@string/no"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="@dimen/body_text_size"
            android:theme="@style/MyCheckBox" />
    </RadioGroup>

    <LinearLayout
        android:id="@+id/layoutRasi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvChooseRashi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pleaseChooseSign"
            android:textColor="@color/black"

            android:textSize="@dimen/body_text_size" />

        <Spinner
            android:id="@+id/spRashiName"
            style="@style/Base.Widget.AppCompat.Spinner.Underlined"
            android:theme="@style/ActionBarThemeOverlay"
            android:layout_width="match_parent"
           
            android:layout_height="@dimen/custom_btn_height"
            android:layout_marginTop="16dp" />

        <!--  <Spinner
              android:id="@+id/spRashiName"

              android:layout_width="match_parent"
              android:layout_height="@dimen/custom_btn_height"

              android:dropDownWidth="wrap_content"
              android:spinnerMode="dropdown" />-->
        <!-- style="@style/Widget.AppCompat.Spinner.Underlined"-->
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="right"
        android:paddingRight="8dp">

        <Button
            android:id="@+id/butChooseCancel"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no"
            android:textAllCaps="false"
            android:textColor="@color/ColorPrimaryDark" />


        <Button
            android:id="@+id/butCooseOk"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/yes"
            android:textAllCaps="false"
            android:textColor="@color/ColorPrimaryDark" />
    </LinearLayout>

</LinearLayout>