<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:elevation="7dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            android:id="@+id/appbarAppModule"
            layout="@layout/tool_bar_app_module"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="vertical"
            android:paddingTop="@dimen/activity_vertical_margin">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_large"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="124dip"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/newAppoinmentLL"
                        android:layout_width="100dip"
                        android:layout_height="104dip"
                        android:background="@drawable/bg_dotted_blue"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="76dip"
                            android:layout_height="76dip"
                            android:padding="@dimen/activity_vertical_margin"
                            android:scaleType="fitCenter"
                            android:src="@drawable/new_appointment" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/newAppoinmentTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:gravity="center_horizontal"
                        android:text="@string/new_appointment"
                        android:textColor="@color/text_color"
                        android:textSize="@dimen/font_medium" />
                </LinearLayout>

                <Space
                    android:layout_width="36dip"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="124dip"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/myAppoinmentLL"
                        android:layout_width="100dip"
                        android:layout_height="104dip"
                        android:background="@drawable/bg_dotted_purple"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="76dip"
                            android:layout_height="76dip"
                            android:padding="@dimen/activity_vertical_margin"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_my_appointment" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/myAppoinmentTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:gravity="center_horizontal"
                        android:text="@string/appointment_today"
                        android:textColor="@color/text_color"
                        android:textSize="@dimen/font_medium" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_xlarge"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="124dip"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/reqVartaLL"
                        android:layout_width="100dip"
                        android:layout_height="104dip"
                        android:background="@drawable/bg_dotted_purple"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="76dip"
                            android:layout_height="76dip"
                            android:padding="@dimen/activity_vertical_margin"
                            android:scaleType="fitCenter"
                            android:src="@drawable/icon_varta" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/reqVartaTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:gravity="center_horizontal"
                        android:text="@string/req_varta"
                        android:textColor="@color/text_color"
                        android:textSize="@dimen/font_medium" />
                </LinearLayout>

                <Space
                    android:layout_width="44dip"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="124dip"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/custFooterLL"
                        android:layout_width="100dip"
                        android:layout_height="104dip"
                        android:background="@drawable/bg_dotted_orange"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="76dip"
                            android:layout_height="76dip"
                            android:padding="@dimen/activity_vertical_margin"
                            android:scaleType="fitCenter"
                            android:src="@drawable/cust_footer" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/custFooterTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_medium"
                        android:gravity="center_horizontal"
                        android:text="@string/cust_footer_details"
                        android:textColor="@color/text_color"
                        android:textSize="@dimen/font_medium" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <fragment
        android:id="@+id/myDrawerFrag"
        android:name="com.ojassoft.astrosage.ui.fragments.HomeNavigationDrawerFragment"
        android:layout_width="309dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:layout="@layout/lay_home_navigation_drawer_fragment" />

</androidx.drawerlayout.widget.DrawerLayout>