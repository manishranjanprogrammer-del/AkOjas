<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingBottom="0dp"
    android:background="@color/backgroundColor"
    android:clipToPadding="false">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_above="@+id/btnSilverPlan"
        android:layout_alignParentTop="true"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/Astrofeatureheading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorPrimary_day_night"
                android:padding="@dimen/cardview_keyline_1_minus_8dp"
                android:singleLine="true"
                android:text="@string/ad_astrologiacl_feature"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/Astrofeaturesubheading"
                style="@style/content_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/Astrofeatureheading"
                android:background="@color/backgroundColorView"
                android:maxLines="2"
                android:padding="@dimen/activity_vertical_margin"
                android:text="@string/ad_complete_experiance_gold"
                android:textColor="@color/black" />


            <!--  <LinearLayout
                  android:id="@+id/card_view_feature"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:layout_below="@id/Astrofeaturesubheading"
                  android:paddingBottom="@dimen/activity_vertical_margin">-->

            <LinearLayout
                android:id="@+id/llPlanCointainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/Astrofeaturesubheading"
                android:orientation="vertical"
                android:paddingBottom="@dimen/activity_vertical_margin"></LinearLayout>

            <!--  </LinearLayout>-->

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSilverPlan"
        style="@style/buttonstyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/extra_space"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        android:textColor="@color/white"
        android:backgroundTint="@color/colorPrimary_day_night"
        android:text="@string/rupees_for_silver_plan"
        android:theme="@style/buttonstyle" />
    <View
        android:id="@+id/extra_space"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_margin_for_kundli"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>