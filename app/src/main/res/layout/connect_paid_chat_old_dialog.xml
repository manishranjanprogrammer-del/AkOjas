<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="@dimen/dimen_10dp"
    android:background="@drawable/bg_dialog"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/ivCPCClose"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_gravity="end"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="7dp"
        android:padding="5dp"
        android:src="@drawable/ic_close_circle_grey600_24dp" />

    <TextView
        android:id="@+id/tvCPCText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/continue_this_chat_with_expert_insights_free"
        android:textColor="@color/black"
        android:textSize="@dimen/tv_size_20" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnCPCNo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_border_orange_less_corner"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingHorizontal="5dp"
            android:stateListAnimator="@null"
            android:text="@string/no"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_15" />

        <Button
            android:id="@+id/btnCPCYes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_yellow_less_round"
            android:backgroundTint="@color/colorPrimary_day_night"
            android:paddingHorizontal="5dp"
            android:stateListAnimator="@null"
            android:text="@string/yes"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/tv_size_15" />
    </LinearLayout>

</LinearLayout>