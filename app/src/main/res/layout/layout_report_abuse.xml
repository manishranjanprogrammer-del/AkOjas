<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_translucent_rounded_corner"
        android:backgroundTint="@color/dark_gray"
        android:paddingBottom="@dimen/dimen_20dp">

        <ImageView
            android:id="@+id/closeAbuse"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="@dimen/dimen_10dp"
            android:background="?attr/selectableItemBackground"
            android:src="@drawable/ic_sdk_close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/orange_color" />

        <TextView
            android:id="@+id/top_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/report_abuse"
            android:textColor="@color/no_change_white"
            android:textSize="@dimen/font_title"
            android:textStyle="bold"
            android:layout_marginEnd="@dimen/dimen_20dp"
            android:layout_marginStart="@dimen/dimen_20dp"
            android:textAlignment="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/closeAbuse" />
        <LinearLayout
            android:id="@+id/ll_radio_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/top_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radio_button_1"
                style="@style/radio_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/no_change_white"
                android:text="@string/abuse_report_1" />

            <FrameLayout
                android:id="@+id/fr_input_concern_1"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:visibility="gone"
                android:layout_marginStart="@dimen/dimen_50dp"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:layout_marginEnd="@dimen/dimen_50dp"
                android:background="@drawable/bg_border_orange_2px">

                <EditText
                    android:id="@+id/etConcern_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/enter_your_concern"
                    android:padding="@dimen/dimen_10dp"
                    android:textColor="#A6AAB3"
                    android:textColorHint="#A6AAB3"
                    android:textSize="14sp"

                    />
            </FrameLayout>



            <RadioButton
                android:id="@+id/radio_button_2"
                style="@style/radio_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/no_change_white"
                android:text="@string/abuse_report_2" />

            <FrameLayout
                android:id="@+id/fr_input_concern_2"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:visibility="gone"
                android:layout_marginStart="@dimen/dimen_50dp"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:layout_marginEnd="@dimen/dimen_50dp"
                android:background="@drawable/bg_border_orange_2px"
                >

                <EditText
                    android:id="@+id/etConcern_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/enter_your_concern"
                    android:padding="@dimen/dimen_10dp"
                    android:textColor="#A6AAB3"
                    android:textColorHint="#A6AAB3"
                    android:textSize="14sp"

                    />
            </FrameLayout>

            <RadioButton
                android:id="@+id/radio_button_3"
                style="@style/radio_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/no_change_white"
                android:text="@string/abuse_report_3" />

            <FrameLayout
                android:id="@+id/fr_input_concern_3"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:visibility="gone"
                android:layout_marginStart="@dimen/dimen_50dp"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:layout_marginEnd="@dimen/dimen_50dp"
                android:background="@drawable/bg_border_orange_2px"
                >
                <EditText
                    android:id="@+id/etConcern_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/enter_your_concern"
                    android:padding="@dimen/dimen_10dp"
                    android:textColor="#A6AAB3"
                    android:textColorHint="#A6AAB3"
                    android:textSize="14sp"

                    />
            </FrameLayout>

            <RadioButton
                android:id="@+id/radio_button_5"
                style="@style/radio_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/no_change_white"
                android:text="@string/abuse_report_5" />

            <FrameLayout
                android:id="@+id/fr_input_concern_5"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:visibility="gone"
                android:layout_marginStart="@dimen/dimen_50dp"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:layout_marginEnd="@dimen/dimen_50dp"
                android:background="@drawable/bg_border_orange_2px"
                >
                <EditText
                    android:id="@+id/etConcern_5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/enter_your_concern"
                    android:padding="@dimen/dimen_10dp"
                    android:textColor="#A6AAB3"
                    android:textColorHint="#A6AAB3"
                    android:textSize="14sp"

                    />
            </FrameLayout>

            <RadioButton
                android:id="@+id/radio_button_4"
                style="@style/radio_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/no_change_white"
                android:text="@string/abuse_report_4" />

            <FrameLayout
                android:id="@+id/fr_input_concern_4"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:visibility="gone"
                android:layout_marginStart="@dimen/dimen_50dp"
                android:layout_marginTop="@dimen/dimen_15dp"
                android:layout_marginEnd="@dimen/dimen_50dp"
                android:background="@drawable/bg_border_orange_2px"
                >
                <EditText
                    android:id="@+id/etConcern_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/enter_your_concern"
                    android:padding="@dimen/dimen_10dp"
                    android:textColor="#A6AAB3"
                    android:textColorHint="#A6AAB3"
                    android:textSize="14sp"

                    />
            </FrameLayout>

        </LinearLayout>

        <Button
            android:id="@+id/submit_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_gray"
            android:paddingLeft="@dimen/margin_xXlarge"
            android:paddingRight="@dimen/margin_xXlarge"
            android:stateListAnimator="@null"
            android:text="@string/submit"
            android:textAllCaps="false"
            android:textColor="@color/no_change_black"
            android:textSize="@dimen/tv_size_18"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.497"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_radio_group" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</RelativeLayout>