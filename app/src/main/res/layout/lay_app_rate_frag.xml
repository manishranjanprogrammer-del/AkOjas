<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/padding_outer">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:scaleType="fitXY"
        android:src="@drawable/popup_top" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#f7f7f7"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="10dp">

        <TextView
            android:id="@+id/textViewHeading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:singleLine="true"
            android:text="Title"
            android:textColor="@color/ColorPrimaryDark"
            android:textSize="@dimen/yohonews_heading"
            />
        <!-- android:text="@string/app_rater_mainheading_text" -->

        <TextView
            android:id="@+id/textViewsubheading"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="5dp"
            android:textColor="#a3a2a2"
            android:textSize="@dimen/yohonews_child_heading" />
        <!-- android:textColor="#a3a2a2"android:text="@string/app_rater_subheading_text" -->

        <TextView
            android:id="@+id/textViewsubchildheading"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="5dp"
            android:textColor="#a3a2a2"
            android:textSize="@dimen/yohonews_child_heading"
            android:textStyle="italic" />
        <!-- android:textColor="#a3a2a2"android:text="@string/app_rater_subchild_text" -->
    </LinearLayout>

    <LinearLayout
        android:id="@+id/starshow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white">

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="1.0"
            android:rating="1"
            android:indeterminate="false"
            android:paddingTop="8dp"
            android:layout_gravity="center"/>

      <!--  <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#f7f7f7"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="8dp"
            android:paddingTop="8dp">

            <ImageView
                android:layout_width="@dimen/image_width_hight"
                android:layout_height="@dimen/image_width_hight"
                android:src="@drawable/star" />

            <ImageView
                android:layout_width="@dimen/image_width_hight"
                android:layout_height="@dimen/image_width_hight"
                android:src="@drawable/star" />

            <ImageView
