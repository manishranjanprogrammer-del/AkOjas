<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainlayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_card_view_color"
    android:layout_marginLeft="5dp"
    android:layout_marginRight="5dp"
    android:layout_marginTop="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical">

        <com.ojassoft.astrosage.varta.utils.CircularNetworkImageView
            android:id="@+id/ri_profile_img"
            android:layout_width="@dimen/tv_size_50"
            android:layout_height="@dimen/tv_size_50"
            android:layout_centerInParent="true"
            android:contentDescription="@null"
            android:src="@drawable/ic_profile_view" />

        <TextView
            android:id="@+id/astrologer_name_txt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_marginLeft="10dp"
            android:text="Astro Guru Mragaank"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_18">

        </TextView>


    </LinearLayout>

</LinearLayout>
