<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <include
            android:id="@+id/appbarAppModule"
            layout="@layout/tool_bar_app_module"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true" />

        <androidx.cardview.widget.CardView
            android:id="@+id/card_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            card_view:cardElevation="5dp"
            card_view:cardBackgroundColor="@color/cardview_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">


                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColorHint="@color/text_day_gray_night_white">

                    <EditText
                        android:id="@+id/etUseremail"
                        style="@style/Theme.App.Base"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/colorPrimary_day_night"
                        android:capitalize="sentences"
                        android:contentDescription="@string/services_email"
                        android:hint="@string/services_email"
                        android:inputType="textCapWords"
                        android:textColor="@color/black"
                        android:maxLength="70" />
                    <!-- android:inputType="textNoSuggestions"-->
                </com.google.android.material.textfield.TextInputLayout>


                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_mobno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColorHint="@color/text_day_gray_night_white">

                    <EditText
                        android:id="@+id/etUsermobno"
                        style="@style/Theme.App.Base"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/colorPrimary_day_night"
                        android:capitalize="sentences"
                        android:contentDescription="@string/phonenumber"
                        android:digits="1234567890"
                        android:hint="@string/phonenumber"
                        android:imeOptions="actionNext"
                        android:inputType="number"
                        android:textColor="@color/black"
                        android:maxLength="15" />
                    <!-- android:inputType="textNoSuggestions"-->
                </com.google.android.material.textfield.TextInputLayout>


                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_question"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColorHint="@color/text_day_gray_night_white">

                    <EditText
                        android:id="@+id/etUserquestion"
                        style="@style/Theme.App.Base"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/colorPrimary_day_night"
                        android:capitalize="sentences"
                        android:contentDescription="@string/astrologer_query"
                        android:gravity="top|left"
                        android:hint="@string/astrologer_query"
                        android:inputType="textMultiLine"
                        android:maxLength="500"
                        android:maxLines="50"
                        android:minLines="1"
                        android:textColor="@color/black"
                        android:singleLine="false" />
                    <!-- android:inputType="textNoSuggestions"-->
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/textquestiontextlimit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:clickable="true"
                    android:paddingStart="10dp"
                    android:textColor="@color/black"
                    android:text="@string/astro_shop_user_question" />


                <!-- <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:layout_marginTop="-10dp"
                     android:orientation="vertical">-->

                <TextView
                    android:id="@+id/tvLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="5dp"
                    android:text="@string/delivery_report_language_selection"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/ics_spinner_lang"
                    style="@style/Base.Widget.AppCompat.Spinner.Underlined"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="-8dp"
                    android:paddingStart="@dimen/dimen_8dp"
                    android:backgroundTint="@color/colorPrimary_day_night"
                    android:theme="@style/ActionBarThemeOverlay" />

                <!--</LinearLayout>-->

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <Button
            android:id="@+id/buy_now"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="30dp"
            android:layout_marginRight="10dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/astroshop_buy_now"
            android:textColor="@color/white"
            android:textSize="@dimen/abc_text_size_medium_material"
            android:textAllCaps="true"
            android:backgroundTint="@color/colorPrimary_day_night"/>
    </LinearLayout>
</ScrollView>