<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/ai_horoscope_blur"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:id="@+id/scrollView"
    android:visibility="visible"
    android:scrollbars="none">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consLayoutTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/dimen_20dp"
            android:paddingBottom="20dp"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/dimen_20dp">

            <!-- Header -->
            <RelativeLayout
                android:id="@+id/linLayoutHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="16dp"
                android:layout_marginHorizontal="@dimen/dimen_20dp"

                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toLeftOf="@+id/relativeLayoutProfile">

                    <TextView
                        android:id="@+id/greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/good_morning"
                        android:textColor="@color/black"
                        android:alpha="9"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <RelativeLayout
                    android:id="@+id/relativeLayoutProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true">
                    <ImageView
                        android:id="@+id/profile_icon"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:background="@drawable/circle_background"
                        android:contentDescription="Profile"
                        android:padding="@dimen/dimen_5dp"
                        android:src="@drawable/male_user"
                        android:layout_centerHorizontal="true"/>
                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:src="@drawable/ic_edit_circle"
                        android:layout_above="@+id/tvEditProfile"
                        android:layout_alignEnd="@+id/profile_icon"
                        />

                    <TextView
                        android:id="@+id/tvEditProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/edit_profile"
                        android:singleLine="true"
                        android:textColor="@color/black"
                        android:alpha="9"
                        android:textSize="@dimen/tv_size_11"
                        android:layout_below="@+id/profile_icon"/>

                </RelativeLayout>

            </RelativeLayout>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.StaggeredGridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/item_score"
                tools:itemCount="4"
                android:layout_marginHorizontal="@dimen/dimen_15dp"
                app:layout_constraintTop_toBottomOf="@+id/linLayoutHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"

                />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@+id/recyclerViewScore"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
            <!-- Horoscope Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewHoroscope"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card_view_color"
                app:cardCornerRadius="@dimen/dimen_7dp"
                app:cardElevation="@dimen/dimen_0dp"
                android:visibility="visible"
                android:layout_marginHorizontal="@dimen/dimen_20dp"
                >

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/dimen_16dp">

                    <TextView
                        android:id="@+id/horoscope_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_personalized_horoscope"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>



                    <TextView
                        android:id="@+id/horoscope_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="@dimen/dimen_10dp"
                        android:alpha="0.9"
                        android:ellipsize="end"
                        android:maxLines="12"
                        android:text=""                    android:textColor="@color/black"
                        android:textSize="16sp"
                        app:layout_constraintTop_toBottomOf="@id/horoscope_title"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <RelativeLayout
                        android:id="@+id/relLayReadMore"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@+id/horoscope_text"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="@dimen/dimen_5dp">
                        <!-- यह RelativeLayout सिर्फ "Read more" और एरो के लिए है -->
                        <TextView
                            android:id="@+id/read_more"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/read_more_ai"
                            android:textColor="@color/colorPrimary_day_night"
                            android:textSize="14sp" />
                        <ImageView
                            android:layout_width="@dimen/margin_25dp"
                            android:layout_height="@dimen/margin_25dp"
                            android:padding="@dimen/dimen_5dp"
                            android:src="@drawable/read_more_arrow"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/linLayoutCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="@dimen/dimen_20dp"
                app:layout_constraintTop_toBottomOf="@+id/recyclerViewScore"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:paddingBottom="20dp"
                android:visibility="visible">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewHoroscopeTodayForcast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_card_view_color"
                    app:cardCornerRadius="@dimen/dimen_7dp"
                    app:cardElevation="@dimen/dimen_0dp"
                    android:layout_marginTop="@dimen/dimen_5dp"
                    android:visibility="gone">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:clipToPadding="false">

                        <!-- Section Title -->
                        <TextView
                            android:id="@+id/tv_forecast_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/today_s_forecast"
                            android:textSize="18sp"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:paddingBottom="12dp"/>

                        <!-- Forecast Item -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_vibe_of_day"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:paddingBottom="4dp"/>

                            <TextView
                                android:id="@+id/tv_lucky_color"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:paddingBottom="4dp"/>

                            <TextView
                                android:id="@+id/tv_lucky_hour"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:paddingBottom="4dp"/>

                            <TextView
                                android:id="@+id/tv_energy_peak"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:paddingBottom="4dp"/>

                            <TextView
                                android:id="@+id/tv_energy_dip"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:paddingBottom="4dp"/>

                            <TextView
                                android:id="@+id/tv_best_activity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:paddingBottom="4dp"/>

                            <TextView
                                android:id="@+id/tv_stress_trigger"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="16sp"/>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/frameLayoutUnloackAIHoroscope"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            >

            <!-- Center Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="24dp"
                android:elevation="12dp"
                app:cardBackgroundColor="@color/bg_card_view_color"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_ai_lock"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/unlock_your_ai_horoscope"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/txtViewSetUpBirthProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="@dimen/tv_size_16"
                        android:layout_marginBottom="20dp"/>

                    <TextView
                        android:id="@+id/btnProceed"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/proceed"
                        android:textAlignment="center"
                        android:textSize="@dimen/dimen_18sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_yellow_less_round"
                        android:backgroundTint="@color/colorPrimary_day_night"
                        android:textColor="@color/white"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </FrameLayout>

    </RelativeLayout>



</ScrollView>
