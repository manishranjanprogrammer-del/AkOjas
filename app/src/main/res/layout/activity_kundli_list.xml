<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_popup_round_corner"
    tools:context=".varta.ui.activity.SavedKundliListActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rlSavedParentView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="@dimen/dimen_15dp"
            android:layout_height="@dimen/dimen_15dp"
            android:src="@drawable/ic_close_live"
            android:layout_marginTop="@dimen/dimen_5dp"
            android:layout_marginEnd="@dimen/dimen_5dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/black" />
        <LinearLayout
            android:id="@+id/create_kundli"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/min_button_height"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_button_choose_kundli"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginEnd="@dimen/dimen_20dp"
            android:paddingHorizontal="@dimen/margin_medium"
            app:layout_constraintTop_toTopOf="@id/tvKundliListMyProfile"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="22dip"
                android:layout_height="22dip"
                android:scaleType="fitCenter"
                android:src="@drawable/round_add_24"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvKundliListCreateKundli"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_small"
                android:gravity="center"
                android:maxLines="1"
                android:maxLength="10"
                android:ellipsize="end"
                android:minWidth="0dip"
                android:minHeight="0dip"
                android:text="@string/create_new"
                android:textColor="@color/white"
                android:textSize="@dimen/tv_size_14" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvKundliListMyProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/create_kundli"
            android:layout_alignBottom="@id/create_kundli"
            android:layout_alignParentLeft="true"
            android:gravity="center_vertical"
            android:text="@string/my_profile"
            android:maxWidth="200dp"
            android:ellipsize="end"
            android:textColor="@color/black"
            android:textSize="@dimen/tv_size_20"
            android:layout_marginStart="@dimen/dimen_20dp"
            android:layout_marginTop="30dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvKundliList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/create_kundli"
            android:layout_marginTop="@dimen/dimen_20dp"
            android:nestedScrollingEnabled="false"
            android:layout_marginHorizontal="@dimen/dimen_20dp"
            app:layout_constraintBottom_toTopOf="@id/llShowAll"
            app:layout_constraintTop_toBottomOf="@id/create_kundli" />

        <LinearLayout
            android:id="@+id/llShowAll"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/min_button_height"
            android:layout_below="@id/rvKundliList"
            android:layout_centerHorizontal="true"
            android:layout_gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingLeft="@dimen/margin_medium"
            android:paddingRight="@dimen/margin_medium"
            android:visibility="visible"
            android:layout_marginBottom="@dimen/dimen_15dp"
            app:layout_constraintBottom_toTopOf="@id/cancel_layout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tvKundliListShowAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_small"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/show_all_profile"
                android:textColor="@color/colorPrimary_day_night"
                android:textSize="@dimen/tv_size_16" />

            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:rotation="90"
                android:scaleType="fitCenter"
                android:src="@drawable/chevron_right_rounded"
                app:tint="@color/colorPrimary_day_night" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cancel_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/llShowAll"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/dimen_20dp"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:weightSum="2"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/llKundliListCancel"
                android:layout_width="0dp"
                android:layout_height="@dimen/min_button_height"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingLeft="@dimen/margin_medium"
                android:paddingRight="@dimen/margin_medium">

                <TextView
                    android:id="@+id/tvKundliListCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/margin_small"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="@string/cancel"
                    android:textColor="@color/colorPrimary_day_night"
                    android:textSize="@dimen/tv_size_16" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/llKundliListSkip"
                android:layout_width="0dp"
                android:layout_height="@dimen/min_button_height"
                android:layout_weight="1"
                android:layout_toRightOf="@id/llKundliListCancel"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingLeft="@dimen/margin_medium"
                android:paddingRight="@dimen/margin_medium">

                <TextView
                    android:id="@+id/tvKundliListSkip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/margin_small"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="@string/skip"
                    android:textColor="@color/colorPrimary_day_night"
                    android:textSize="@dimen/tv_size_16" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>