<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="16dp">

        <TextView
            android:padding="1dp"
            android:id="@+id/textViewHeading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/choose_calendar_type"
            android:textColor="@color/black"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="350dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/india_map" />

            <RadioGroup
                android:visibility="gone"
                android:id="@+id/radioGroupLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|right"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"
                android:layout_marginTop="24dp">

                <RadioButton
                    android:id="@+id/radioAmmanth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:paddingLeft="16dp"
                    android:text="@string/amanta"
                    android:textColor="@color/black"
                    android:textSize="@dimen/body_text_size"
                    android:theme="@style/MyCheckBox" />

                <RadioButton
                    android:id="@+id/radioPurnimant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingLeft="16dp"
                    android:text="@string/purnimant"
                    android:textColor="@color/black"
                    android:textSize="@dimen/body_text_size"
                    android:theme="@style/MyCheckBox" />

            </RadioGroup>
            <!-- <RadioGroup
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 android:layout_marginLeft="8dp"
                 android:layout_marginRight="8dp"
                 android:gravity="center"
                 android:orientation="horizontal">

                 <RadioButton
                     android:id="@+id/radioAmmanth"
                     android:layout_width="0dp"
                     android:layout_height="@dimen/custom_btn_height"
                     android:layout_weight="1"
                     android:background="@drawable/rbtn_selector"
                     android:button="@null"
                     android:checked="true"
                     android:gravity="center"
                     android:text="@string/amanta"
                     android:textColor="@drawable/rbtn_textcolor_selector"
                     android:textSize="@dimen/input_screen_text_size" />

                 <RadioButton
                     android:id="@+id/radioPurnimant"
                     android:layout_width="0dp"
                     android:layout_height="@dimen/custom_btn_height"
                     android:layout_weight="1"
                     android:background="@drawable/rbtn_selector"
                     android:button="@null"
                     android:gravity="center"
                     android:text="@string/purnimant"
                     android:textColor="@drawable/rbtn_textcolor_selector"
                     android:textSize="@dimen/input_screen_text_size" />
             </RadioGroup>-->


        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="right">

            <Button
                android:id="@+id/cancel_btn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/change_month_type"
                android:textAllCaps="false"
                android:textColor="@color/ColorPrimaryDark" />


            <Button
                android:id="@+id/ok_btn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ok"
                android:textAllCaps="false"
                android:textColor="@color/ColorPrimaryDark" />


        </LinearLayout>
    </LinearLayout>
</LinearLayout>