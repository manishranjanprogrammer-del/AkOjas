<?xml version="1.0" encoding="utf-8"?>


<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include
        android:id="@+id/appbarAppModule"
        layout="@layout/tool_bar_app_module"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <TextView
        android:id="@+id/watermark"
        android:layout_width="wrap_content"
        android:layout_centerInParent="true"
        android:paddingTop="@dimen/cardview_keyline_1_minus_8dp"
        android:layout_height="wrap_content"
        android:alpha="0.7"
        android:text="@string/no_orders_or_transection_found"
        android:textSize="18sp"
        android:visibility="gone"
        android:textColor="@color/black"
        />


    <androidx.core.widget.NestedScrollView
        android:layout_below="@+id/appbarAppModule"
        android:id="@+id/nScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="wrap_content">

    <TextView
        android:layout_below="@id/appbarAppModule"
        android:id="@+id/text_title"
        android:layout_width="match_parent"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="@dimen/cardview_keyline_1_minus_8dp"
        android:layout_height="wrap_content"
        android:text="@string/note_these_orders_do_not_include_orders_from_older_app_version_and_website"
        android:textSize="16sp"
        android:visibility="gone"
        android:textColor="@color/black"
         />



    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/my_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/text_title"
        android:layout_margin="8dp"
        android:background="@color/light_grey"
        android:drawSelectorOnTop="true"
        android:horizontalSpacing="0dp"
        android:verticalSpacing="0dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>