<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_one_half_transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvIntroSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/skip"
            android:textColor="@color/no_change_white"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_margin="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="80dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivIntro1"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="5dp"
                android:src="@drawable/circle_orange"
                android:background="@drawable/circle_border" />
            <ImageView
                android:id="@+id/ivIntro2"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="5dp"
                android:background="@drawable/circle_border" />
            <ImageView
                android:id="@+id/ivIntro3"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="5dp"
                android:background="@drawable/circle_border" />
            <ImageView
                android:id="@+id/ivIntro4"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="5dp"
                android:background="@drawable/circle_border" />
            <ImageView
                android:id="@+id/ivIntro5"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="5dp"
                android:background="@drawable/circle_border" />
            <ImageView
                android:id="@+id/ivIntro6"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="5dp"
                android:background="@drawable/circle_border" />
        </LinearLayout>

        <View
            android:id="@+id/viewDecoy"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            app:layout_constraintBottom_toTopOf="@id/clIntroMiddle"/>

        <LinearLayout
            android:id="@+id/llIntroReport"
            android:layout_width="280dp"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginRight="70dp"
            android:background="@drawable/callout_right"
            android:visibility="invisible"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@id/viewDecoy">

            <TextView
                android:id="@+id/tvReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:text="@string/report_inappropriate_behaviour"
                android:layout_marginEnd="20dp"
                android:textColor="@color/no_change_black"/>

            <ImageView
                android:id="@+id/ivIntroReportNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/circle_orange"
                android:src="@drawable/chevron_right_rounded"
                app:tint="@color/white"
                android:padding="5dp"
                android:layout_gravity="center"/>
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clIntroMiddle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@id/relSendMessage">

            <LinearLayout
                android:id="@+id/llIntroCall"
                android:layout_width="200dp"
                android:layout_height="80dp"
                android:paddingBottom="20dp"
                android:paddingHorizontal="20dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/callout_br"
                android:visibility="visible"
                app:layout_constraintBottom_toTopOf="@id/rlIntroCall"
                app:layout_constraintRight_toLeftOf="@id/llVertical">

                <TextView
                    android:id="@+id/tvCall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/call_astrologer"
                    android:layout_marginEnd="20dp"
                    android:textColor="@color/no_change_black"/>

                <ImageView
                    android:id="@+id/ivIntroCall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/circle_orange"
                    android:src="@drawable/chevron_right_rounded"
                    app:tint="@color/white"
                    android:padding="5dp"
                    android:layout_gravity="center"/>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/llIntroReport"
                android:layout_width="200dp"
                android:layout_height="80dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingVertical="10dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/callout_right"
                android:visibility="invisible"
                app:layout_constraintRight_toLeftOf="@id/llVertical"
                app:layout_constraintTop_toTopOf="@id/llVertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minLines="2"
                    android:text="@string/report_inappropriate_behaviour"
                    android:layout_marginEnd="20dp"
                    android:textColor="@color/no_change_black"/>

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/circle_orange"
                    android:src="@drawable/chevron_right_rounded"
                    app:tint="@color/white"
                    android:padding="5dp"
                    android:layout_gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llIntroAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/callout_right"
                android:visibility="invisible"
                app:layout_constraintRight_toLeftOf="@id/llVertical"
                app:layout_constraintTop_toBottomOf="@id/llIntroReport">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/done"
                    android:layout_marginEnd="20dp"
                    android:textColor="@color/no_change_black"/>

                <ImageView
                    android:id="@+id/ivIntroAudioNext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/circle_orange"
                    android:src="@drawable/chevron_right_rounded"
                    app:tint="@color/white"
                    android:layout_marginEnd="40dp"
                    android:padding="5dp"
                    android:layout_gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llIntroVideo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/callout_right"
                android:visibility="invisible"
                app:layout_constraintRight_toLeftOf="@id/llVertical"
                app:layout_constraintTop_toBottomOf="@id/llIntroAudio">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/done"
                    android:layout_marginEnd="20dp"
                    android:textColor="@color/no_change_black"/>

                <ImageView
                    android:id="@+id/ivIntroVideoNext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/circle_orange"
                    android:src="@drawable/chevron_right_rounded"
                    app:tint="@color/white"
                    android:layout_marginEnd="40dp"
                    android:padding="5dp"
                    android:layout_gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llIntroSpeaker"
                android:layout_width="250dp"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/callout_right"
                android:visibility="invisible"
                app:layout_constraintRight_toLeftOf="@id/llVertical"
                app:layout_constraintBottom_toTopOf="@id/rlIntroCall">

                <TextView
                    android:id="@+id/tvSpeaker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/off_speaker_phone"
                    android:layout_marginEnd="20dp"
                    android:textColor="@color/no_change_black"/>

                <ImageView
                    android:id="@+id/ivIntroSpeakerNext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/circle_orange"
                    android:src="@drawable/chevron_right_rounded"
                    app:tint="@color/white"
                    android:padding="5dp"
                    android:layout_gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llVertical"
                android:layout_width="@dimen/dimen_70dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                app:layout_constraintBottom_toTopOf="@+id/rlIntroCall"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/ivIntroReport"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/dimen_10dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:padding="@dimen/dimen_7dp"
                    android:scaleType="centerCrop"
                    android:visibility="invisible"
                    android:src="@drawable/abuse_report_72"
                    app:tint="@color/white"/>

                <ImageView
                    android:id="@+id/ivIntroAudio"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/dimen_10dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:padding="@dimen/dimen_10dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:src="@drawable/btn_mute_audio"
                    app:tint="@color/white"/>

                <ImageView
                    android:id="@+id/ivIntroVideo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/dimen_10dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:padding="@dimen/dimen_10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/btn_mute_video"
                    android:visibility="gone"
                    app:tint="@color/white"/>

                <ImageView
                    android:id="@+id/ivIntroSpeaker"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="@dimen/dimen_10dp"
                    android:background="@drawable/btn_mute_audio_background"
                    android:padding="@dimen/dimen_10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/btn_enable_speaker"
                    app:tint="@color/white"
                    android:visibility="invisible" />
            </LinearLayout>

            <RelativeLayout
                android:id="@+id/rlIntroCall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/dimen_20dp"
                android:layout_marginBottom="@dimen/dimen_20dp"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/ll_inner_call_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_border_live_call"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginLeft="18dp"
                        android:layout_marginRight="10dp"
                        android:gravity="center"
                        android:text="@string/call_now"
                        android:textColor="@color/white" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="18dp"
                        android:layout_marginRight="10dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvPriceToCross"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginRight="3dp"
                            android:singleLine="true"
                            android:text="₹56/Min"
                            android:textColor="@color/white"
                            android:textSize="@dimen/tv_size_12" />

                        <TextView
                            android:id="@+id/tvPriceToCall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:singleLine="true"
                            android:text="Price"
                            android:textColor="@color/white"
                            android:textSize="@dimen/tv_size_12" />

                    </LinearLayout>


                </LinearLayout>

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginLeft="6dp"
                    android:layout_marginTop="19dp"
                    android:src="@drawable/ic_call_live" />

            </RelativeLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/llIntroGift"
            android:layout_width="200dp"
            android:layout_height="80dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginEnd="15dp"
            android:background="@drawable/callout_br"
            android:visibility="invisible"
            app:layout_constraintBottom_toTopOf="@id/relSendMessage"
            app:layout_constraintRight_toRightOf="parent">

            <TextView
                android:id="@+id/tvGift"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/send_gifts"
                android:layout_marginEnd="20dp"
                android:textColor="@color/no_change_black"/>

            <ImageView
                android:id="@+id/ivIntroGiftNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/circle_orange"
                android:src="@drawable/chevron_right_rounded"
                app:tint="@color/white"
                android:padding="5dp"
                android:layout_gravity="center"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/llIntroSend"
            android:layout_width="230dp"
            android:layout_height="80dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="40dp"
            android:background="@drawable/callout_bl"
            android:visibility="invisible"
            app:layout_constraintBottom_toTopOf="@id/relSendMessage"
            app:layout_constraintLeft_toLeftOf="parent">

            <TextView
                android:id="@+id/tvSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/send_message"
                android:layout_marginEnd="20dp"
                android:textColor="@color/no_change_black"/>

            <TextView
                android:id="@+id/tvIntroDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_orange"
                android:textColor="@color/white"
                android:paddingHorizontal="20dp"
                android:paddingVertical="5dp"
                android:textAllCaps="false"
                android:gravity="center"
                android:text="@string/done"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/relSendMessage"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginStart="@dimen/dimen_16dp"
            android:layout_marginEnd="@dimen/dimen_16dp"
            android:layout_marginBottom="@dimen/dimen_10dp"
            android:background="@android:color/transparent"
            android:orientation="horizontal"
            android:padding="5dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/etIntroSend"
                    android:visibility="invisible"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/message_input_shape_live"
                    android:drawableEnd="@drawable/icon_send"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="10dp"
                    android:text="@string/write_comment"
                    android:textColor="@color/no_change_white"
                    android:textSize="@dimen/tv_size_14" />

                <ImageView
                    android:id="@+id/ivIntroGift"
                    android:layout_width="40dip"
                    android:layout_height="40dip"
                    android:layout_marginLeft="10dp"
                    android:scaleType="fitCenter"
                    android:padding="8dp"
                    android:visibility="invisible"
                    android:background="@drawable/btn_mute_audio_background"
                    android:src="@drawable/gift_icon"
                    app:tint="@color/white"
                    app:layout_constraintLeft_toRightOf="@+id/editTextMessage" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="@dimen/dimen_60dp"
            android:orientation="vertical"
            android:weightSum="1">

            <LinearLayout

                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="right|center"
                android:layout_weight="1"
                android:gravity="right|center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivIntroNext"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginRight="@dimen/dimen_16dp"
                    android:layout_marginBottom="@dimen/dimen_50dp"
                    android:background="@drawable/rounded_bg_full_transparent"
                    android:padding="@dimen/dimen_10dp"
                    android:rotation="180"
                    android:visibility="visible"
                    android:src="@drawable/btn_back_arrow" />


            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/llIntroNext"
            android:layout_width="200dp"
            android:layout_height="80dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginEnd="15dp"
            android:background="@drawable/callout_br"
            android:visibility="invisible"
            android:layout_marginBottom="40dp"
            app:layout_constraintBottom_toTopOf="@id/clIntroMiddle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent">

            <TextView
                android:id="@+id/tvNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/next_live_nastrologer"
                android:layout_marginEnd="20dp"
                android:minLines="2"
                android:textColor="@color/no_change_black"/>

            <ImageView
                android:id="@+id/ivIntroNNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/circle_orange"
                android:src="@drawable/chevron_right_rounded"
                app:tint="@color/white"
                android:padding="5dp"
                android:layout_gravity="center"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
