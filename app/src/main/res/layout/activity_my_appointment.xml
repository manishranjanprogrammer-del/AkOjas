<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <include
        android:id="@+id/appbarAppModule"
        layout="@layout/tool_bar_app_module"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="@dimen/margin_large"
        android:paddingTop="8dip"
        android:paddingRight="@dimen/margin_large">

        <Button
            android:id="@+id/btnNewApmt"
            style="@style/buttonstyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_purple"
            android:gravity="center"
            android:padding="@dimen/margin_medium"
            android:text="@string/new_appointmt_booking"
            android:textSize="@dimen/font_large" />

        <LinearLayout
            android:id="@+id/lineViewLL"
            android:layout_width="match_parent"
            android:layout_height="0.7dip"
            android:layout_marginLeft="@dimen/margin_mlarge"
            android:layout_marginTop="@dimen/margin_medium"
            android:layout_marginRight="@dimen/margin_mlarge"
            android:background="@color/colorBlack30"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="48dip"
                android:layout_height="48dip"
                android:background="@drawable/dot_circle_orange"
                android:padding="12dip"
                android:scaleType="fitCenter"
                android:src="@drawable/icon_calender_white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="12dip">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dip"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/apmtDateTV"
                        android:layout_width="0dip"
                        android:layout_height="40dip"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edit_text_my_apmt"
                        android:clickable="true"
                        android:gravity="center"
                        android:hint="@string/dd_mm_yyyy"
                        android:maxLines="1"
                        android:textColor="@color/black"
                        android:textColorHint="@color/text_day_gray_night_white"
                        android:textSize="@dimen/font_medium"
                        android:layout_marginRight="12dip"/>

                    <Button
                        android:id="@+id/btnShowApmt"
                        style="@style/buttonstyle"
                        android:layout_width="wrap_content"
                        android:layout_height="40dip"
                        android:layout_marginRight="@dimen/activity_vertical_margin"
                        android:background="@drawable/bg_button_blue"
                        android:gravity="center"
                        android:text="@string/btn_show"
                        android:textSize="@dimen/font_large" />
                </LinearLayout>

                <TextView
                    android:id="@+id/todayDateTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:text="@string/scheduled"
                    android:textColor="@color/black"
                    android:textSize="@dimen/font_large" />

                <TextView
                    android:id="@+id/noApmtTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:text="@string/no_apmt_booked"
                    android:textColor="@color/black_87"
                    android:textSize="@dimen/font_medium"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/myApmtRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none" />

            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/apmtRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:scrollbars="none" />

    </LinearLayout>
</LinearLayout>