<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/no_change_black"
    tools:context=".ui.act.FreeChatNowActivity">


        <ImageView
            android:id="@+id/imgViewBack"
            android:layout_width="@dimen/dimen_45dp"
            android:layout_height="@dimen/dimen_45dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:clickable="true"
            android:layout_marginTop="30dp"
            android:elevation="@dimen/dimen_10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/ic_back"
            app:tint="@color/no_change_white"
            android:focusable="true" />

        <View
            android:id="@+id/innerView"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:elevation="@dimen/dimen_10dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_astrologer_image"
            android:background="@drawable/black_trans_gradient" />
        <ImageView
            android:id="@+id/iv_astrologer_image"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scaleType="fitXY"
            android:src="@drawable/ic_ai_astrologer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/bottom_top_view"/>


            <LinearLayout
                android:id="@+id/bottom_top_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:paddingBottom="@dimen/dimen_10dp"
                app:layout_constraintBottom_toBottomOf="parent">
                <TextView
                    android:id="@+id/consult_premium_astrologers_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:layout_marginHorizontal="@dimen/dimen_10dp"
                    android:text="@string/consult_with_our_premium_ai_astrologer"
                    android:textColor="@color/text_color_black"
                    android:textSize="26sp"

                />
                <TextView
                    android:id="@+id/first_call_in_1rs_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dimen_10dp"
                    android:layout_marginVertical="@dimen/dimen_5dp"
                    android:gravity="center"
                    android:padding="8dp"

                    android:textColor="@color/text_color_black"
                    android:textSize="26sp"

                />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/dimen_5dp"
                    android:layout_marginBottom="45dp"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btnAiChatNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/drawable_bg_yellow"
                        android:backgroundTint="@color/colorPrimary"
                        android:layout_marginHorizontal="@dimen/dimen_10dp"
                        android:paddingHorizontal="@dimen/dimen_20dp"
                        android:layout_marginBottom="@dimen/dimen_10dp"
                        android:text="Free Chat Now"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:textColor="@color/no_change_black"
                        android:textSize="@dimen/dimen_22sp"
                        />

                    <Button
                        android:id="@+id/btnExit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/drawable_bg_exit"
                        android:layout_marginHorizontal="@dimen/dimen_10dp"
                        android:paddingHorizontal="25dp"
                        android:layout_marginBottom="@dimen/dimen_10dp"
                        android:text="Exit"
                        android:textColor="@color/exit_text_color"
                        android:textSize="18sp"
                        android:textAllCaps="false"
                        />
                </LinearLayout>

            </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

