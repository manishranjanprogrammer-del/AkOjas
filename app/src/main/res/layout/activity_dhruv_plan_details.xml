<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/appbarAppModule"
        layout="@layout/tool_bar_app_module"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_large"
        android:background="@drawable/bg_dialog"
        android:orientation="vertical"
        android:padding="@dimen/activity_vertical_margin">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="66dip"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/icon_bill_plan" />

            <TextView
                android:id="@+id/titleBillPlanTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginLeft="@dimen/activity_vertical_margin"
                android:layout_marginBottom="@dimen/margin_small"
                android:text="@string/bill_plan"
                android:textColor="@color/black"
                android:textSize="@dimen/font_xlarge" />
        </LinearLayout>

        <TextView
            android:id="@+id/monthlyTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/msg_monthly_pdf_count"
            android:textColor="@color/black_87"
            android:textSize="@dimen/font_medium" />

        <TextView
            android:id="@+id/topupTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/msg_topup_pdf_count"
            android:textColor="@color/black_87"
            android:textSize="@dimen/font_medium" />

        <TextView
            android:id="@+id/dhruvPlanTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:layout_marginBottom="@dimen/margin_small"
            android:text="@string/msg_dhruv_plan_expiry"
            android:textColor="@color/black_87"
            android:textSize="@dimen/font_medium" />
    </LinearLayout>
</LinearLayout>