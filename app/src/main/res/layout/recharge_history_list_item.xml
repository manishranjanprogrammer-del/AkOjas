<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"

    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/amount_tv"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_circle_border"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Rs. 120"
            android:textColor="@color/white"
            android:textSize="@dimen/tv_size_14" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/added_to_wallet_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/added_to_wallet"
                android:textColor="@color/black"
                android:maxLines="2"
                android:textSize="@dimen/tv_size_18" />


            <TextView
                android:id="@+id/recharge_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="22-07-2020 12:25PM"
                android:textColor="@color/hint_text_color"
                android:textSize="@dimen/tv_size_16" />

            <TextView
                android:id="@+id/order_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="djfjdhjf"
                android:layout_marginTop="4dp"
                android:textColor="@color/hint_text_color"
                android:textSize="@dimen/tv_size_16" />

        </LinearLayout>


    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="@color/separator_line" />
</LinearLayout>