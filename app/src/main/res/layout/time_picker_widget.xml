<?xml version="1.0" encoding="utf-8"?>


<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center_horizontal"
    android:gravity="center_vertical"
    android:layout_marginStart="@dimen/dimen_24dp"
    android:layout_marginEnd="@dimen/dimen_24dp"

    android:orientation="horizontal">


    <TextView
        android:id="@+id/tv_hrs"
        android:layout_width="@dimen/dimen_0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/hours"
        android:gravity="center"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:singleLine="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tv_minutes"
        android:textSize="@dimen/tv_size_12"/>

    <com.ojassoft.astrosage.utils.NumberPicker
        android:id="@+id/hour"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:focusable="true"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        app:layout_constraintTop_toBottomOf="@id/tv_hrs"
        app:layout_constraintStart_toStartOf="@id/tv_hrs"
        android:theme="@style/DefaultNumberPickerTheme"
        app:layout_constraintEnd_toEndOf="@+id/tv_hrs"
        android:focusableInTouchMode="true"
        />

    <TextView
        android:id="@+id/tv_minutes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/minutes"
        android:layout_weight="1"
        android:gravity="center"
        android:textStyle="bold"
        android:singleLine="true"
        android:textColor="@color/black"
        app:layout_constraintStart_toEndOf="@+id/tv_hrs"
        app:layout_constraintEnd_toStartOf="@+id/tv_second"
        app:layout_constraintTop_toTopOf="parent"
        android:textSize="@dimen/tv_size_12"/>

    <TextView
        android:id="@+id/tv_second"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/seconds_text"
        android:gravity="center"
        android:layout_weight="1"
        android:textColor="@color/black"
        android:singleLine="true"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/tv_minutes"
        app:layout_constraintEnd_toStartOf="@+id/tv_Blank"
        app:layout_constraintTop_toTopOf="parent"
        android:textSize="@dimen/tv_size_12"/>

    <TextView
        android:id="@+id/tv_Blank"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:gravity="center"
        android:layout_weight="1"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/tv_second"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:textColor="@color/black"
        android:textSize="@dimen/tv_size_12"/>





    <com.ojassoft.astrosage.utils.NumberPicker
        android:id="@+id/minute"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:focusable="true"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_minutes"
        app:layout_constraintStart_toStartOf="@id/tv_minutes"
        android:theme="@style/DefaultNumberPickerTheme"
        app:layout_constraintEnd_toEndOf="@+id/tv_minutes"
        android:focusableInTouchMode="true"
        />
    <com.ojassoft.astrosage.utils.NumberPicker
        android:id="@+id/seconds"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:focusable="true"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_second"
        app:layout_constraintStart_toStartOf="@id/tv_second"
        android:theme="@style/DefaultNumberPickerTheme"
        app:layout_constraintEnd_toEndOf="@+id/tv_second"
        android:focusableInTouchMode="true"
        />



    <com.ojassoft.astrosage.utils.NumberPicker
        android:id="@+id/am_pm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"
        android:theme="@style/DefaultNumberPickerTheme"
        app:layout_constraintTop_toTopOf="@id/seconds"
        app:layout_constraintStart_toStartOf="@id/tv_Blank"
        app:layout_constraintEnd_toEndOf="@+id/tv_Blank"
        app:layout_constraintBottom_toBottomOf="@id/seconds"
        />




</androidx.constraintlayout.widget.ConstraintLayout>

