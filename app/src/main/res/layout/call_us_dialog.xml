<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/transparent"
    android:paddingHorizontal="14dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        app:cardBackgroundColor="@color/bg_card_view_color"
        app:cardCornerRadius="@dimen/dimen_20dp"
        app:cardUseCompatPadding="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/iv_close_view"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="@dimen/dimen_8dp"
                android:clickable="true"
                android:elevation="@dimen/dimen_10dp"
                android:focusable="true"
                android:padding="6dp"
                android:src="@drawable/cross_grey"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/black" />


            <androidx.cardview.widget.CardView
                android:id="@+id/customer_support_img_layout"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/image_bg_color"
                app:cardCornerRadius="@dimen/dimen_60dp">

                <ImageView
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:layout_gravity="center"
                    android:src="@drawable/customer_care" />


            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/headign_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/customer_support_img_layout"
                android:layout_marginTop="@dimen/dimen_10dp"
                android:paddingHorizontal="@dimen/dimen_10dp"
                android:text="@string/we_are_here_for_you"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="32sp" />


            <TextView
                android:id="@+id/sub_headign_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/headign_tv"
                android:layout_marginTop="3dp"
                android:paddingHorizontal="@dimen/dimen_14dp"
                android:text="@string/if_you_have_query_call_us_msg"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/call_now_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/sub_headign_tv"
                android:layout_gravity="center_horizontal"
                android:layout_marginHorizontal="@dimen/dimen_20dp"
                android:layout_marginVertical="@dimen/dimen_20dp"
                android:background="@drawable/bg_button_yellow_less_round"
                android:backgroundTint="@color/colorPrimary_day_night"
                android:paddingHorizontal="@dimen/dimen_8dp"
                android:paddingVertical="@dimen/dimen_6dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="@string/call_now"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="32sp" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>